---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import globalStyles from '@/styles/global.css?inline';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
}

const { title, description, image, canonical, ogType = 'website', publishedTime, modifiedTime } = Astro.props;

const siteUrl = 'https://patasyhogar.com';
const ogImage = image ? `${siteUrl}${image}` : `${siteUrl}/og-default.jpg`;
const canonicalUrl = canonical || Astro.url.href;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#2d6a4f" id="meta-theme-color" />
    <meta name="color-scheme" content="light dark" />
    <meta name="robots" content="max-image-preview:large" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Preload critical font (latin covers all Spanish chars: á é í ó ú ñ ü) -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Display font for headings (self-hosted) -->
    <link rel="preload" href="/fonts/outfit-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Preconnect for resources loaded on article pages -->
    <link rel="dns-prefetch" href="https://m.media-amazon.com" />

    <!-- DNS prefetch for external resources (lightweight, no unused connection warnings) -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.google-analytics.com" />
    <link rel="dns-prefetch" href="https://static.cloudflareinsights.com" />
    <link rel="dns-prefetch" href="https://www.amazon.es" />
    <link rel="dns-prefetch" href="https://www.zooplus.es" />
    <link rel="dns-prefetch" href="https://www.tiendanimal.es" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="Patas y Hogar" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Patas y Hogar" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- SEO: alternate hreflang for Spanish content -->
    <link rel="alternate" hreflang="es" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <style set:html={globalStyles}></style>

    <!-- Dark mode: apply saved preference before paint -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme:dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
          var m = document.getElementById('meta-theme-color');
          if (m) m.content = '#121220';
        }
      })();
    </script>

    <!-- Schema.org -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Patas y Hogar",
        "url": "https://patasyhogar.com",
        "description": "Guías de compra y comparativas de productos para perros y gatos",
        "inLanguage": "es",
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://patasyhogar.com/buscar/?q={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      }
    </script>

    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <!-- Mobile bottom navigation -->
    <nav class="bottom-nav" aria-label="Navegación rápida">
      <a href="/" class={`bottom-nav-item ${currentPath === '/' ? 'bottom-nav-active' : ''}`}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        <span>Inicio</span>
      </a>
      <a href="/perros/" class={`bottom-nav-item ${currentPath.startsWith('/perros') ? 'bottom-nav-active' : ''}`}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M18 4c-1 0-3 1-4 2H10C9 5 7 4 6 4c-2 0-3 2-3 4 0 1 .5 2 1 3v5a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5c.5-1 1-2 1-3 0-2-1-4-3-4z"/><path d="M6 4L4 2"/><path d="M18 4l2-2"/><circle cx="9" cy="11" r="1.5" fill="currentColor" stroke="none"/><circle cx="15" cy="11" r="1.5" fill="currentColor" stroke="none"/><ellipse cx="12" cy="15" rx="2" ry="1.5"/></svg>
        <span>Perros</span>
      </a>
      <a href="/gatos/" class={`bottom-nav-item ${currentPath.startsWith('/gatos') ? 'bottom-nav-active' : ''}`}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M12 22c5 0 9-3.5 9-8s-1-8-3-10l-2 4h-8l-2-4C4 6 3 9.5 3 14s4 8 9 8z"/><circle cx="9" cy="13" r="1.5" fill="currentColor" stroke="none"/><circle cx="15" cy="13" r="1.5" fill="currentColor" stroke="none"/><path d="M10 17c.6.4 1.3.6 2 .6s1.4-.2 2-.6"/></svg>
        <span>Gatos</span>
      </a>
      <a href="/articulos/" class={`bottom-nav-item ${currentPath.startsWith('/articulos') ? 'bottom-nav-active' : ''}`}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>
        <span>Guías</span>
      </a>
      <a href="/buscar/" class={`bottom-nav-item ${currentPath.startsWith('/buscar') ? 'bottom-nav-active' : ''}`}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <span>Buscar</span>
      </a>
    </nav>

    <!-- Scroll reveal observer -->
    <script is:inline>
      (function() {
        var els = document.querySelectorAll('.reveal, .reveal-group');
        if (!els.length || !('IntersectionObserver' in window)) {
          els.forEach(function(el) { el.classList.add('revealed'); });
          return;
        }
        var obs = new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) {
              e.target.classList.add('revealed');
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        els.forEach(function(el) { obs.observe(el); });
      })();
    </script>

    <!-- GA4: load after page is interactive -->
    <script is:inline>
      window.addEventListener('load', function() {
        setTimeout(function() {
          var s = document.createElement('script');
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-NNXGD8G7GC';
          s.async = true;
          document.head.appendChild(s);
          s.onload = function() {
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            window.gtag = gtag;
            gtag('js', new Date());
            gtag('config', 'G-NNXGD8G7GC');
          };
        }, 2000);
      });

      // Track affiliate clicks (works even before GA loads, queues events)
      document.addEventListener('click', function(e) {
        var link = e.target.closest('a[rel*="sponsored"]');
        if (!link) return;
        var href = link.href || '';
        var tienda = 'otro';
        if (href.includes('amazon.')) tienda = 'amazon';
        else if (href.includes('zooplus.')) tienda = 'zooplus';
        else if (href.includes('tiendanimal.')) tienda = 'tiendanimal';
        if (typeof gtag === 'function') {
          gtag('event', 'affiliate_click', {
            event_category: 'afiliados',
            event_label: tienda,
            link_url: href,
            page_path: window.location.pathname
          });
        }
      });
    </script>
  </body>
</html>
