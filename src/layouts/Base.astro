---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import globalStyles from '@/styles/global.css?inline';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
}

const { title, description, image, canonical, ogType = 'website', publishedTime, modifiedTime } = Astro.props;

const siteUrl = 'https://patasyhogar.com';
const ogImage = image ? `${siteUrl}${image}` : `${siteUrl}/og-default.jpg`;
const canonicalUrl = canonical || Astro.url.href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#c2410c" id="meta-theme-color" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Preconnect to external resources -->
    <link rel="preconnect" href="https://m.media-amazon.com" crossorigin />
    <link rel="dns-prefetch" href="https://m.media-amazon.com" />
    <link rel="preconnect" href="https://static.cloudflareinsights.com" crossorigin />
    <link rel="dns-prefetch" href="https://static.cloudflareinsights.com" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="Patas y Hogar" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Patas y Hogar" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- SEO: alternate hreflang for Spanish content -->
    <link rel="alternate" hreflang="es" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <style set:html={globalStyles}></style>

    <!-- Dark mode: apply saved preference before paint -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme:dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
          var m = document.getElementById('meta-theme-color');
          if (m) m.content = '#0c0a09';
        }
      })();
    </script>

    <!-- Schema.org -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Patas y Hogar",
        "url": "https://patasyhogar.com",
        "description": "Guías de compra y comparativas de productos para perros y gatos",
        "inLanguage": "es"
      }
    </script>

    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <!-- GA4: load after page is interactive -->
    <script is:inline>
      window.addEventListener('load', function() {
        setTimeout(function() {
          var s = document.createElement('script');
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-NNXGD8G7GC';
          s.async = true;
          document.head.appendChild(s);
          s.onload = function() {
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            window.gtag = gtag;
            gtag('js', new Date());
            gtag('config', 'G-NNXGD8G7GC');
          };
        }, 2000);
      });

      // Track affiliate clicks (works even before GA loads, queues events)
      document.addEventListener('click', function(e) {
        var link = e.target.closest('a[rel*="sponsored"]');
        if (!link) return;
        var href = link.href || '';
        var tienda = 'otro';
        if (href.includes('amazon.')) tienda = 'amazon';
        else if (href.includes('zooplus.')) tienda = 'zooplus';
        else if (href.includes('tiendanimal.')) tienda = 'tiendanimal';
        if (typeof gtag === 'function') {
          gtag('event', 'affiliate_click', {
            event_category: 'afiliados',
            event_label: tienda,
            link_url: href,
            page_path: window.location.pathname
          });
        }
      });
    </script>
  </body>
</html>
