---
import Base from './Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

interface Props {
  articulo: CollectionEntry<'articulos'>;
}

const { articulo } = Astro.props;
const { titulo, descripcion, categoria, animal: artAnimal, fecha, actualizadoEn, tags, imagen, imagenAlt, faqs, tipo } = articulo.data;
const esInformativo = tipo === 'informativo';
const animalLabel = artAnimal === 'perro' ? '🐶 Perros' : artAnimal === 'gato' ? '🐱 Gatos' : '🐾 Perros y gatos';

// Reading time: ~200 words per minute, strip MDX syntax first
const wordCount = articulo.body
  .replace(/^---[\s\S]*?---/, '')
  .replace(/^import\s.+$/gm, '')
  .replace(/<[^>]+>/g, ' ')
  .replace(/[#*`_~\[\]()]/g, '')
  .trim()
  .split(/\s+/).length;
const minutosLectura = Math.max(1, Math.round(wordCount / 200));

// Related articles: prioritize same animal + shared tags, then same category
const allArticles = await getCollection('articulos', ({ slug }) => slug !== articulo.slug);
const animal = articulo.data.animal;
const articleTags = new Set(tags || []);

const scored = allArticles.map(a => {
  let score = 0;
  // Same tipo: +2
  if (a.data.tipo === tipo) score += 2;
  // Same category: +3
  if (a.data.categoria === categoria) score += 3;
  // Same animal or either is 'ambos': +2
  if (a.data.animal === animal || a.data.animal === 'ambos' || animal === 'ambos') score += 2;
  // Shared tags: +1 per tag
  (a.data.tags || []).forEach(t => { if (articleTags.has(t)) score += 1; });
  return { article: a, score };
});

const related = scored
  .filter(s => s.score > 0)
  .sort((a, b) => b.score - a.score || b.article.data.fecha.getTime() - a.article.data.fecha.getTime())
  .slice(0, 3)
  .map(s => s.article);

const categoriasInfo: Record<string, { nombre: string; icono: string }> = {
  alimentacion: { nombre: 'Alimentación', icono: '🥣' },
  higiene: { nombre: 'Higiene', icono: '🪮' },
  paseo: { nombre: 'Paseo y Transporte', icono: '🦮' },
  juguetes: { nombre: 'Juguetes', icono: '🧸' },
  hogar: { nombre: 'Hogar y Descanso', icono: '🏠' },
};

const catInfo = esInformativo
  ? { nombre: 'Cuidados', icono: '📖' }
  : categoriasInfo[categoria];

const fechaFormateada = fecha.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const actualizadoFormateado = actualizadoEn?.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const siteUrl = 'https://patasyhogar.com';

const articleUrl = `${siteUrl}/${esInformativo ? 'cuidados' : categoria}/${articulo.slug}/`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: titulo,
  description: descripcion,
  ...(imagen && { image: `${siteUrl}${imagen}` }),
  datePublished: fecha.toISOString(),
  dateModified: (actualizadoEn || fecha).toISOString(),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': articleUrl,
  },
  wordCount: wordCount,
  inLanguage: 'es',
  author: {
    '@type': 'Organization',
    name: 'Patas y Hogar',
    url: siteUrl,
    logo: `${siteUrl}/favicon.svg`,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Patas y Hogar',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/favicon.svg`,
    },
  },
  isPartOf: {
    '@type': 'WebSite',
    name: 'Patas y Hogar',
    url: siteUrl,
  },
};

const faqSchema = faqs && faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.pregunta,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.respuesta,
    },
  })),
} : null;

// HowTo schema: auto-detect articles with "### Paso N:" headings
const stepRegex = /^### Paso \d+:\s*(.+)$/gm;
const bodyText = articulo.body || '';
const steps: { name: string; text: string }[] = [];
let match;
while ((match = stepRegex.exec(bodyText)) !== null) {
  const stepName = match[1].trim();
  // Extract text until next heading or end
  const startIdx = match.index + match[0].length;
  const nextHeading = bodyText.indexOf('\n#', startIdx);
  const endIdx = nextHeading > -1 ? nextHeading : bodyText.length;
  const rawText = bodyText.slice(startIdx, endIdx)
    .replace(/<[^>]+>/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_`~]/g, '')
    .replace(/\n+/g, ' ')
    .trim();
  const text = rawText.slice(0, 300);
  if (stepName && text) steps.push({ name: stepName, text });
}

const howToSchema = steps.length >= 3 ? {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: titulo,
  description: descripcion,
  ...(imagen && { image: `${siteUrl}${imagen}` }),
  totalTime: `PT${minutosLectura * 2}M`,
  step: steps.map((s, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: s.name,
    text: s.text,
  })),
} : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: catInfo.nombre, item: `${siteUrl}/${esInformativo ? 'cuidados' : categoria}/` },
    { '@type': 'ListItem', position: 3, name: titulo },
  ],
};
---

<Base title={`${titulo} | Patas y Hogar`} description={descripcion} image={imagen} ogType="article" publishedTime={fecha.toISOString()} modifiedTime={(actualizadoEn || fecha).toISOString()}>
  <meta name="robots" content="max-image-preview:large" slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  {faqSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />}
  {howToSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(howToSchema)} slot="head" />}

  <article class="article-page">
    <nav class="breadcrumb" aria-label="Migas de pan">
      <a href="/">Inicio</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <a href={esInformativo ? '/cuidados/' : `/${categoria}/`}>{catInfo.nombre}</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <span class="breadcrumb-animal">{animalLabel}</span>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <span>{titulo}</span>
    </nav>

    <header class="article-header">
      <span class="article-category-badge">
        <span aria-hidden="true">{catInfo.icono}</span> {catInfo.nombre}
      </span>

      <h1 class="article-title">{titulo}</h1>
      <p class="article-description">{descripcion}</p>

      <div class="article-meta">
        <span class="article-author">Por <a href="/sobre-nosotros/" rel="author">Patas y Hogar</a></span>
        <time datetime={fecha.toISOString().split('T')[0]}>Publicado: {fechaFormateada}</time>
        {actualizadoFormateado && (
          <time datetime={(actualizadoEn as Date).toISOString().split('T')[0]} class="article-updated">
            ✅ Actualizado: {actualizadoFormateado}
          </time>
        )}
        <span>{minutosLectura} min lectura</span>
      </div>
    </header>

    {imagen && (
      <picture>
        <source srcset={imagen.replace(/\.(jpg|jpeg|png)$/i, '.webp')} type="image/webp" sizes="(max-width: 768px) 100vw, 800px" />
        <img
          src={imagen}
          alt={imagenAlt || titulo}
          width="800"
          height="400"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          sizes="(max-width: 768px) 100vw, 800px"
          style="width: 100%; height: auto; max-height: 400px; object-fit: cover; border-radius: 8px; margin-bottom: 1.5rem;"
        />
      </picture>
    )}

    {!esInformativo && (
      <div class="affiliate-disclaimer" role="note">
        <span aria-hidden="true">ℹ️</span>
        <span>
          Este artículo contiene enlaces de afiliados. Si compras a través de
          ellos podemos recibir una pequeña comisión <strong>sin coste adicional
          para ti</strong>.
        </span>
      </div>
    )}

    <nav class="toc" id="toc" aria-label="Tabla de contenidos" style="display:none;">
      <p class="toc-title">En este artículo</p>
      <ol class="toc-list" id="toc-list"></ol>
    </nav>

    <div class="prose" id="article-content">
      <slot />
    </div>

    {tags && tags.length > 0 && (
      <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border);">
        <strong style="font-size: 0.85rem; color: var(--color-text-muted);">Etiquetas:</strong>
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem;">
          {tags.map(tag => {
            const tagSlug = tag.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9áéíóúñü-]/g, '');
            return (
              <a href={`/tags/${tagSlug}/`} class="badge" style="background: var(--color-bg-muted); color: var(--color-text-muted); text-decoration: none;">
                {tag}
              </a>
            );
          })}
        </div>
      </div>
    )}

    {faqs && faqs.length > 0 && (
      <section class="faq-section" aria-labelledby="faq-titulo">
        <h2 id="faq-titulo">Preguntas frecuentes</h2>
        <div class="faq-list">
          {faqs.map(f => (
            <details class="faq-item">
              <summary class="faq-pregunta">{f.pregunta}</summary>
              <p class="faq-respuesta">{f.respuesta}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <div class="article-newsletter">
      <p class="article-newsletter-title">📬 ¿Te ha sido útil? Recibe más contenido como este</p>
      <p class="article-newsletter-desc">Comparativas, consejos y novedades para tu mascota. Sin spam, solo contenido útil.</p>
      <form
        action="/api/subscribe"
        method="post"
        class="newsletter-form article-newsletter-form"
      >
        <input
          type="email"
          name="email"
          placeholder="tu@email.com"
          required
          aria-label="Tu email"
          class="article-newsletter-input"
        />
        <button type="submit" class="newsletter-btn">Suscribirme</button>
      </form>
      <p id="newsletter-msg-article" style="font-size: 0.8rem; margin-top: 0.5rem;"></p>
    </div>

    {related.length > 0 && (
      <section style="margin-top: 3rem; padding-top: 2rem; border-top: 2px solid var(--color-border);">
        <h2 style="font-size: 1.3rem; font-weight: 700; margin-bottom: 1.25rem;">
          Artículos relacionados
        </h2>
        <div class="articles-grid">
          {related.map(a => (
            <ArticleCard articulo={a} />
          ))}
        </div>
        <div style="text-align: center; margin-top: 1.5rem;">
          <a href={esInformativo ? '/cuidados/' : `/${categoria}/`} class="affiliate-button" style="display: inline-flex; font-size: 0.9rem; padding: 0.65rem 1.5rem;">
            {catInfo.icono} Ver más en {catInfo.nombre} →
          </a>
        </div>
      </section>
    )}

    <div class="back-to-top-wrap">
      <a href="#main-content" class="back-to-top-link">↑ Volver arriba</a>
    </div>
  </article>

  <script>
    // Wrap tables for horizontal scroll on mobile
    document.querySelectorAll('.prose table').forEach(table => {
      if (!table.parentElement?.classList.contains('table-wrapper')) {
        const wrapper = document.createElement('div');
        wrapper.className = 'table-wrapper';
        table.parentNode?.insertBefore(wrapper, table);
        wrapper.appendChild(table);
      }
    });

    const content = document.getElementById('article-content');
    const tocNav = document.getElementById('toc');
    const tocList = document.getElementById('toc-list');
    if (content && tocNav && tocList) {
      const headings = content.querySelectorAll('h2');
      if (headings.length >= 3) {
        headings.forEach((h, i) => {
          if (!h.id) h.id = `section-${i}`;
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = `#${h.id}`;
          a.textContent = h.textContent;
          li.appendChild(a);
          tocList.appendChild(li);
        });
        tocNav.style.display = '';
      }
    }
  </script>

  <style>
    .toc {
      background: var(--color-bg-muted);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
    }
    .toc-title {
      font-weight: 700;
      font-size: 0.95rem;
      margin-bottom: 0.75rem;
      color: var(--color-text);
    }
    .toc-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .toc-list li {
      padding-left: 0;
    }
    .toc-list a {
      color: var(--color-primary);
      text-decoration: none;
      font-size: 0.9rem;
      line-height: 1.5;
      transition: color var(--transition);
    }
    .toc-list a:hover {
      color: var(--color-primary-dark);
      text-decoration: underline;
    }
    .toc-list li::before {
      content: counter(toc-counter) ". ";
      counter-increment: toc-counter;
      font-weight: 600;
      color: var(--color-text-muted);
      font-size: 0.85rem;
    }
    .toc-list {
      counter-reset: toc-counter;
    }

    .article-author a {
      color: var(--color-primary);
      text-decoration: none;
      font-weight: 600;
    }
    .article-author a:hover {
      text-decoration: underline;
    }

    .back-to-top-wrap {
      text-align: center;
      margin-top: 2.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--color-border);
    }
    .back-to-top-link {
      display: inline-block;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--color-primary);
      text-decoration: none;
      padding: 0.5rem 1.25rem;
      border: 1.5px solid var(--color-primary);
      border-radius: 99px;
      transition: all 0.2s;
    }
    .back-to-top-link:hover {
      background: var(--color-primary);
      color: white;
    }

    .article-updated {
      color: var(--color-secondary);
      font-weight: 600;
    }

    .article-newsletter {
      margin-top: 2.5rem;
      padding: 1.5rem;
      background: var(--color-bg-muted);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      text-align: center;
    }
    .article-newsletter-title {
      font-weight: 700;
      font-size: 1.05rem;
      margin-bottom: 0.4rem;
    }
    .article-newsletter-desc {
      font-size: 0.85rem;
      color: var(--color-text-muted);
      margin-bottom: 1rem;
    }
    .article-newsletter-form {
      max-width: 420px;
      margin: 0 auto;
      display: flex;
      gap: 0.5rem;
    }
    .article-newsletter-input {
      flex: 1;
      padding: 0.6rem 0.875rem;
      border-radius: 100px;
      border: 1px solid var(--color-border);
      background: var(--color-bg-card);
      color: var(--color-text);
      font-size: 0.85rem;
      font-family: var(--font-sans);
      outline: none;
      transition: border-color var(--transition);
    }
    .article-newsletter-input:focus {
      border-color: var(--color-primary);
    }
    .article-newsletter-input::placeholder {
      color: var(--color-text-light);
    }
    @media (max-width: 480px) {
      .article-newsletter-form {
        flex-direction: column;
      }
    }

    .breadcrumb-animal {
      font-size: 0.85rem;
      color: var(--color-text-muted);
    }

    /* FAQ */
    .faq-section {
      margin-top: 2.5rem;
      padding-top: 2rem;
      border-top: 2px solid var(--color-border);
    }
    .faq-section h2 {
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 1.25rem;
    }
    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .faq-item {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      overflow: hidden;
    }
    .faq-pregunta {
      background: var(--color-bg-muted);
      padding: 0.875rem 1.25rem;
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
      user-select: none;
    }
    .faq-pregunta::-webkit-details-marker {
      display: none;
    }
    .faq-pregunta::before {
      content: 'P: ';
      color: var(--color-primary);
      font-weight: 700;
      flex-shrink: 0;
    }
    .faq-pregunta::after {
      content: '+';
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--color-primary);
      flex-shrink: 0;
      transition: transform 0.2s;
    }
    .faq-item[open] .faq-pregunta::after {
      content: '−';
    }
    .faq-respuesta {
      padding: 0.875rem 1.25rem;
      font-size: 0.9rem;
      color: var(--color-text-muted);
      line-height: 1.6;
      margin: 0;
    }
  </style>
</Base>
