---
import Base from './Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';

import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

interface Props {
  articulo: CollectionEntry<'articulos'>;
}

const { articulo } = Astro.props;
const { titulo, descripcion, categoria, fecha, actualizadoEn, tags, imagen, imagenAlt, faqs } = articulo.data;

// Related articles: same category, excluding current, max 3, most recent first
const allArticles = await getCollection('articulos', ({ data, slug }) =>
  data.categoria === categoria && slug !== articulo.slug
);
const related = allArticles
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime())
  .slice(0, 3);

const categoriasInfo: Record<string, { nombre: string; icono: string }> = {
  alimentacion: { nombre: 'Alimentación', icono: '🥣' },
  higiene: { nombre: 'Higiene', icono: '🪮' },
  descanso: { nombre: 'Descanso y Transporte', icono: '🏠' },
  comportamiento: { nombre: 'Enriquecimiento', icono: '🧸' },
};

const catInfo = categoriasInfo[categoria];

const fechaFormateada = fecha.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const actualizadoFormateado = actualizadoEn?.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const siteUrl = 'https://patasyhogar.com';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: titulo,
  description: descripcion,
  ...(imagen && { image: `${siteUrl}${imagen}` }),
  datePublished: fecha.toISOString(),
  dateModified: (actualizadoEn || fecha).toISOString(),
  publisher: {
    '@type': 'Organization',
    name: 'Patas y Hogar',
    url: siteUrl,
  },
};

const faqSchema = faqs && faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.pregunta,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.respuesta,
    },
  })),
} : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: catInfo.nombre, item: `${siteUrl}/${categoria}` },
    { '@type': 'ListItem', position: 3, name: titulo },
  ],
};
---

<Base title={`${titulo} | Patas y Hogar`} description={descripcion}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  {faqSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />}

  <article class="article-page">
    <nav class="breadcrumb" aria-label="Migas de pan">
      <a href="/">Inicio</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <a href={`/${categoria}`}>{catInfo.nombre}</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <span>{titulo}</span>
    </nav>

    <header class="article-header">
      <span class="article-category-badge">
        <span aria-hidden="true">{catInfo.icono}</span> {catInfo.nombre}
      </span>

      <h1 class="article-title">{titulo}</h1>
      <p class="article-description">{descripcion}</p>

      <div class="article-meta">
        <time datetime={fecha.toISOString().split('T')[0]}>Publicado: {fechaFormateada}</time>
        {actualizadoFormateado && (
          <time datetime={(actualizadoEn as Date).toISOString().split('T')[0]}>Actualizado: {actualizadoFormateado}</time>
        )}
        <span>~5 min lectura</span>
      </div>
    </header>

    {imagen && (
      <img
        src={imagen}
        alt={imagenAlt || titulo}
        width="800"
        height="400"
        style="width: 100%; height: auto; max-height: 400px; object-fit: cover; border-radius: 8px; margin-bottom: 1.5rem;"
      />
    )}

    <div class="affiliate-disclaimer" role="note">
      <span aria-hidden="true">ℹ️</span>
      <span>
        Este artículo contiene enlaces de afiliados. Si compras a través de
        ellos podemos recibir una pequeña comisión <strong>sin coste adicional
        para ti</strong>.
      </span>
    </div>

    <nav class="toc" id="toc" aria-label="Tabla de contenidos" style="display:none;">
      <p class="toc-title">En este artículo</p>
      <ol class="toc-list" id="toc-list"></ol>
    </nav>

    <div class="prose" id="article-content">
      <slot />
    </div>

    {tags && tags.length > 0 && (
      <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border);">
        <strong style="font-size: 0.85rem; color: var(--color-text-muted);">Etiquetas:</strong>
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem;">
          {tags.map(tag => (
            <span class="badge" style="background: var(--color-bg-muted); color: var(--color-text-muted);">
              {tag}
            </span>
          ))}
        </div>
      </div>
    )}

    {faqs && faqs.length > 0 && (
      <section class="faq-section" aria-labelledby="faq-titulo">
        <h2 id="faq-titulo">Preguntas frecuentes</h2>
        <dl class="faq-list">
          {faqs.map(f => (
            <div class="faq-item">
              <dt class="faq-pregunta">{f.pregunta}</dt>
              <dd class="faq-respuesta">{f.respuesta}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    {related.length > 0 && (
      <section style="margin-top: 3rem; padding-top: 2rem; border-top: 2px solid var(--color-border);">
        <h2 style="font-size: 1.3rem; font-weight: 700; margin-bottom: 1.25rem;">
          Artículos relacionados
        </h2>
        <div class="articles-grid">
          {related.map(a => (
            <ArticleCard articulo={a} />
          ))}
        </div>
      </section>
    )}
  </article>

  <script>
    const content = document.getElementById('article-content');
    const tocNav = document.getElementById('toc');
    const tocList = document.getElementById('toc-list');
    if (content && tocNav && tocList) {
      const headings = content.querySelectorAll('h2');
      if (headings.length >= 3) {
        headings.forEach((h, i) => {
          if (!h.id) h.id = `section-${i}`;
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = `#${h.id}`;
          a.textContent = h.textContent;
          li.appendChild(a);
          tocList.appendChild(li);
        });
        tocNav.style.display = '';
      }
    }
  </script>

  <style>
    .toc {
      background: var(--color-bg-muted);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
    }
    .toc-title {
      font-weight: 700;
      font-size: 0.95rem;
      margin-bottom: 0.75rem;
      color: var(--color-text);
    }
    .toc-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .toc-list li {
      padding-left: 0;
    }
    .toc-list a {
      color: var(--color-primary);
      text-decoration: none;
      font-size: 0.9rem;
      line-height: 1.5;
      transition: color var(--transition);
    }
    .toc-list a:hover {
      color: var(--color-primary-dark);
      text-decoration: underline;
    }
    .toc-list li::before {
      content: counter(toc-counter) ". ";
      counter-increment: toc-counter;
      font-weight: 600;
      color: var(--color-text-muted);
      font-size: 0.85rem;
    }
    .toc-list {
      counter-reset: toc-counter;
    }

    /* FAQ */
    .faq-section {
      margin-top: 2.5rem;
      padding-top: 2rem;
      border-top: 2px solid var(--color-border);
    }
    .faq-section h2 {
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 1.25rem;
    }
    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .faq-item {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      overflow: hidden;
    }
    .faq-pregunta {
      background: var(--color-bg-muted);
      padding: 0.875rem 1.25rem;
      font-weight: 600;
      font-size: 0.95rem;
      cursor: default;
    }
    .faq-pregunta::before {
      content: 'P: ';
      color: var(--color-primary);
      font-weight: 700;
    }
    .faq-respuesta {
      padding: 0.875rem 1.25rem;
      font-size: 0.9rem;
      color: var(--color-text-muted);
      line-height: 1.6;
      margin: 0;
    }
  </style>
</Base>
