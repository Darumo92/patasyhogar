---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articulos = await getCollection('articulos', ({ data }) =>
  data.animal === 'perro' || data.animal === 'ambos'
);
const articulosOrdenados = articulos.sort(
  (a, b) => b.data.fecha.getTime() - a.data.fecha.getTime()
);

const destacados = articulosOrdenados.filter(a => a.data.destacado).slice(0, 3);
const resto = articulosOrdenados.filter(a => !destacados.includes(a));

const categorias = [
  { slug: 'alimentacion', nombre: 'Alimentación', icono: '🥣' },
  { slug: 'higiene', nombre: 'Higiene', icono: '🪮' },
  { slug: 'descanso', nombre: 'Descanso', icono: '🏠' },
  { slug: 'comportamiento', nombre: 'Enriquecimiento', icono: '🧸' },
];

const porCategoria = categorias.map(cat => ({
  ...cat,
  articulos: articulosOrdenados.filter(a => a.data.categoria === cat.slug),
})).filter(c => c.articulos.length > 0);

const siteUrl = 'https://patasyhogar.com';
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Perros' },
  ],
};
---

<Base
  title="Guías y comparativas para perros 2026 | Patas y Hogar"
  description="Todas las guías de compra y comparativas de productos para perros: pienso, camas, juguetes, higiene, transporte y más. Análisis honestos para elegir lo mejor."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <div class="category-page-header">
    <div class="container">
      <div class="category-icon-large" aria-hidden="true">🐶</div>
      <h1>Todo para tu perro</h1>
      <p>{articulosOrdenados.length} guías y comparativas para elegir lo mejor para tu perro</p>
    </div>
  </div>

  <div class="container section">
    <nav class="breadcrumb" aria-label="Migas de pan">
      <a href="/">Inicio</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <span>Perros</span>
    </nav>

    <div class="animal-landing-intro">
      <p>Hemos analizado decenas de productos para perros en España: desde el mejor pienso según la raza y edad de tu perro, hasta camas ortopédicas, juguetes de estimulación mental, antiparasitarios y accesorios de paseo. Cada guía incluye comparativa de precios entre tiendas para que encuentres la mejor oferta.</p>
    </div>

    {/* Quick nav by category */}
    <div class="animal-landing-cats">
      {porCategoria.map(cat => (
        <a href={`#${cat.slug}`} class="animal-landing-cat-link">
          <span aria-hidden="true">{cat.icono}</span>
          {cat.nombre}
          <span class="animal-landing-cat-count">{cat.articulos.length}</span>
        </a>
      ))}
    </div>

    {/* Destacados */}
    {destacados.length > 0 && (
      <div style="margin-bottom: 3rem;">
        <h2 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 1.25rem; color: var(--color-primary);">
          ⭐ Guías más populares
        </h2>
        <div class="articles-grid">
          {destacados.map(a => <ArticleCard articulo={a} />)}
        </div>
      </div>
    )}

    {/* By category */}
    {porCategoria.map(cat => (
      <section id={cat.slug} style="margin-bottom: 3rem;">
        <h2 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 1.25rem;">
          {cat.icono} {cat.nombre}
          <span style="font-weight: 400; font-size: 0.85rem; color: var(--color-text-muted); margin-left: 0.5rem;">
            {cat.articulos.length} {cat.articulos.length === 1 ? 'artículo' : 'artículos'}
          </span>
        </h2>
        <div class="articles-grid">
          {cat.articulos.map(a => <ArticleCard articulo={a} />)}
        </div>
      </section>
    ))}
  </div>
</Base>

<style>
  .animal-landing-intro {
    background: var(--color-bg-muted);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin-bottom: 2rem;
    border-left: 4px solid var(--color-primary);
  }
  .animal-landing-intro p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }
  .animal-landing-cats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }
  .animal-landing-cat-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: 99px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    transition: all 0.2s;
  }
  .animal-landing-cat-link:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .animal-landing-cat-count {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
</style>
