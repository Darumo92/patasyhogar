---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import SmoothScroll from '@/components/SmoothScroll.astro';
import { getCollection } from 'astro:content';

const articulos = await getCollection('articulos', ({ data }) => data.tipo === 'informativo');
const articulosOrdenados = articulos.sort(
  (a, b) => b.data.fecha.getTime() - a.data.fecha.getTime()
);

const destacados = articulosOrdenados.filter(a => a.data.destacado).slice(0, 3);

const grupos = [
  { id: 'perros', nombre: 'Cuidados para perros', animal: 'perro', articulos: articulosOrdenados.filter(a => a.data.animal === 'perro') },
  { id: 'gatos', nombre: 'Cuidados para gatos', animal: 'gato', articulos: articulosOrdenados.filter(a => a.data.animal === 'gato') },
  { id: 'ambos', nombre: 'Para perros y gatos', animal: 'ambos', articulos: articulosOrdenados.filter(a => a.data.animal === 'ambos') },
].filter(g => g.articulos.length > 0);

const siteUrl = 'https://patasyhogar.com';
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Cuidados', item: `${siteUrl}/cuidados/` },
  ],
};
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Cuidados y consejos para mascotas',
  numberOfItems: articulosOrdenados.length,
  itemListElement: articulosOrdenados.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${siteUrl}/cuidados/${a.slug}/`,
    name: a.data.titulo,
  })),
};
const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Cuidados y consejos para mascotas',
  description: 'Guías informativas sobre cuidados, salud, comportamiento y bienestar de perros y gatos.',
  url: `${siteUrl}/cuidados/`,
  numberOfItems: articulosOrdenados.length,
  inLanguage: 'es',
  isPartOf: {
    '@type': 'WebSite',
    name: 'Patas y Hogar',
    url: siteUrl,
  },
};
---

<Base
  title={`Cuidados para perros y gatos ${new Date().getFullYear()} | Patas y Hogar`}
  description="Guías informativas sobre cuidados, salud, comportamiento y bienestar de perros y gatos. Consejos prácticos de expertos para cuidar mejor a tu mascota."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} slot="head" />

  <div class="category-page-header">
    <div class="container">
      <div class="category-icon-large" aria-hidden="true"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg></div>
      <h1>Cuidados y consejos</h1>
      <p>{articulosOrdenados.length} guías informativas para el bienestar de tu mascota</p>

      {articulosOrdenados.length > 0 && (
        <nav class="subcat-nav" aria-label="Filtrar por animal">
          {grupos.map(g => (
            <a href={`#${g.id}`} class="subcat-nav-link">
              <span aria-hidden="true">
                {g.animal === 'perro' && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5"/><path d="M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.855-1.45-2.239-2.5"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75z"/><path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444a11.702 11.702 0 0 0-.493-3.309"/></svg>}
                {g.animal === 'gato' && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15V3.5a.5.5 0 0 1 .8-.4l4.2 3.15a.5.5 0 0 0 .6 0L13.8 3.1a.5.5 0 0 1 .8.4V15M2 15a9 9 0 1 0 18 0 9 9 0 0 0-18 0zM10 13v.01M14 13v.01M10 17c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/></svg>}
                {g.animal === 'ambos' && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><circle cx="4" cy="8" r="2"/><circle cx="2" cy="16" r="2"/><path d="M15.8 13.3a1.5 1.5 0 0 0-2.2-.8 6 6 0 0 1-6.2 0 1.5 1.5 0 0 0-2.2.8l-.7 1.4A2 2 0 0 0 6.3 17h11.4a2 2 0 0 0 1.8-2.7Z"/></svg>}
              </span>
              <span>{g.nombre}</span>
              <span class="subcat-nav-count">{g.articulos.length}</span>
            </a>
          ))}
        </nav>
      )}
    </div>
  </div>

  <div class="container section">
    <nav class="breadcrumb" aria-label="Migas de pan">
      <a href="/">Inicio</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <span>Cuidados</span>
    </nav>

    <div class="category-intro">
      <p>Todo lo que necesitas saber para cuidar mejor a tu perro o gato: alimentación, salud, comportamiento, higiene y bienestar. Guías prácticas basadas en fuentes veterinarias para que tomes las mejores decisiones para tu mascota.</p>
    </div>

    {articulosOrdenados.length > 0 ? (
      <>
        {/* Destacados */}
        {destacados.length > 0 && (
          <div style="margin-bottom: 3rem;">
            <h2 class="subcat-heading">
              <span class="subcat-heading-icon" aria-hidden="true">⭐</span>
              Guías destacadas
            </h2>
            <div class="articles-grid">
              {destacados.map((a, i) => <ArticleCard articulo={a} eager={i < 2} />)}
            </div>
          </div>
        )}

        {/* Por animal */}
        {grupos.map(g => (
          <section id={g.id} class="subcat-section">
            <h2 class="subcat-heading">
              <span class="subcat-heading-icon" aria-hidden="true">
                {g.animal === 'perro' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5"/><path d="M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.855-1.45-2.239-2.5"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75z"/><path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444a11.702 11.702 0 0 0-.493-3.309"/></svg>}
                {g.animal === 'gato' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15V3.5a.5.5 0 0 1 .8-.4l4.2 3.15a.5.5 0 0 0 .6 0L13.8 3.1a.5.5 0 0 1 .8.4V15M2 15a9 9 0 1 0 18 0 9 9 0 0 0-18 0zM10 13v.01M14 13v.01M10 17c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/></svg>}
                {g.animal === 'ambos' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><circle cx="4" cy="8" r="2"/><circle cx="2" cy="16" r="2"/><path d="M15.8 13.3a1.5 1.5 0 0 0-2.2-.8 6 6 0 0 1-6.2 0 1.5 1.5 0 0 0-2.2.8l-.7 1.4A2 2 0 0 0 6.3 17h11.4a2 2 0 0 0 1.8-2.7Z"/></svg>}
              </span>
              {g.nombre}
              <span class="subcat-heading-count">
                {g.articulos.length} {g.articulos.length === 1 ? 'artículo' : 'artículos'}
              </span>
            </h2>
            <div class="articles-grid">
              {g.articulos.map(a => <ArticleCard articulo={a} />)}
            </div>
          </section>
        ))}
      </>
    ) : (
      <div class="text-center" style="padding: 4rem 0;">
        <div style="margin-bottom: 1rem;" aria-hidden="true"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-text-muted);"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg></div>
        <h2 style="margin-bottom: 0.5rem;">Próximamente</h2>
        <p class="text-muted">Estamos preparando las primeras guías de cuidados.</p>
        <a href="/" class="affiliate-button" style="margin-top: 1.5rem; display: inline-flex;">
          ← Volver al inicio
        </a>
      </div>
    )}
  </div>
</Base>

<SmoothScroll />

<style>
  .category-intro {
    background: var(--color-bg-muted);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin-bottom: 2rem;
    border-left: 4px solid var(--color-primary);
  }
  .category-intro p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }
  .subcat-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }
  .subcat-nav-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.85rem;
    border: 1.5px solid var(--color-border);
    border-radius: 99px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    transition: all 0.2s;
    white-space: nowrap;
    background: var(--color-bg-card);
  }
  .subcat-nav-link:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
  .subcat-nav-count {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    background: var(--color-bg-muted);
    padding: 0.1rem 0.4rem;
    border-radius: 99px;
  }
  .subcat-section {
    margin-bottom: 3rem;
  }
  .subcat-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-border);
    flex-wrap: wrap;
  }
  .subcat-heading-icon {
    font-size: 1.2rem;
  }
  .subcat-heading-count {
    font-weight: 400;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-left: auto;
  }
  @media (max-width: 640px) {
    .subcat-nav { gap: 0.4rem; }
    .subcat-nav-link { padding: 0.4rem 0.7rem; font-size: 0.75rem; }
    .subcat-heading { font-size: 1.05rem; }
    .subcat-heading-count { width: 100%; margin-left: 0; margin-top: 0.25rem; }
  }
</style>
