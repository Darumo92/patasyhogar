---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import AnimalFilter from '@/components/AnimalFilter.astro';
import { getCollection } from 'astro:content';

const articulos = await getCollection('articulos', ({ data }) => data.tipo === 'informativo');
const articulosOrdenados = articulos.sort(
  (a, b) => b.data.fecha.getTime() - a.data.fecha.getTime()
);

const destacados = articulosOrdenados.filter(a => a.data.destacado).slice(0, 3);
const resto = articulosOrdenados.filter(a => !destacados.includes(a));

const perroCount = articulosOrdenados.filter(a => a.data.animal === 'perro' || a.data.animal === 'ambos').length;
const gatoCount = articulosOrdenados.filter(a => a.data.animal === 'gato' || a.data.animal === 'ambos').length;

const siteUrl = 'https://patasyhogar.com';
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Cuidados' },
  ],
};
const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Cuidados y consejos para mascotas',
  description: 'Guías informativas sobre cuidados, salud, comportamiento y bienestar de perros y gatos.',
  url: `${siteUrl}/cuidados/`,
  numberOfItems: articulosOrdenados.length,
  inLanguage: 'es',
};
---

<Base
  title="Cuidados para perros y gatos 2026 | Consejos y guías | Patas y Hogar"
  description="Guías informativas sobre cuidados, salud, comportamiento y bienestar de perros y gatos. Consejos prácticos de expertos para cuidar mejor a tu mascota."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} slot="head" />

  <div class="category-page-header">
    <div class="container">
      <div class="category-icon-large" aria-hidden="true">📖</div>
      <h1>Cuidados y consejos</h1>
      <p>{articulosOrdenados.length} guías informativas para el bienestar de tu mascota</p>
    </div>
  </div>

  <div class="container section">
    <nav class="breadcrumb" aria-label="Migas de pan">
      <a href="/">Inicio</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <span>Cuidados</span>
    </nav>

    <div class="cuidados-intro">
      <p>Todo lo que necesitas saber para cuidar mejor a tu perro o gato: alimentación, salud, comportamiento, higiene y bienestar. Guías prácticas basadas en fuentes veterinarias para que tomes las mejores decisiones para tu mascota.</p>
    </div>

    {articulosOrdenados.length > 0 ? (
      <>
        {perroCount > 0 && gatoCount > 0 && (
          <AnimalFilter perroCount={perroCount} gatoCount={gatoCount} totalCount={articulosOrdenados.length} />
        )}

        {destacados.length > 0 && (
          <div style="margin-bottom: 3rem;">
            <h2 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 1.25rem; color: var(--color-primary);">
              Guías destacadas
            </h2>
            <div class="articles-grid">
              {destacados.map(a => <ArticleCard articulo={a} />)}
            </div>
          </div>
        )}

        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem;">
          <h2 style="font-size: 1.2rem; font-weight: 700;">
            {destacados.length > 0 ? 'Todas las guías' : 'Guías de cuidados'}
          </h2>
          <p class="text-muted" style="font-size: 0.875rem;">
            {articulosOrdenados.length} {articulosOrdenados.length === 1 ? 'artículo' : 'artículos'}
          </p>
        </div>
        <div class="articles-grid">
          {(destacados.length > 0 ? resto : articulosOrdenados).map(a => (
            <ArticleCard articulo={a} />
          ))}
        </div>
      </>
    ) : (
      <div class="text-center" style="padding: 4rem 0;">
        <p style="font-size: 3rem; margin-bottom: 1rem;">📖</p>
        <h2 style="margin-bottom: 0.5rem;">Próximamente</h2>
        <p class="text-muted">Estamos preparando las primeras guías de cuidados.</p>
        <a href="/" class="affiliate-button" style="margin-top: 1.5rem; display: inline-flex;">
          ← Volver al inicio
        </a>
      </div>
    )}
  </div>
</Base>

<style>
  .cuidados-intro {
    background: var(--color-bg-muted);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin-bottom: 2.5rem;
    border-left: 4px solid var(--color-primary);
  }
  .cuidados-intro p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }
</style>
