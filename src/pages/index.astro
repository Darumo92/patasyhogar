---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import AnimalFilter from '@/components/AnimalFilter.astro';
import CategoryIcon from '@/components/CategoryIcon.astro';
import { getCollection } from 'astro:content';

const articulos = await getCollection('articulos');

const destacados = articulos
  .filter(a => a.data.destacado)
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime());

const recientes = articulos
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime())
  .slice(0, 4);

const perroCount = recientes.filter(a => a.data.animal === 'perro' || a.data.animal === 'ambos').length;
const gatoCount = recientes.filter(a => a.data.animal === 'gato' || a.data.animal === 'ambos').length;

const siteUrl = 'https://patasyhogar.com';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Patas y Hogar',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${siteUrl}/favicon.svg`,
  },
  description: 'Guías de compra y comparativas de productos para perros y gatos',
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'contacto@patasyhogar.com',
    contactType: 'customer service',
    availableLanguage: 'es',
  },
  foundingDate: '2026',
  areaServed: 'ES',
  availableLanguage: 'es',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Últimos análisis de productos para mascotas',
  numberOfItems: recientes.length,
  itemListElement: recientes.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${siteUrl}/${a.data.tipo === 'informativo' ? 'cuidados' : a.data.categoria}/${a.slug}/`,
    name: a.data.titulo,
  })),
};

const categorias = [
  {
    slug: 'alimentacion',
    nombre: 'Alimentación',
    descripcion: 'Pienso, húmeda, snacks, fuentes y comederos para perros y gatos',
    count: articulos.filter(a => a.data.categoria === 'alimentacion').length,
  },
  {
    slug: 'higiene',
    nombre: 'Higiene',
    descripcion: 'Arena, areneros, cepillos, champús y cuidado diario',
    count: articulos.filter(a => a.data.categoria === 'higiene').length,
  },
  {
    slug: 'paseo',
    nombre: 'Paseo y Transporte',
    descripcion: 'Arneses, correas, transportines, ropa y accesorios de viaje',
    count: articulos.filter(a => a.data.categoria === 'paseo').length,
  },
  {
    slug: 'juguetes',
    nombre: 'Juguetes',
    descripcion: 'Juguetes interactivos, rascadores, mordedores y estimulación mental',
    count: articulos.filter(a => a.data.categoria === 'juguetes').length,
  },
  {
    slug: 'hogar',
    nombre: 'Hogar y Descanso',
    descripcion: 'Camas, mantas, protectores y accesorios para casa',
    count: articulos.filter(a => a.data.categoria === 'hogar').length,
  },
  {
    slug: 'cuidados',
    nombre: 'Cuidados',
    descripcion: 'Guías sobre salud, comportamiento y bienestar de tu mascota',
    count: articulos.filter(a => a.data.tipo === 'informativo').length,
  },
];
---

<Base
  title="Patas y Hogar · Guías y comparativas para perros y gatos"
  description="Análisis honestos y comparativas de productos para perros y gatos. Pienso, accesorios, higiene, camas y transportines. Todo lo que tu mascota necesita."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head" />
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">
        Lo mejor para tu <span>perro y tu gato</span>,<br />
        sin perder tiempo buscando
      </h1>
      <p class="hero-subtitle">
        Analizamos productos en Amazon, Zooplus y Tiendanimal para que tú solo tengas que elegir.
      </p>
      <div class="hero-cta">
        <a href="/perros/" class="hero-cta-btn hero-cta-dog">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 5h2"/><path d="M19 12c-.667 5.333-2.333 8-5 8h-4c-2.667 0-4.333-2.667-5-8"/><path d="M11 16c0 .667.333 1 1 1s1-.333 1-1h-2"/><path d="M12 18v2"/><path d="M10 11v.01"/><path d="M14 11v.01"/><path d="M5 4l6 .97-6.238 6.688a1.021 1.021 0 0 1-1.41.111.953.953 0 0 1-.327-.954l1.975-6.815"/><path d="M19 4l-6 .97 6.238 6.688c.358.408.989.458 1.41.111a.953.953 0 0 0 .327-.954l-1.975-6.815"/></svg>
          Guías para perros
        </a>
        <a href="/gatos/" class="hero-cta-btn hero-cta-cat">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 3v10a8 8 0 1 1-16 0v-10l3.432 3.432a7.963 7.963 0 0 1 4.568-1.432c1.769 0 3.403.574 4.728 1.546l3.272-3.546"/><path d="M2 16h5l-4 4"/><path d="M22 16h-5l4 4"/><path d="M11 16a1 1 0 1 0 2 0 1 1 0 1 0-2 0"/><path d="M9 11v.01"/><path d="M15 11v.01"/></svg>
          Guías para gatos
        </a>
      </div>
      <p class="hero-meta">
        Precios actualizados en marzo 2026 · Comparados en 3 tiendas
      </p>
    </div>
  </section>

  <!-- Categorías -->
  <section class="section" style="background: var(--color-bg-muted); border-bottom: 1px solid var(--color-border);">
    <div class="container">
      <h2 class="section-title">Explora por categoría</h2>
      <p class="section-subtitle">Encuentra exactamente lo que buscas para tu mascota</p>
      <div class="categories-grid reveal-group">
        {categorias.map(cat => (
          <a href={`/${cat.slug}/`} class="category-card">
            <span class="category-icon" aria-hidden="true"><CategoryIcon categoria={cat.slug} size={24} /></span>
            <div class="category-info">
              <h3>{cat.nombre}</h3>
              <p>{cat.descripcion}</p>
              {cat.count > 0 && (
                <p style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--color-primary); font-weight: 600;">
                  {cat.count} {cat.count === 1 ? 'artículo' : 'artículos'}
                </p>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Guías destacadas -->
  {destacados.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title reveal">Guías destacadas</h2>
        <p class="section-subtitle reveal">Nuestros análisis más completos y populares</p>
        <div class="articles-grid reveal-group">
          {destacados.slice(0, 6).map((articulo, i) => (
            <ArticleCard articulo={articulo} eager={i < 2} />
          ))}
        </div>
        {destacados.length > 6 && (
          <div class="text-center" style="margin-top: 1.5rem;">
            <a href="/articulos/" class="section-link">Ver todas las guías →</a>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Artículos recientes -->
  {recientes.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title reveal">Últimos análisis</h2>
        <p class="section-subtitle reveal">Los artículos más recientes del blog</p>
        {perroCount > 0 && gatoCount > 0 && (
          <AnimalFilter perroCount={perroCount} gatoCount={gatoCount} totalCount={recientes.length} />
        )}
        <div class="articles-grid reveal-group">
          {recientes.map(articulo => (
            <ArticleCard articulo={articulo} />
          ))}
        </div>
      </div>
    </section>
  )}

</Base>
