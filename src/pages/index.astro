---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import AnimalFilter from '@/components/AnimalFilter.astro';
import { getCollection } from 'astro:content';

const articulos = await getCollection('articulos');

const destacados = articulos
  .filter(a => a.data.destacado)
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime());

const recientes = articulos
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime())
  .slice(0, 6);

const perroCount = recientes.filter(a => a.data.animal === 'perro' || a.data.animal === 'ambos').length;
const gatoCount = recientes.filter(a => a.data.animal === 'gato' || a.data.animal === 'ambos').length;

const comparativas = articulos.filter(a => a.data.tipo !== 'informativo');
const totalProductos = comparativas.reduce((sum, a) => {
  const matches = a.body?.match(/nombre:\s*"/g);
  return sum + (matches ? matches.length : 0);
}, 0);

const siteUrl = 'https://patasyhogar.com';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
  ],
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Patas y Hogar',
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  description: 'Guías de compra y comparativas de productos para perros y gatos',
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'contacto@patasyhogar.com',
    contactType: 'customer service',
    availableLanguage: 'Spanish',
  },
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Últimos análisis de productos para mascotas',
  numberOfItems: recientes.length,
  itemListElement: recientes.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${siteUrl}/${a.data.tipo === 'informativo' ? 'cuidados' : a.data.categoria}/${a.slug}`,
    name: a.data.titulo,
  })),
};

const categorias = [
  {
    slug: 'alimentacion',
    nombre: 'Alimentación',
    descripcion: 'Pienso, húmeda, snacks, fuentes y comederos para perros y gatos',
    icono: '🥣',
    count: articulos.filter(a => a.data.categoria === 'alimentacion').length,
  },
  {
    slug: 'higiene',
    nombre: 'Higiene',
    descripcion: 'Arena, areneros, cepillos, champús y cuidado diario',
    icono: '🪮',
    count: articulos.filter(a => a.data.categoria === 'higiene').length,
  },
  {
    slug: 'paseo',
    nombre: 'Paseo y Transporte',
    descripcion: 'Arneses, correas, transportines, ropa y accesorios de viaje',
    icono: '🦮',
    count: articulos.filter(a => a.data.categoria === 'paseo').length,
  },
  {
    slug: 'juguetes',
    nombre: 'Juguetes',
    descripcion: 'Juguetes interactivos, rascadores, mordedores y estimulación mental',
    icono: '🧸',
    count: articulos.filter(a => a.data.categoria === 'juguetes').length,
  },
  {
    slug: 'hogar',
    nombre: 'Hogar y Descanso',
    descripcion: 'Camas, mantas, protectores y accesorios para casa',
    icono: '🏠',
    count: articulos.filter(a => a.data.categoria === 'hogar').length,
  },
  {
    slug: 'cuidados',
    nombre: 'Cuidados',
    descripcion: 'Guías sobre salud, comportamiento y bienestar de tu mascota',
    icono: '📖',
    count: articulos.filter(a => a.data.tipo === 'informativo').length,
  },
];
---

<Base
  title="Patas y Hogar · Guías y comparativas para perros y gatos"
  description="Análisis honestos y comparativas de productos para perros y gatos. Pienso, accesorios, higiene, camas y transportines. Todo lo que tu mascota necesita."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head" />
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">
        Lo mejor para tu <span>perro y tu gato</span>,<br />
        sin perder tiempo buscando
      </h1>
      <p class="hero-subtitle">
        Analizamos productos en Amazon, Zooplus y Tiendanimal para que tú solo tengas que elegir.
      </p>
      <div class="hero-cta">
        <a href="/perros/" class="hero-cta-btn hero-cta-primary">
          🐶 Guías para perros
        </a>
        <a href="/gatos/" class="hero-cta-btn hero-cta-primary">
          🐱 Guías para gatos
        </a>
      </div>
      <p class="hero-meta">
        {totalProductos}+ productos · {comparativas.length} comparativas · Precios actualizados
      </p>
    </div>
  </section>

  <!-- Categorías -->
  <section class="section" style="background: var(--color-bg-muted); border-bottom: 1px solid var(--color-border);">
    <div class="container">
      <h2 class="section-title">Explora por categoría</h2>
      <p class="section-subtitle">Encuentra exactamente lo que buscas para tu mascota</p>
      <div class="categories-grid">
        {categorias.map(cat => (
          <a href={`/${cat.slug}/`} class="category-card">
            <span class="category-icon" aria-hidden="true">{cat.icono}</span>
            <div class="category-info">
              <h3>{cat.nombre}</h3>
              <p>{cat.descripcion}</p>
              {cat.count > 0 && (
                <p style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--color-primary); font-weight: 600;">
                  {cat.count} {cat.count === 1 ? 'artículo' : 'artículos'}
                </p>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Guías destacadas -->
  {destacados.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">Guías destacadas</h2>
        <p class="section-subtitle">Nuestros análisis más completos y populares</p>
        <div class="articles-grid">
          {destacados.map(articulo => (
            <ArticleCard articulo={articulo} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Artículos recientes -->
  {recientes.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">Últimos análisis</h2>
        <p class="section-subtitle">Los artículos más recientes del blog</p>
        {perroCount > 0 && gatoCount > 0 && (
          <AnimalFilter perroCount={perroCount} gatoCount={gatoCount} totalCount={recientes.length} />
        )}
        <div class="articles-grid">
          {recientes.map(articulo => (
            <ArticleCard articulo={articulo} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section cta-section" style="border-top: 1px solid var(--color-border);">
    <div class="container text-center">
      <h2 style="font-size: 1.75rem; font-weight: 800; margin-bottom: 0.75rem;">
        ¿No sabes por dónde empezar?
      </h2>
      <p style="color: var(--color-text-muted); margin-bottom: 1.5rem; font-size: 1.05rem; max-width: 500px; margin-left: auto; margin-right: auto;">
        Elige tu mascota o empieza por alimentación, la decisión más importante para su salud.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center;">
        <a href="/perros/" class="affiliate-button" style="font-size: 1rem; padding: 0.875rem 2rem;">
          🐶 Guías para perros
        </a>
        <a href="/gatos/" class="affiliate-button" style="font-size: 1rem; padding: 0.875rem 2rem;">
          🐱 Guías para gatos
        </a>
        <a href="/alimentacion/" class="affiliate-button" style="font-size: 1rem; padding: 0.875rem 2rem; background: var(--color-bg-muted); color: var(--color-text); border: 1.5px solid var(--color-border);">
          🥣 Ver alimentación
        </a>
        <a href="/cuidados/" class="affiliate-button" style="font-size: 1rem; padding: 0.875rem 2rem; background: var(--color-bg-muted); color: var(--color-text); border: 1.5px solid var(--color-border);">
          📖 Cuidados y consejos
        </a>
      </div>
    </div>
  </section>
</Base>
