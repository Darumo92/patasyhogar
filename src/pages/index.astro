---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import IconCategory from '@/components/IconCategory.astro';
import { getCollection } from 'astro:content';

const articulos = await getCollection('articulos');

// Featured article (most recent with destacado: true)
const featuredArticle = articulos
  .filter(a => a.data.destacado)
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime())[0];

// Split by tipo
const comparativas = articulos
  .filter(a => a.data.tipo !== 'informativo')
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime());

const informativos = articulos
  .filter(a => a.data.tipo === 'informativo')
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime());

// Category counts (comparativas only)
const catCounts: Record<string, number> = {};
for (const a of articulos) {
  if (a.data.tipo !== 'informativo') {
    catCounts[a.data.categoria] = (catCounts[a.data.categoria] || 0) + 1;
  }
}

const categorias = [
  { slug: 'alimentacion', nombre: 'Alimentación' },
  { slug: 'higiene',      nombre: 'Higiene' },
  { slug: 'paseo',        nombre: 'Paseo' },
  { slug: 'juguetes',     nombre: 'Juguetes' },
  { slug: 'hogar',        nombre: 'Hogar' },
];

const siteUrl = 'https://patasyhogar.com';

const recientes = comparativas.slice(0, 6);

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Patas y Hogar',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${siteUrl}/favicon.svg`,
  },
  description: 'Guías de compra y comparativas de productos para perros y gatos',
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'contacto@patasyhogar.com',
    contactType: 'customer service',
    availableLanguage: 'es',
  },
  foundingDate: '2026',
  areaServed: 'ES',
  availableLanguage: 'es',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Últimos análisis de productos para mascotas',
  numberOfItems: recientes.length,
  itemListElement: recientes.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${siteUrl}/${a.data.categoria}/${a.slug}/`,
    name: a.data.titulo,
  })),
};

function articleUrl(a: typeof articulos[0]) {
  return a.data.tipo === 'informativo'
    ? `/cuidados/${a.slug}/`
    : `/${a.data.categoria}/${a.slug}/`;
}
---

<Base
  title="Patas y Hogar · Guías y comparativas para perros y gatos"
  description="Análisis honestos y comparativas de productos para perros y gatos. Pienso, accesorios, higiene, camas y transportines. Todo lo que tu mascota necesita."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head" />

  <!-- 1. Hero -->
  <section class="hero">
    <div class="container">
      <p class="hero-label">Guías y comparativas para mascotas</p>
      <h1 class="hero-title">Lo mejor para tu perro y tu gato</h1>
      <p class="hero-subtitle">Analizamos productos en Amazon, Zooplus y Tiendanimal para que tú solo tengas que elegir.</p>
      <div class="hero-ctas">
        <a href="/perros/" class="hero-cta dog">🐶 Guías para perros</a>
        <a href="/gatos/" class="hero-cta cat">🐱 Guías para gatos</a>
      </div>
    </div>
  </section>

  <!-- 2. Featured Article -->
  {featuredArticle && (
    <section class="featured">
      <div class="container">
        <a href={articleUrl(featuredArticle)} class="featured-card">
          <div class="featured-img">
            {featuredArticle.data.imagen ? (
              <img
                src={featuredArticle.data.imagen}
                alt={featuredArticle.data.imagenAlt || featuredArticle.data.titulo}
                width="800"
                height="500"
                loading="eager"
              />
            ) : (
              <div class="featured-placeholder"></div>
            )}
          </div>
          <div class="featured-body">
            <span class="featured-badge">Artículo destacado</span>
            <h2>{featuredArticle.data.titulo}</h2>
            <p>{featuredArticle.data.descripcion}</p>
            <span class="featured-link">Leer artículo →</span>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- 3. Categories -->
  <section class="categories">
    <div class="container">
      <div class="section-header">
        <h2>Categorías</h2>
        <a href="/articulos/">Ver todo →</a>
      </div>
      <div class="categories-grid">
        {categorias.map(cat => (
          <a href={`/${cat.slug}/`} class="cat-card">
            <div class="cat-icon"><IconCategory category={cat.slug} size={28} /></div>
            <h3>{cat.nombre}</h3>
            <span>{catCounts[cat.slug] || 0} guías</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Latest Comparativas -->
  {recientes.length > 0 && (
    <section class="articles">
      <div class="container">
        <div class="section-header">
          <h2>Últimas comparativas</h2>
          <a href="/articulos/">Ver todas →</a>
        </div>
        <div class="articles-grid">
          {recientes.map((articulo, i) => (
            <ArticleCard articulo={articulo} headingLevel={3} eager={i < 2} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 5. Guides (Informativos) -->
  {informativos.length > 0 && (
    <section class="guides">
      <div class="container">
        <div class="section-header">
          <h2>Guías de cuidados</h2>
          <a href="/cuidados/">Ver todas →</a>
        </div>
        <div class="guides-grid">
          {informativos.slice(0, 6).map(guide => (
            <a href={`/cuidados/${guide.slug}/`} class="guide-card">
              <div class="guide-icon">📖</div>
              <div class="guide-info">
                <h3>{guide.data.titulo}</h3>
                <span>{guide.data.animal === 'perro' ? 'Perros' : guide.data.animal === 'gato' ? 'Gatos' : 'Perros y gatos'}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 6. Newsletter -->
  <section class="container">
    <div class="newsletter">
      <h2>No te pierdas nada</h2>
      <p>Recibe las últimas guías y ofertas en tu email. Sin spam, solo contenido útil.</p>
      <form class="newsletter-form" id="newsletter-form">
        <input type="email" name="email" placeholder="tu@email.com" required aria-label="Tu email" />
        <button type="submit">Suscribirme</button>
      </form>
      <p class="newsletter-msg" id="newsletter-msg" style="margin-top:0.75rem;font-size:0.8rem;display:none;"></p>
    </div>
  </section>

  <script is:inline>
  (function(){
    var f=document.getElementById('newsletter-form');
    var m=document.getElementById('newsletter-msg');
    if(!f||!m)return;
    f.addEventListener('submit',function(e){
      e.preventDefault();
      var email=f.querySelector('input[name="email"]').value;
      if(!email)return;
      var btn=f.querySelector('button');
      btn.disabled=true;btn.textContent='Enviando...';
      fetch('/api/subscribe',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({email:email})
      }).then(function(r){
        if(r.ok){
          m.style.display='block';m.style.color='var(--green-600)';
          m.textContent='¡Suscripción confirmada! Revisa tu email.';
          f.reset();
        }else{
          throw new Error('Error');
        }
      }).catch(function(){
        m.style.display='block';m.style.color='var(--color-text-muted)';
        m.textContent='Hubo un error. Inténtalo de nuevo.';
      }).finally(function(){
        btn.disabled=false;btn.textContent='Suscribirme';
      });
    });
  })();
  </script>
</Base>
