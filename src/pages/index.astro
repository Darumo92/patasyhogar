---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import AnimalFilter from '@/components/AnimalFilter.astro';
import CategoryIcon from '@/components/CategoryIcon.astro';
import PetQuiz from '@/components/PetQuiz.astro';
import { getCollection } from 'astro:content';

const articulos = await getCollection('articulos');

const destacados = articulos
  .filter(a => a.data.destacado)
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime());

const recientes = articulos
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime())
  .slice(0, 4);

const perroCount = recientes.filter(a => a.data.animal === 'perro' || a.data.animal === 'ambos').length;
const gatoCount = recientes.filter(a => a.data.animal === 'gato' || a.data.animal === 'ambos').length;

const comparativas = articulos.filter(a => a.data.tipo !== 'informativo');
const totalProductos = comparativas.reduce((sum, a) => {
  const matches = a.body?.match(/nombre:\s*"/g);
  return sum + (matches ? matches.length : 0);
}, 0);

const siteUrl = 'https://patasyhogar.com';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Patas y Hogar',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${siteUrl}/favicon.svg`,
  },
  description: 'Guías de compra y comparativas de productos para perros y gatos',
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'contacto@patasyhogar.com',
    contactType: 'customer service',
    availableLanguage: 'es',
  },
  foundingDate: '2026',
  areaServed: {
    '@type': 'Country',
    name: 'ES',
  },
  availableLanguage: 'es',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Últimos análisis de productos para mascotas',
  numberOfItems: recientes.length,
  itemListElement: recientes.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${siteUrl}/${a.data.tipo === 'informativo' ? 'cuidados' : a.data.categoria}/${a.slug}`,
    name: a.data.titulo,
  })),
};

// Seasonal content: find articles tagged with current season topics
const now = new Date();
const month = now.getMonth() + 1; // 1-12

type SeasonalConfig = { tags: string[]; titulo: string; icono: string; color: string };
const seasonalMap: SeasonalConfig[] = [];

// Spring (March-May): procesionaria, allergies
if (month >= 3 && month <= 5) {
  seasonalMap.push({ tags: ['procesionaria', 'primavera', 'alergia'], titulo: 'Temporada de procesionaria', icono: '⚠️', color: '#dc2626' });
  seasonalMap.push({ tags: ['garrapatas', 'antiparasitarios', 'pulgas'], titulo: 'Protege contra parásitos', icono: '🛡️', color: '#047857' });
}
// Summer (June-August): heat, hydration
if (month >= 6 && month <= 8) {
  seasonalMap.push({ tags: ['golpe de calor', 'verano', 'hidratacion'], titulo: 'Protege del calor', icono: '☀️', color: '#d97706' });
  seasonalMap.push({ tags: ['viaje', 'transportin', 'coche'], titulo: 'Viajar con mascotas', icono: '🚗', color: '#2563eb' });
}
// Autumn (Sept-Nov): cold prep
if (month >= 9 && month <= 11) {
  seasonalMap.push({ tags: ['frio', 'ropa perro', 'abrigo'], titulo: 'Prepara el invierno', icono: '🧥', color: '#7c3aed' });
}
// Winter (Dec-Feb): cold, gifts
if (month === 12 || month <= 2) {
  seasonalMap.push({ tags: ['navidad', 'regalo', 'juguete'], titulo: 'Regalos para mascotas', icono: '🎁', color: '#dc2626' });
  seasonalMap.push({ tags: ['frio', 'ropa perro', 'manta'], titulo: 'Mantén caliente a tu mascota', icono: '❄️', color: '#2563eb' });
}

// Find matching seasonal articles
const seasonalArticles: { articulo: typeof articulos[0]; config: SeasonalConfig }[] = [];
for (const config of seasonalMap) {
  const match = articulos.find(a =>
    a.data.tags?.some(t => config.tags.some(st => t.toLowerCase().includes(st)))
  );
  if (match && !seasonalArticles.some(s => s.articulo.slug === match.slug)) {
    seasonalArticles.push({ articulo: match, config });
  }
}

const categorias = [
  {
    slug: 'alimentacion',
    nombre: 'Alimentación',
    descripcion: 'Pienso, húmeda, snacks, fuentes y comederos para perros y gatos',
    count: articulos.filter(a => a.data.categoria === 'alimentacion').length,
  },
  {
    slug: 'higiene',
    nombre: 'Higiene',
    descripcion: 'Arena, areneros, cepillos, champús y cuidado diario',
    count: articulos.filter(a => a.data.categoria === 'higiene').length,
  },
  {
    slug: 'paseo',
    nombre: 'Paseo y Transporte',
    descripcion: 'Arneses, correas, transportines, ropa y accesorios de viaje',
    count: articulos.filter(a => a.data.categoria === 'paseo').length,
  },
  {
    slug: 'juguetes',
    nombre: 'Juguetes',
    descripcion: 'Juguetes interactivos, rascadores, mordedores y estimulación mental',
    count: articulos.filter(a => a.data.categoria === 'juguetes').length,
  },
  {
    slug: 'hogar',
    nombre: 'Hogar y Descanso',
    descripcion: 'Camas, mantas, protectores y accesorios para casa',
    count: articulos.filter(a => a.data.categoria === 'hogar').length,
  },
  {
    slug: 'cuidados',
    nombre: 'Cuidados',
    descripcion: 'Guías sobre salud, comportamiento y bienestar de tu mascota',
    count: articulos.filter(a => a.data.tipo === 'informativo').length,
  },
];
---

<Base
  title="Patas y Hogar · Guías y comparativas para perros y gatos"
  description="Análisis honestos y comparativas de productos para perros y gatos. Pienso, accesorios, higiene, camas y transportines. Todo lo que tu mascota necesita."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head" />
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">
        Lo mejor para tu <span>perro y tu gato</span>,<br />
        sin perder tiempo buscando
      </h1>
      <p class="hero-subtitle">
        Analizamos productos en Amazon, Zooplus y Tiendanimal para que tú solo tengas que elegir.
      </p>
      <div class="hero-stats">
        <div class="hero-stat">
          <strong>{totalProductos}+</strong>
          <span>productos</span>
        </div>
        <div class="hero-stat">
          <strong>{comparativas.length}</strong>
          <span>comparativas</span>
        </div>
        <div class="hero-stat">
          <strong>3</strong>
          <span>tiendas</span>
        </div>
      </div>
      <div class="hero-cta">
        <a href="/perros/" class="hero-cta-btn hero-cta-dog">
          🐶 Guías para perros
        </a>
        <a href="/gatos/" class="hero-cta-btn hero-cta-cat">
          🐱 Guías para gatos
        </a>
      </div>
      <p class="hero-meta">
        Precios actualizados en marzo 2026 · Comparados en 3 tiendas
      </p>
    </div>
  </section>

  <!-- Quiz: ¿Qué necesita mi mascota? -->
  <section class="section" style="padding: 3rem 0;">
    <div class="container" style="max-width: 600px;">
      <PetQuiz />
    </div>
  </section>

  <!-- Seasonal Banner -->
  {seasonalArticles.length > 0 && (
    <section class="seasonal-banner">
      <div class="container">
        <div class="seasonal-items">
          {seasonalArticles.slice(0, 2).map(({ articulo: sa, config }) => {
            const saUrl = `/${sa.data.tipo === 'informativo' ? 'cuidados' : sa.data.categoria}/${sa.slug}/`;
            return (
              <a href={saUrl} class="seasonal-item" style={`--seasonal-color: ${config.color}`}>
                <span class="seasonal-icon">{config.icono}</span>
                <div class="seasonal-text">
                  <strong>{config.titulo}</strong>
                  <span>{sa.data.titulo}</span>
                </div>
                <span class="seasonal-arrow">→</span>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Categorías -->
  <section class="section" style="background: var(--color-bg-muted); border-bottom: 1px solid var(--color-border);">
    <div class="container">
      <h2 class="section-title">Explora por categoría</h2>
      <p class="section-subtitle">Encuentra exactamente lo que buscas para tu mascota</p>
      <div class="categories-grid reveal-group">
        {categorias.map(cat => (
          <a href={`/${cat.slug}/`} class="category-card">
            <span class="category-icon" aria-hidden="true"><CategoryIcon categoria={cat.slug} size={24} /></span>
            <div class="category-info">
              <h3>{cat.nombre}</h3>
              <p>{cat.descripcion}</p>
              {cat.count > 0 && (
                <p style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--color-primary); font-weight: 600;">
                  {cat.count} {cat.count === 1 ? 'artículo' : 'artículos'}
                </p>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Guías destacadas -->
  {destacados.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title reveal">Guías destacadas</h2>
        <p class="section-subtitle reveal">Nuestros análisis más completos y populares</p>
        <div class="articles-grid reveal-group">
          {destacados.map((articulo, i) => (
            <ArticleCard articulo={articulo} eager={i < 2} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Artículos recientes -->
  {recientes.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title reveal">Últimos análisis</h2>
        <p class="section-subtitle reveal">Los artículos más recientes del blog</p>
        {perroCount > 0 && gatoCount > 0 && (
          <AnimalFilter perroCount={perroCount} gatoCount={gatoCount} totalCount={recientes.length} />
        )}
        <div class="articles-grid reveal-group">
          {recientes.map(articulo => (
            <ArticleCard articulo={articulo} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Trust / Social proof -->
  <section class="trust-section">
    <div class="container">
      <div class="trust-grid reveal-group">
        <div class="trust-card">
          <span class="trust-card-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></span>
          <div>
            <strong>Análisis independientes</strong>
            <p>Probamos y comparamos productos reales. Sin reseñas patrocinadas.</p>
          </div>
        </div>
        <div class="trust-card">
          <span class="trust-card-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></svg></span>
          <div>
            <strong>Precios comparados en 3 tiendas</strong>
            <p>Amazon, Zooplus y Tiendanimal. Te mostramos el mejor precio.</p>
          </div>
        </div>
        <div class="trust-card">
          <span class="trust-card-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><path d="M21 12a9 9 0 1 1-6.219-8.56"/><polyline points="21 3 21 9 15 9"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L21 9"/></svg></span>
          <div>
            <strong>Actualizado regularmente</strong>
            <p>Revisamos precios y disponibilidad para que la info sea fiable.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter (home: lead magnet) -->
  <section class="section newsletter-section">
    <div class="container text-center">
      <h2 class="newsletter-section-title reveal">📋 Checklist gratis: lo esencial para tu mascota</h2>
      <p class="newsletter-section-desc">
        Descarga nuestra guía con el equipamiento imprescindible para perros y gatos.
        Además, recibirás nuestras mejores comparativas y alertas de bajadas de precio.
      </p>
      <form
        action="/api/subscribe"
        method="post"
        class="newsletter-form newsletter-form-hero"
        id="newsletter-form-hero"
      >
        <input
          type="email"
          name="email"
          placeholder="tu@email.com"
          required
          aria-label="Tu email"
          class="newsletter-input"
        />
        <button type="submit" class="newsletter-btn">Quiero la guía</button>
      </form>
      <p class="newsletter-section-privacy" id="newsletter-msg-hero">
        Gratis y sin spam. Puedes darte de baja cuando quieras.
      </p>
    </div>
  </section>
</Base>
