---
import Base from '@/layouts/Base.astro';

const siteUrl = 'https://patasyhogar.com';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Contacto' },
  ],
};

const contactPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contacto — Patas y Hogar',
  description: 'Contacta con Patas y Hogar para consultas, colaboraciones o sugerencias sobre productos para perros y gatos.',
  url: `${siteUrl}/contacto/`,
  mainEntity: {
    '@type': 'Organization',
    name: 'Patas y Hogar',
    url: siteUrl,
    email: 'contacto@patasyhogar.com',
    contactPoint: {
      '@type': 'ContactPoint',
      email: 'contacto@patasyhogar.com',
      contactType: 'customer service',
      availableLanguage: 'es',
    },
  },
};
---

<Base
  title="Contacto — Patas y Hogar"
  description="Contacta con Patas y Hogar para consultas, colaboraciones o sugerencias sobre productos para perros y gatos."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} slot="head" />

  <article class="container legal-page">
    <nav class="breadcrumb" aria-label="Migas de pan">
      <a href="/">Inicio</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <span>Contacto</span>
    </nav>

    <h1>Contacto</h1>

    <p>
      Si tienes alguna duda sobre un producto, quieres sugerirnos un artículo o simplemente saludarnos,
      estaremos encantados de leerte.
    </p>

    <div class="contact-methods">
      <div class="contact-card">
        <h2>Escríbenos por email</h2>
        <p>
          La forma más directa de contactar con nosotros. Intentamos responder en menos de 48 horas.
        </p>
        <a href="mailto:contacto@patasyhogar.com" class="contact-email">
          contacto@patasyhogar.com
        </a>
      </div>

      <div class="contact-card">
        <h2>Sobre qué puedes escribirnos</h2>
        <ul>
          <li><strong>Dudas sobre productos</strong> — si necesitas ayuda para elegir un producto para tu perro o gato</li>
          <li><strong>Correcciones</strong> — si encuentras un precio desactualizado, un enlace roto o un error</li>
          <li><strong>Sugerencias de artículos</strong> — si echas en falta una comparativa o guía</li>
          <li><strong>Colaboraciones</strong> — si representas a una marca y quieres que probemos tu producto</li>
        </ul>
      </div>
    </div>

    <div class="contact-note">
      <p>
        <strong>Nota:</strong> Patas y Hogar es un proyecto independiente. No aceptamos reseñas patrocinadas
        ni modificamos nuestras opiniones a cambio de productos gratuitos. Si nos envías un producto para probar,
        nuestra opinión será honesta — incluyendo los puntos negativos.
      </p>
    </div>
  </article>
</Base>

<style>
  .contact-methods {
    display: grid;
    gap: 1.5rem;
    margin: 2rem 0;
  }
  @media (min-width: 640px) {
    .contact-methods { grid-template-columns: 1fr 1fr; }
  }
  .contact-card {
    background: var(--color-bg-muted);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    border: 1px solid var(--color-border);
  }
  .contact-card h2 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }
  .contact-card ul {
    padding-left: 1.2rem;
    margin: 0;
  }
  .contact-card li {
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }
  .contact-email {
    display: inline-block;
    margin-top: 0.75rem;
    padding: 0.6rem 1.2rem;
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s;
  }
  .contact-email:hover {
    opacity: 0.9;
  }
  .contact-note {
    background: var(--color-bg-muted);
    border-left: 4px solid var(--color-primary);
    padding: 1rem 1.5rem;
    border-radius: var(--radius-sm);
    margin-top: 2rem;
  }
  .contact-note p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }
</style>
