---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return [
    { params: { categoria: 'alimentacion' } },
    { params: { categoria: 'higiene' } },
    { params: { categoria: 'descanso' } },
    { params: { categoria: 'comportamiento' } },
  ];
}

const { categoria } = Astro.params;

const categoriasInfo: Record<string, {
  nombre: string;
  descripcion: string;
  icono: string;
  intro: string;
  subtemas: string[];
}> = {
  alimentacion: {
    nombre: 'Alimentación',
    descripcion: 'Guías y comparativas de pienso, comida húmeda, snacks, fuentes y comederos para perros y gatos.',
    icono: '🥣',
    intro: 'La alimentación es la decisión más importante para la salud y longevidad de tu mascota. Un buen pienso puede prevenir enfermedades, mantener un peso saludable y mejorar la calidad de vida de tu perro o gato. En esta sección analizamos piensos secos, comida húmeda, snacks naturales y accesorios de alimentación, comparando ingredientes, precios y dónde comprarlos más barato en España.',
    subtemas: ['Pienso para perros', 'Pienso para gatos', 'Comida húmeda', 'Snacks y premios', 'Fuentes de agua', 'Comederos'],
  },
  higiene: {
    nombre: 'Higiene y Cuidado',
    descripcion: 'Todo sobre arena, areneros, cepillos, champús y productos de cuidado diario para mascotas.',
    icono: '🪮',
    intro: 'El cuidado diario de tu mascota va mucho más allá del baño ocasional. Una buena rutina de higiene previene infecciones, mantiene el pelo en buen estado y refuerza el vínculo entre vosotros. Analizamos los mejores productos de higiene para perros y gatos: cepillos, champús, arenas para gatos, areneros, cortaúñas y más.',
    subtemas: ['Arena para gatos', 'Areneros', 'Cepillos y peines', 'Champús', 'Antiparasitarios', 'Cortaúñas'],
  },
  descanso: {
    nombre: 'Descanso y Transporte',
    descripcion: 'Análisis de camas, transportines, mochilas de transporte y jaulas para perros y gatos.',
    icono: '🏠',
    intro: 'Un perro o gato que descansa bien es un animal más sano y equilibrado. La cama adecuada puede aliviar problemas articulares en perros mayores, reducir la ansiedad y mejorar la calidad del sueño. En transporte, elegir bien el transportín marca la diferencia en viajes al veterinario, vuelos y excursiones. Comparamos camas, transportines, mochilas y jaulas para todas las necesidades.',
    subtemas: ['Camas para perros', 'Camas para gatos', 'Transportines', 'Mochilas de transporte', 'Jaulas', 'Correas y arneses'],
  },
  comportamiento: {
    nombre: 'Enriquecimiento y Juego',
    descripcion: 'Juguetes interactivos, rascadores, mordedores y accesorios para estimular a tu mascota.',
    icono: '🧸',
    intro: 'El enriquecimiento ambiental es fundamental para el bienestar mental de perros y gatos. Un animal aburrido desarrolla conductas destructivas, ansiedad y estrés. Los juguetes adecuados estimulan los instintos naturales, reducen la ansiedad por separación y mantienen a tu mascota activa y feliz. Analizamos juguetes interactivos, puzzles, rascadores, mordedores y accesorios de estimulación.',
    subtemas: ['Juguetes para perros', 'Juguetes para gatos', 'Rascadores', 'Mordedores', 'Puzzles cognitivos', 'Alfombras olfativas'],
  },
};

const info = categoriasInfo[categoria as string];

const articulos = await getCollection('articulos', ({ data }) => data.categoria === categoria);
const articulosOrdenados = articulos.sort(
  (a, b) => b.data.fecha.getTime() - a.data.fecha.getTime()
);

const destacados = articulosOrdenados.filter(a => a.data.destacado).slice(0, 3);
const resto = articulosOrdenados.filter(a => !a.data.destacado || destacados.length === 0);
---

<Base
  title={`${info.nombre} para perros y gatos | Guías y comparativas | Patas y Hogar`}
  description={info.descripcion}
>
  <div class="category-page-header">
    <div class="container">
      <div class="category-icon-large" aria-hidden="true">{info.icono}</div>
      <h1>{info.nombre}</h1>
      <p>{info.descripcion}</p>
    </div>
  </div>

  <div class="container section">

    <!-- Intro SEO -->
    <div class="category-intro">
      <p>{info.intro}</p>
      <div class="category-subtemas">
        {info.subtemas.map(s => (
          <span class="badge" style="background: var(--color-bg-muted); color: var(--color-text-muted);">{s}</span>
        ))}
      </div>
    </div>

    {articulosOrdenados.length > 0 ? (
      <>
        <!-- Destacados -->
        {destacados.length > 0 && (
          <div style="margin-bottom: 3rem;">
            <h2 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 1.25rem; color: var(--color-primary);">
              ⭐ Guías destacadas
            </h2>
            <div class="articles-grid">
              {destacados.map(articulo => (
                <ArticleCard articulo={articulo} />
              ))}
            </div>
          </div>
        )}

        <!-- Todos los artículos -->
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem;">
          <h2 style="font-size: 1.2rem; font-weight: 700;">
            {destacados.length > 0 ? 'Todos los artículos' : 'Artículos'}
          </h2>
          <p class="text-muted" style="font-size: 0.875rem;">
            {articulosOrdenados.length} {articulosOrdenados.length === 1 ? 'artículo' : 'artículos'}
          </p>
        </div>
        <div class="articles-grid">
          {(destacados.length > 0 ? resto : articulosOrdenados).map(articulo => (
            <ArticleCard articulo={articulo} />
          ))}
        </div>
      </>
    ) : (
      <div class="text-center" style="padding: 4rem 0;">
        <p style="font-size: 3rem; margin-bottom: 1rem;">{info.icono}</p>
        <h2 style="margin-bottom: 0.5rem;">Próximamente</h2>
        <p class="text-muted">Estamos preparando los primeros artículos de esta categoría.</p>
        <a href="/" class="affiliate-button" style="margin-top: 1.5rem; display: inline-flex;">
          ← Volver al inicio
        </a>
      </div>
    )}
  </div>
</Base>

<style>
  .category-intro {
    background: var(--color-bg-muted);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin-bottom: 2.5rem;
    border-left: 4px solid var(--color-primary);
  }
  .category-intro p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .category-subtemas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
