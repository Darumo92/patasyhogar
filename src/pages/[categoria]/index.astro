---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import AnimalFilter from '@/components/AnimalFilter.astro';
import SmoothScroll from '@/components/SmoothScroll.astro';
import IconCategory from '@/components/IconCategory.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return [
    { params: { categoria: 'alimentacion' } },
    { params: { categoria: 'higiene' } },
    { params: { categoria: 'paseo' } },
    { params: { categoria: 'juguetes' } },
    { params: { categoria: 'hogar' } },
  ];
}

const { categoria } = Astro.params;

const categoriasInfo: Record<string, {
  nombre: string;
  descripcion: string;
  intro: string;
}> = {
  alimentacion: {
    nombre: 'Alimentación',
    descripcion: 'Guías y comparativas de pienso, comida húmeda, snacks, fuentes y comederos para perros y gatos. Encuentra el mejor producto al mejor precio.',
    intro: 'La alimentación es la decisión más importante para la salud y longevidad de tu mascota. Un buen pienso puede prevenir enfermedades, mantener un peso saludable y mejorar la calidad de vida de tu perro o gato. En esta sección analizamos piensos secos, comida húmeda, snacks naturales y accesorios de alimentación, comparando ingredientes, precios y dónde comprarlos más barato en España.',
  },
  higiene: {
    nombre: 'Higiene y Cuidado',
    descripcion: 'Guías y comparativas de arena, areneros, cepillos, champús, antiparasitarios y productos de cuidado diario para perros y gatos en España.',
    intro: 'El cuidado diario de tu mascota va mucho más allá del baño ocasional. Una buena rutina de higiene previene infecciones, mantiene el pelo en buen estado y refuerza el vínculo entre vosotros. Analizamos los mejores productos de higiene para perros y gatos: cepillos, champús, arenas para gatos, areneros, cortaúñas y más.',
  },
  paseo: {
    nombre: 'Paseo y Transporte',
    descripcion: 'Comparativas de arneses, correas, transportines, GPS, ropa y accesorios para pasear y viajar con tu perro o gato de forma segura.',
    intro: 'El paseo es uno de los momentos más importantes del día para tu perro, y viajar con tu mascota requiere el equipamiento adecuado. Un buen arnés previene lesiones cervicales, un transportín homologado es obligatorio en avión, y la ropa de abrigo protege a razas pequeñas en invierno. Comparamos arneses, correas, transportines, mochilas, GPS y todo lo que necesitas para salir con tu mascota.',
  },
  juguetes: {
    nombre: 'Juguetes y Enriquecimiento',
    descripcion: 'Comparativas de juguetes interactivos, rascadores, mordedores y accesorios de estimulación mental para perros y gatos. Mantén a tu mascota activa.',
    intro: 'El enriquecimiento ambiental es fundamental para el bienestar mental de perros y gatos. Un animal aburrido desarrolla conductas destructivas, ansiedad y estrés. Los juguetes adecuados estimulan los instintos naturales, reducen la ansiedad por separación y mantienen a tu mascota activa y feliz. Analizamos juguetes interactivos, puzzles, rascadores, mordedores y accesorios de estimulación.',
  },
  hogar: {
    nombre: 'Hogar y Descanso',
    descripcion: 'Guías y comparativas de camas, mantas, protectores de sofá y accesorios de descanso para perros y gatos. Crea el hogar perfecto para tu mascota.',
    intro: 'Tu mascota pasa la mayor parte de su vida en casa, y su comodidad influye directamente en su salud y bienestar. La cama adecuada puede aliviar problemas articulares en perros mayores, reducir la ansiedad y mejorar la calidad del sueño. Comparamos camas, mantas, protectores de sofá, gateras, puertas de seguridad y todo lo que necesitas para crear un hogar perfecto para tu perro o gato.',
  },
};

// All SVG paths from Lucide v1.8+ (lucide.dev) — ISC license
const subcatSvgPaths: Record<string, string> = {
  // Lucide: dog
  'pienso-perros': `<path d="M11.25 16.25h1.5L12 17z"/><path d="M16 14v.5"/><path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444a11.702 11.702 0 0 0-.493-3.309"/><path d="M8 14v.5"/><path d="M8.5 8.5c-.384 1.05-1.083 2.028-2.344 2.5-1.931.722-3.576-.297-3.656-1-.113-.994 1.177-6.53 4-7 1.923-.321 3.651.845 3.651 2.235A7.497 7.497 0 0 1 14 5.277c0-1.39 1.844-2.598 3.767-2.277 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.855-1.45-2.239-2.5"/>`,
  // Lucide: cat
  'pienso-gatos': `<path d="M12 5c.67 0 1.35.09 2 .26 1.78-2 5.03-2.84 6.42-2.26 1.4.58-.42 7-.42 7 .57 1.07 1 2.24 1 3.44C21 17.9 16.97 21 12 21s-9-3-9-7.56c0-1.25.5-2.4 1-3.44 0 0-1.89-6.42-.5-7 1.39-.58 4.72.23 6.5 2.23A9.04 9.04 0 0 1 12 5Z"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75Z"/>`,
  // Lucide: beef
  'comida-humeda': `<path d="M16.4 13.7A6.5 6.5 0 1 0 6.28 6.6c-1.1 3.13-.78 3.9-3.18 6.08A3 3 0 0 0 5 18c4 0 8.4-1.8 11.4-4.3"/><path d="m18.5 6 2.19 4.5a6.48 6.48 0 0 1-2.29 7.2C15.4 20.2 11 22 7 22a3 3 0 0 1-2.68-1.66L2.4 16.5"/><circle cx="12.5" cy="8.5" r="2.5"/>`,
  // Lucide: cookie
  'snacks': `<path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"/><path d="M8.5 8.5v.01"/><path d="M16 15.5v.01"/><path d="M12 12v.01"/><path d="M11 17v.01"/><path d="M7 14v.01"/>`,
  // Lucide: utensils
  'comederos': `<path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/>`,
  // Lucide: droplets
  'bebederos': `<path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/>`,
  // Lucide: apple
  'nutricion': `<path d="M12 6.528V3a1 1 0 0 1 1-1h0"/><path d="M18.237 21A15 15 0 0 0 22 11a6 6 0 0 0-10-4.472A6 6 0 0 0 2 11a15.1 15.1 0 0 0 3.763 10 3 3 0 0 0 3.648.648 5.5 5.5 0 0 1 5.178 0A3 3 0 0 0 18.237 21"/>`,
  // Lucide: box
  'arena-areneros': `<path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/>`,
  // Lucide: scissors
  'cepillos-aseo': `<circle cx="6" cy="6" r="3"/><path d="M8.12 8.12 12 12"/><path d="M20 4 8.12 15.88"/><circle cx="6" cy="18" r="3"/><path d="M14.8 14.8 20 20"/>`,
  // Lucide: shield
  'antiparasitarios': `<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>`,
  // Lucide: trash-2
  'limpieza': `<path d="M10 11v6"/><path d="M14 11v6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>`,
  // Lucide: link
  'arneses-correas': `<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>`,
  // Lucide: luggage
  'transportines': `<path d="M6 20a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2"/><path d="M8 18V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v14"/><path d="M10 20h4"/><circle cx="16" cy="20" r="2"/><circle cx="8" cy="20" r="2"/>`,
  // Lucide: map-pin
  'collares-gps': `<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>`,
  // Lucide: shirt
  'ropa': `<path d="M20.38 3.46 16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23z"/>`,
  // Lucide: car
  'coche': `<path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/>`,
  // Lucide: dog
  'juguetes-perros': `<path d="M11.25 16.25h1.5L12 17z"/><path d="M16 14v.5"/><path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444a11.702 11.702 0 0 0-.493-3.309"/><path d="M8 14v.5"/><path d="M8.5 8.5c-.384 1.05-1.083 2.028-2.344 2.5-1.931.722-3.576-.297-3.656-1-.113-.994 1.177-6.53 4-7 1.923-.321 3.651.845 3.651 2.235A7.497 7.497 0 0 1 14 5.277c0-1.39 1.844-2.598 3.767-2.277 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.855-1.45-2.239-2.5"/>`,
  // Lucide: cat
  'juguetes-gatos': `<path d="M12 5c.67 0 1.35.09 2 .26 1.78-2 5.03-2.84 6.42-2.26 1.4.58-.42 7-.42 7 .57 1.07 1 2.24 1 3.44C21 17.9 16.97 21 12 21s-9-3-9-7.56c0-1.25.5-2.4 1-3.44 0 0-1.89-6.42-.5-7 1.39-.58 4.72.23 6.5 2.23A9.04 9.04 0 0 1 12 5Z"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75Z"/>`,
  // Lucide: scissors (rascadores = grooming tool)
  'rascadores': `<circle cx="6" cy="6" r="3"/><path d="M8.12 8.12 12 12"/><path d="M20 4 8.12 15.88"/><circle cx="6" cy="18" r="3"/><path d="M14.8 14.8 20 20"/>`,
  // Lucide: bed
  'camas-perros': `<path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/>`,
  // Lucide: moon
  'camas-gatos': `<path d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"/>`,
  // Lucide: sofa
  'confort': `<path d="M20 9V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v3"/><path d="M2 16a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0v1.5a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5V11a2 2 0 0 0-4 0z"/><path d="M4 18v2"/><path d="M20 18v2"/><path d="M12 4v9"/>`,
  // Lucide: lock
  'seguridad': `<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`,
  // Lucide: heart
  'bienestar': `<path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/>`,
  // Lucide: list
  'otros': `<path d="M3 5h.01"/><path d="M3 12h.01"/><path d="M3 19h.01"/><path d="M8 5h13"/><path d="M8 12h13"/><path d="M8 19h13"/>`,
};

// Subcategorías con keywords para agrupar artículos por slug
const subcategoriasConfig: Record<string, { id: string; nombre: string; keywords: string[] }[]> = {
  alimentacion: [
    { id: 'pienso-perros', nombre: 'Pienso para perros', keywords: ['pienso-perro', 'pienso-cachorro-raza', 'pienso-hipoalergenico'] },
    { id: 'pienso-gatos', nombre: 'Pienso para gatos', keywords: ['pienso-gato', 'pienso-gatito', 'pienso-cachorro-gato', 'grain-free'] },
    { id: 'comida-humeda', nombre: 'Comida húmeda', keywords: ['comida-humeda'] },
    { id: 'snacks', nombre: 'Snacks y premios', keywords: ['snacks'] },
    { id: 'comederos', nombre: 'Comederos', keywords: ['comedero'] },
    { id: 'bebederos', nombre: 'Bebederos y fuentes', keywords: ['bebedero', 'fuente'] },
    { id: 'nutricion', nombre: 'Nutrición y consejos', keywords: ['cuantas-veces', 'cuanto-debe-comer', 'sobrepeso', 'no-quiere-comer', 'vomita', 'alimentos-prohibidos', 'alimentos-toxicos'] },
  ],
  higiene: [
    { id: 'arena-areneros', nombre: 'Arena y areneros', keywords: ['arena', 'arenero'] },
    { id: 'cepillos-aseo', nombre: 'Cepillos y aseo', keywords: ['cepillo', 'cortapelos', 'champu', 'banar', 'secador', 'cortaunas', 'oidos'] },
    { id: 'antiparasitarios', nombre: 'Antiparasitarios', keywords: ['antiparasitario', 'desparasitante', 'pipeta', 'pulgas', 'collar-antiparasitario'] },
    { id: 'limpieza', nombre: 'Limpieza e higiene', keywords: ['bolsas-caca', 'empapadores', 'limpiador', 'dispensador', 'toallitas', 'aspirador', 'protector-patas'] },
  ],
  paseo: [
    { id: 'arneses-correas', nombre: 'Arneses y correas', keywords: ['arnes', 'correa'] },
    { id: 'transportines', nombre: 'Transportines y mochilas', keywords: ['transportin', 'mochila'] },
    { id: 'collares-gps', nombre: 'Collares y localización', keywords: ['collar', 'gps', 'bozal'] },
    { id: 'ropa', nombre: 'Ropa y protección', keywords: ['abrigo', 'chubasquero', 'chaleco'] },
    { id: 'coche', nombre: 'Coche y viaje', keywords: ['asiento-coche', 'protector-maletero'] },
  ],
  juguetes: [
    { id: 'juguetes-perros', nombre: 'Juguetes para perros', keywords: ['kong', 'lanzador', 'pelota', 'mordedor', 'alfombras-olfato', 'circuito-agilidad', 'juguete-cachorro', 'juguete-estimulacion', 'juguete-rellenable', 'juguetes-perros'] },
    { id: 'juguetes-gatos', nombre: 'Juguetes para gatos', keywords: ['juguete-inteligencia', 'juguete-cana', 'juguetes-interactivos-gatos', 'tunel', 'hierba-gatera', 'difusor-feromonas', 'enriquecimiento-ambiental', 'adiestrar-gato'] },
    { id: 'rascadores', nombre: 'Rascadores', keywords: ['rascador', 'arbol-rascador'] },
  ],
  hogar: [
    { id: 'camas-perros', nombre: 'Camas para perros', keywords: ['cama-perro', 'cama-antiansiedad', 'cama-elevada', 'cama-lavable'] },
    { id: 'camas-gatos', nombre: 'Camas y descanso para gatos', keywords: ['cama-gato', 'cama-cueva', 'hamaca'] },
    { id: 'confort', nombre: 'Confort y protección', keywords: ['manta', 'alfombrilla', 'protector-sofa', 'piscina', 'repelente'] },
    { id: 'seguridad', nombre: 'Seguridad en el hogar', keywords: ['puerta-seguridad', 'gatera', 'escalera', 'jaula'] },
    { id: 'bienestar', nombre: 'Bienestar y convivencia', keywords: ['cachorro-primeras', 'maulla', 'petardos', 'residencias'] },
  ],
};

const info = categoriasInfo[categoria as string];
const subcats = subcategoriasConfig[categoria as string] || [];

// Excluir informativos de las páginas de categoría (van en /cuidados/)
const articulos = await getCollection('articulos', ({ data }) =>
  data.categoria === categoria && data.tipo !== 'informativo'
);
const articulosOrdenados = articulos.sort(
  (a, b) => b.data.fecha.getTime() - a.data.fecha.getTime()
);

// Agrupar artículos por subcategoría
function matchSubcat(slug: string, keywords: string[]): boolean {
  return keywords.some(kw => slug.includes(kw));
}

const grupos = subcats.map(sub => ({
  ...sub,
  articulos: articulosOrdenados.filter(a => matchSubcat(a.slug, sub.keywords)),
}));

// Artículos que no encajan en ninguna subcategoría
const asignados = new Set(grupos.flatMap(g => g.articulos.map(a => a.slug)));
const sinGrupo = articulosOrdenados.filter(a => !asignados.has(a.slug));

const destacados = articulosOrdenados.filter(a => a.data.destacado).slice(0, 3);

const perroCount = articulosOrdenados.filter(a => a.data.animal === 'perro' || a.data.animal === 'ambos').length;
const gatoCount = articulosOrdenados.filter(a => a.data.animal === 'gato' || a.data.animal === 'ambos').length;

const siteUrl = 'https://patasyhogar.com';
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${info.nombre} para perros y gatos`,
  numberOfItems: articulosOrdenados.length,
  itemListElement: articulosOrdenados.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${siteUrl}/${a.data.categoria}/${a.slug}/`,
    name: a.data.titulo,
  })),
};

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${info.nombre} para perros y gatos`,
  description: info.descripcion,
  url: `${siteUrl}/${categoria}/`,
  numberOfItems: articulosOrdenados.length,
  inLanguage: 'es',
  isPartOf: {
    '@type': 'WebSite',
    name: 'Patas y Hogar',
    url: siteUrl,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: info.nombre, item: `${siteUrl}/${categoria}/` },
  ],
};
---

<Base
  title={`${info.nombre} para mascotas ${new Date().getFullYear()} | Patas y Hogar`}
  description={info.descripcion}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <div class="container">
    <nav class="breadcrumb" aria-label="Migas de pan">
      <a href="/">Inicio</a>
      <span aria-hidden="true">&rsaquo;</span>
      <span aria-current="page">{info.nombre}</span>
    </nav>
  </div>

  <div class="category-page-header">
    <div class="container">
      <div class="category-icon-large" aria-hidden="true">
        <IconCategory category={categoria as string} size={48} />
      </div>
      <h1>{info.nombre} para mascotas</h1>
      <p>{info.descripcion}</p>

      {/* Navegación rápida por subcategoría — dentro del banner */}
      {articulosOrdenados.length > 0 && (
        <nav class="subcat-nav" aria-label="Subcategorías">
          {grupos.filter(g => g.articulos.length > 0).map(g => (
            <a href={`#${g.id}`} class="subcat-nav-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={subcatSvgPaths[g.id] || subcatSvgPaths['otros']} />
              <span>{g.nombre}</span>
              <span class="subcat-nav-count">{g.articulos.length}</span>
            </a>
          ))}
          {sinGrupo.length > 0 && (
            <a href="#otros" class="subcat-nav-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={subcatSvgPaths['otros']} />
              <span>Otros</span>
              <span class="subcat-nav-count">{sinGrupo.length}</span>
            </a>
          )}
        </nav>
      )}
    </div>
  </div>

  <div class="container section">

    <!-- Intro SEO -->
    <div class="category-intro">
      <p>{info.intro}</p>
    </div>

    {articulosOrdenados.length > 0 ? (
      <>

        {/* Filtro por animal */}
        {perroCount > 0 && gatoCount > 0 && (
          <AnimalFilter perroCount={perroCount} gatoCount={gatoCount} totalCount={articulosOrdenados.length} />
        )}

        {/* Destacados */}
        {destacados.length > 0 && (
          <div style="margin-bottom: 3rem;">
            <h2 class="subcat-heading">
              <span class="subcat-heading-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </span>
              Guías destacadas
            </h2>
            <div class="articles-grid">
              {destacados.map((articulo, i) => (
                <ArticleCard articulo={articulo} eager={i < 2} />
              ))}
            </div>
          </div>
        )}

        {/* Subcategorías */}
        {grupos.filter(g => g.articulos.length > 0).map(g => (
          <section id={g.id} class="subcat-section">
            <h2 class="subcat-heading">
              <span class="subcat-heading-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={subcatSvgPaths[g.id] || subcatSvgPaths['otros']} />
              </span>
              {g.nombre}
              <span class="subcat-heading-count">
                {g.articulos.length} {g.articulos.length === 1 ? 'artículo' : 'artículos'}
              </span>
            </h2>
            <div class="articles-grid">
              {g.articulos.map(articulo => (
                <ArticleCard articulo={articulo} />
              ))}
            </div>
          </section>
        ))}

        {/* Sin grupo */}
        {sinGrupo.length > 0 && (
          <section id="otros" class="subcat-section">
            <h2 class="subcat-heading">
              <span class="subcat-heading-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={subcatSvgPaths['otros']} />
              </span>
              Otras guías
              <span class="subcat-heading-count">
                {sinGrupo.length} {sinGrupo.length === 1 ? 'artículo' : 'artículos'}
              </span>
            </h2>
            <div class="articles-grid">
              {sinGrupo.map(articulo => (
                <ArticleCard articulo={articulo} />
              ))}
            </div>
          </section>
        )}
      </>
    ) : (
      <div class="text-center" style="padding: 4rem 0;">
        <div style="margin-bottom: 1rem; color: var(--color-primary);" aria-hidden="true">
          <IconCategory category={categoria as string} size={48} />
        </div>
        <h2 style="margin-bottom: 0.5rem;">Próximamente</h2>
        <p class="text-muted">Estamos preparando los primeros artículos de esta categoría.</p>
        <a href="/" class="affiliate-button" style="margin-top: 1.5rem; display: inline-flex;">
          ← Volver al inicio
        </a>
      </div>
    )}
  </div>
</Base>

<SmoothScroll />

