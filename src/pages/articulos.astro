---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import IconCategory from '@/components/IconCategory.astro';
import { getCollection } from 'astro:content';

const articulos = await getCollection('articulos');
const articulosOrdenados = articulos.sort(
  (a, b) => b.data.fecha.getTime() - a.data.fecha.getTime()
);

const perroCount = articulosOrdenados.filter(a => a.data.animal === 'perro' || a.data.animal === 'ambos').length;
const gatoCount = articulosOrdenados.filter(a => a.data.animal === 'gato' || a.data.animal === 'ambos').length;

const siteUrl = 'https://patasyhogar.com';
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Todos los artículos' },
  ],
};
---

<Base
  title="Todos los artículos | Patas y Hogar"
  description="Todos los artículos, guías y comparativas de productos para perros y gatos en Patas y Hogar. Filtra por animal o categoría."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <div class="category-page-header">
    <div class="container">
      <div class="category-icon-large" aria-hidden="true"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg></div>
      <h1>Todos los artículos</h1>
      <p>{articulosOrdenados.length} guías y comparativas para perros y gatos</p>
    </div>
  </div>

  <div class="container section">
    <nav class="breadcrumb" aria-label="Migas de pan">
      <a href="/">Inicio</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <span>Todos los artículos</span>
    </nav>

    {/* Combined filters */}
    <div class="all-articles-filters">
      <div class="filter-group">
        <span class="filter-label">Animal:</span>
        <div class="animal-filter" role="tablist" aria-label="Filtrar por animal">
          <button class="animal-filter-btn active" data-filter="todos" role="tab" aria-selected="true">
            Todos <span class="animal-filter-count">{articulosOrdenados.length}</span>
          </button>
          <button class="animal-filter-btn" data-filter="perro" role="tab" aria-selected="false">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 5h2"/><path d="M19 12c-.667 5.333-2.333 8-5 8h-4c-2.667 0-4.333-2.667-5-8"/><path d="M11 16c0 .667.333 1 1 1s1-.333 1-1h-2"/><path d="M12 18v2"/><path d="M10 11v.01"/><path d="M14 11v.01"/><path d="M5 4l6 .97-6.238 6.688a1.021 1.021 0 0 1-1.41.111.953.953 0 0 1-.327-.954l1.975-6.815"/><path d="M19 4l-6 .97 6.238 6.688c.358.408.989.458 1.41.111a.953.953 0 0 0 .327-.954l-1.975-6.815"/></svg>
            Perros <span class="animal-filter-count">{perroCount}</span>
          </button>
          <button class="animal-filter-btn" data-filter="gato" role="tab" aria-selected="false">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 3v10a8 8 0 1 1-16 0v-10l3.432 3.432a7.963 7.963 0 0 1 4.568-1.432c1.769 0 3.403.574 4.728 1.546l3.272-3.546"/><path d="M2 16h5l-4 4"/><path d="M22 16h-5l4 4"/><path d="M11 16a1 1 0 1 0 2 0 1 1 0 1 0-2 0"/><path d="M9 11v.01"/><path d="M15 11v.01"/></svg>
            Gatos <span class="animal-filter-count">{gatoCount}</span>
          </button>
        </div>
      </div>
      <div class="filter-group">
        <span class="filter-label">Tipo:</span>
        <div class="tipo-filter" role="tablist" aria-label="Filtrar por tipo">
          <button class="tipo-filter-btn active" data-tipo="todos">Todos</button>
          <button class="tipo-filter-btn" data-tipo="comparativa">Comparativas</button>
          <button class="tipo-filter-btn" data-tipo="informativo">Cuidados</button>
        </div>
      </div>
      <div class="filter-group">
        <span class="filter-label">Categoría:</span>
        <div class="cat-filter" role="tablist" aria-label="Filtrar por categoría">
          <button class="cat-filter-btn active" data-cat="todos">Todas</button>
          <button class="cat-filter-btn" data-cat="alimentacion"><IconCategory category="alimentacion" size={14} /> Alimentación</button>
          <button class="cat-filter-btn" data-cat="higiene"><IconCategory category="higiene" size={14} /> Higiene</button>
          <button class="cat-filter-btn" data-cat="paseo"><IconCategory category="paseo" size={14} /> Paseo</button>
          <button class="cat-filter-btn" data-cat="juguetes"><IconCategory category="juguetes" size={14} /> Juguetes</button>
          <button class="cat-filter-btn" data-cat="hogar"><IconCategory category="hogar" size={14} /> Hogar</button>
        </div>
      </div>
      <p class="filter-count" id="filter-count"></p>
    </div>

    <div class="articles-grid">
      {articulosOrdenados.map((a, i) => (
        <ArticleCard articulo={a} headingLevel={2} eager={i < 2} />
      ))}
    </div>
  </div>
</Base>

<script>
  function initArticleFilters() {
    const animalBtns = document.querySelectorAll('.animal-filter-btn');
    const catBtns = document.querySelectorAll('.cat-filter-btn');
    const tipoBtns = document.querySelectorAll('.tipo-filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.article-card[data-animal]');
    const countEl = document.getElementById('filter-count');

    let activeAnimal = 'todos';
    let activeCat = 'todos';
    let activeTipo = 'todos';

    function applyFilters() {
      let visible = 0;
      cards.forEach(card => {
        const animal = card.dataset.animal || '';
        const tipo = card.dataset.tipo || 'comparativa';
        const catBadge = card.querySelector('.article-card-category');
        const cardCat = catBadge ? catBadge.className.replace(/.*badge-(\w+).*/, '$1') : '';

        const animalMatch = activeAnimal === 'todos' || animal === activeAnimal || animal === 'ambos';
        const catMatch = activeCat === 'todos' || cardCat === activeCat;
        const tipoMatch = activeTipo === 'todos' || tipo === activeTipo;

        if (animalMatch && catMatch && tipoMatch) {
          card.style.display = '';
          visible++;
        } else {
          card.style.display = 'none';
        }
      });
      if (countEl) {
        countEl.textContent = `Mostrando ${visible} de ${cards.length} artículos`;
      }
    }

    animalBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        activeAnimal = (btn as HTMLElement).dataset.filter || 'todos';
        animalBtns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        applyFilters();
      });
    });

    catBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        activeCat = (btn as HTMLElement).dataset.cat || 'todos';
        catBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilters();
      });
    });

    tipoBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        activeTipo = (btn as HTMLElement).dataset.tipo || 'todos';
        tipoBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilters();
      });
    });

    applyFilters();
  }

  document.addEventListener('DOMContentLoaded', initArticleFilters);
</script>

<style>
  .all-articles-filters {
    margin-bottom: 2rem;
  }
  .filter-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .filter-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    min-width: 70px;
  }
  .animal-filter, .cat-filter, .tipo-filter {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .animal-filter-btn, .cat-filter-btn, .tipo-filter-btn {
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: var(--neutral-50);
    color: var(--neutral-500);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .animal-filter-btn:hover, .cat-filter-btn:hover, .tipo-filter-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .animal-filter-btn[data-filter="perro"]:hover {
    border-color: var(--dog-color);
    color: var(--dog-color);
  }
  .animal-filter-btn[data-filter="gato"]:hover {
    border-color: var(--cat-color);
    color: var(--cat-color);
  }
  .animal-filter-btn.active, .cat-filter-btn.active, .tipo-filter-btn.active {
    background: var(--green-800);
    border-color: var(--green-800);
    color: white;
  }
  .animal-filter-btn.active[data-filter="perro"] {
    background: var(--dog-bg);
    border-color: var(--dog-color);
    color: var(--dog-color);
  }
  .animal-filter-btn.active[data-filter="gato"] {
    background: var(--cat-bg);
    border-color: var(--cat-color);
    color: var(--cat-color);
  }
  .animal-filter-count {
    font-size: 0.7rem;
    opacity: 0.8;
  }
  .filter-count {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }
</style>
