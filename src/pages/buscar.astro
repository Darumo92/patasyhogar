---
import Base from '@/layouts/Base.astro';

const siteUrl = 'https://patasyhogar.com';
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Buscar' },
  ],
};
---

<Base
  title="Buscador de artículos | Patas y Hogar"
  description="Busca entre todas nuestras guías y comparativas de productos para perros y gatos. Encuentra análisis de piensos, juguetes, camas, antiparasitarios y más."
  canonical="https://patasyhogar.com/buscar/"
>
  <meta name="robots" content="noindex, follow" slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <div class="container section">
    <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem;">
      Buscar artículos
    </h1>
    <p style="color: var(--color-text-muted); margin-bottom: 2rem;">
      Encuentra guías y comparativas sobre productos para tu mascota
    </p>

    <div class="search-box">
      <label for="search-input" class="sr-only">Buscar artículos</label>
      <div style="position: relative;">
        <span class="search-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></span>
        <input
          type="search"
          id="search-input"
          placeholder="¿Qué estás buscando? Ej: pienso cachorro, cama gato…"
          autocomplete="off"
          spellcheck="false"
        />
      </div>
      <div id="search-meta" class="search-meta" style="display:none;"></div>
    </div>

    <div id="results-container">
      <div id="loading-state" class="search-state">
        <p class="text-muted">Cargando índice de artículos…</p>
      </div>
      <div id="empty-state" class="search-state" style="display:none;">
        <div style="margin-bottom: 0.75rem;"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.4;" aria-hidden="true"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><circle cx="4" cy="8" r="2"/><circle cx="2" cy="16" r="2"/><path d="M15.8 13.3a1.5 1.5 0 0 0-2.2-.8 6 6 0 0 1-6.2 0 1.5 1.5 0 0 0-2.2.8l-.7 1.4A2 2 0 0 0 6.3 17h11.4a2 2 0 0 0 1.8-2.7Z"/></svg></div>
        <p class="text-muted">Escribe algo para buscar entre los artículos</p>
      </div>
      <div id="no-results-state" class="search-state" style="display:none;">
        <div style="margin-bottom: 0.75rem;"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.4;" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="m8 8 6 6"/><path d="m14 8-6 6"/></svg></div>
        <h2 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Sin resultados</h2>
        <p class="text-muted">Prueba con otras palabras clave o explora por categoría:</p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; margin-top: 1rem;">
          <a href="/alimentacion/" class="affiliate-button" style="font-size: 0.85rem; padding: 0.5rem 1rem;">Alimentación</a>
          <a href="/higiene/" class="affiliate-button" style="font-size: 0.85rem; padding: 0.5rem 1rem;">Higiene</a>
          <a href="/paseo/" class="affiliate-button" style="font-size: 0.85rem; padding: 0.5rem 1rem;">Paseo</a>
          <a href="/juguetes/" class="affiliate-button" style="font-size: 0.85rem; padding: 0.5rem 1rem;">Juguetes</a>
          <a href="/hogar/" class="affiliate-button" style="font-size: 0.85rem; padding: 0.5rem 1rem;">Hogar</a>
        </div>
      </div>
      <div id="results-grid" class="articles-grid" style="display:none;" role="region" aria-live="polite" aria-label="Resultados de búsqueda"></div>
    </div>
  </div>
</Base>

<style>
  .search-box {
    margin-bottom: 2.5rem;
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    color: var(--color-text-muted);
    pointer-events: none;
  }

  #search-input {
    width: 100%;
    padding: 0.875rem 1rem 0.875rem 3rem;
    font-size: 1rem;
    font-family: var(--font-sans);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
    color: var(--color-text);
    outline: none;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  #search-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 12%, transparent);
  }

  .search-meta {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .search-state {
    text-align: center;
    padding: 4rem 1rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  const CATEGORIA_NOMBRES: Record<string, string> = {
    alimentacion: 'Alimentación',
    higiene: 'Higiene',
    paseo: 'Paseo y Transporte',
    juguetes: 'Juguetes',
    hogar: 'Hogar y Descanso',
  };

  interface Article {
    titulo: string;
    descripcion: string;
    slug: string;
    categoria: string;
    animal: string;
    tipo: string;
    imagen: string | null;
    tags: string[];
    contenido: string;
  }

  const ANIMAL_SVG: Record<string, string> = {
    perro: '<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-label="Perro" role="img"><path fill-rule="evenodd" clip-rule="evenodd" d="M16 4V7C16 9.20914 14.2091 11 12 11H10V15H0V13L0.931622 10.8706C1.25226 10.9549 1.59036 11 1.94124 11C3.74931 11 5.32536 9.76947 5.76388 8.01538L3.82359 7.53031C3.60766 8.39406 2.83158 9.00001 1.94124 9.00001C1.87789 9.00001 1.81539 8.99702 1.75385 8.99119C1.02587 8.92223 0.432187 8.45551 0.160283 7.83121C0.0791432 7.64491 0.0266588 7.44457 0.00781272 7.23658C-0.0112323 7.02639 0.00407892 6.80838 0.0588889 6.58914C0.0588882 6.58914 0.0588896 6.58913 0.0588889 6.58914L0.698705 4.02986C1.14387 2.24919 2.7438 1 4.57928 1H10L12 4H16ZM9 6C9.55229 6 10 5.55228 10 5C10 4.44772 9.55229 4 9 4C8.44771 4 8 4.44772 8 5C8 5.55228 8.44771 6 9 6Z" fill="currentColor"/></svg>',
    gato: '<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-label="Gato" role="img"><path fill-rule="evenodd" clip-rule="evenodd" d="M1 7L4.80061 1.43926C5.56059 0.527292 6.68638 0 7.8735 0H8V4L12 5L15 10L14.1875 11.2188C13.4456 12.3316 12.1967 13 10.8593 13H9L7 16H5L1 7ZM10 9C10.5523 9 11 8.55229 11 8C11 7.44772 10.5523 7 10 7C9.44771 7 9 7.44772 9 8C9 8.55229 9.44771 9 10 9Z" fill="currentColor"/><path d="M10 0.465878V2.43845L12 2.93845V0H11.8735C11.2125 0 10.5704 0.163501 10 0.465878Z" fill="currentColor"/></svg>',
    ambos: '<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-label="Perros y gatos" role="img"><path fill-rule="evenodd" clip-rule="evenodd" d="M16 4V7C16 9.20914 14.2091 11 12 11H10V15H0V13L0.931622 10.8706C1.25226 10.9549 1.59036 11 1.94124 11C3.74931 11 5.32536 9.76947 5.76388 8.01538L3.82359 7.53031C3.60766 8.39406 2.83158 9.00001 1.94124 9.00001C1.87789 9.00001 1.81539 8.99702 1.75385 8.99119C1.02587 8.92223 0.432187 8.45551 0.160283 7.83121C0.0791432 7.64491 0.0266588 7.44457 0.00781272 7.23658C-0.0112323 7.02639 0.00407892 6.80838 0.0588889 6.58914C0.0588882 6.58914 0.0588896 6.58913 0.0588889 6.58914L0.698705 4.02986C1.14387 2.24919 2.7438 1 4.57928 1H10L12 4H16ZM9 6C9.55229 6 10 5.55228 10 5C10 4.44772 9.55229 4 9 4C8.44771 4 8 4.44772 8 5C8 5.55228 8.44771 6 9 6Z" fill="currentColor"/></svg>',
  };

  let allArticles: Article[] = [];

  const input = document.getElementById('search-input') as HTMLInputElement;
  const meta = document.getElementById('search-meta')!;
  const loadingState = document.getElementById('loading-state')!;
  const emptyState = document.getElementById('empty-state')!;
  const noResultsState = document.getElementById('no-results-state')!;
  const resultsGrid = document.getElementById('results-grid')!;

  function normalize(str: string): string {
    return str
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '');
  }

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function highlight(text: string, query: string): string {
    if (!query) return escapeHtml(text);
    const normText = normalize(text);
    const normQuery = normalize(query);
    const idx = normText.indexOf(normQuery);
    if (idx === -1) return escapeHtml(text);
    return (
      escapeHtml(text.slice(0, idx)) +
      '<mark>' +
      escapeHtml(text.slice(idx, idx + query.length)) +
      '</mark>' +
      escapeHtml(text.slice(idx + query.length))
    );
  }

  function getExcerpt(contenido: string, query: string, maxLen = 150): string {
    const norm = normalize(contenido);
    const normQ = normalize(query);
    const idx = norm.indexOf(normQ);
    if (idx === -1) return contenido.slice(0, maxLen) + '…';
    const start = Math.max(0, idx - 60);
    const end = Math.min(contenido.length, idx + query.length + 90);
    const prefix = start > 0 ? '…' : '';
    const suffix = end < contenido.length ? '…' : '';
    return highlight(prefix + contenido.slice(start, end) + suffix, query);
  }

  function renderCard(article: Article, query: string): string {
    const url = article.tipo === 'informativo'
      ? `/cuidados/${encodeURI(article.slug)}/`
      : `/${encodeURI(article.categoria)}/${encodeURI(article.slug)}/`;
    const catNombre = article.tipo === 'informativo'
      ? 'Cuidados'
      : (CATEGORIA_NOMBRES[article.categoria] || escapeHtml(article.categoria));
    const normQ = normalize(query);

    const inTitle = normalize(article.titulo).includes(normQ);
    const inDesc = normalize(article.descripcion).includes(normQ);
    const inTags = article.tags.some(t => normalize(t).includes(normQ));
    const showExcerpt = !inTitle && !inDesc && !inTags && article.contenido;

    const tituloHtml = highlight(article.titulo, query);
    const bodyHtml = showExcerpt
      ? getExcerpt(article.contenido, query)
      : highlight(article.descripcion, query);

    const imgHtml = article.imagen
      ? `<a href="${url}" class="article-card-image" aria-hidden="true" tabindex="-1">
           <img src="${escapeHtml(article.imagen)}" alt="" loading="lazy" />
         </a>`
      : '';

    return `
      <article class="article-card" data-animal="${article.animal}">
        ${imgHtml}
        <div class="article-card-body">
          <div class="article-card-badges">
            <span class="article-card-category badge badge-${article.tipo === 'informativo' ? 'cuidados' : article.categoria}">${catNombre}</span>
            <span class="article-card-animal">${ANIMAL_SVG[article.animal] || ANIMAL_SVG['ambos']}</span>
          </div>
          <a href="${url}"><h3 class="article-card-title">${tituloHtml}</h3></a>
          <p class="article-card-excerpt">${bodyHtml}</p>
          <div class="article-card-meta">
            <a href="${url}" class="article-card-link">Leer más →</a>
          </div>
        </div>
      </article>
    `;
  }

  function search(query: string) {
    const q = query.trim();

    if (!q) {
      loadingState.style.display = 'none';
      emptyState.style.display = '';
      noResultsState.style.display = 'none';
      resultsGrid.style.display = 'none';
      meta.style.display = 'none';
      return;
    }

    const normQ = normalize(q);
    const results = allArticles.filter(a =>
      normalize(a.titulo).includes(normQ) ||
      normalize(a.descripcion).includes(normQ) ||
      normalize(a.contenido).includes(normQ) ||
      a.tags.some(t => normalize(t).includes(normQ))
    );

    // Title matches first
    results.sort((a, b) => {
      const aT = normalize(a.titulo).includes(normQ) ? 0 : 1;
      const bT = normalize(b.titulo).includes(normQ) ? 0 : 1;
      return aT - bT;
    });

    loadingState.style.display = 'none';
    emptyState.style.display = 'none';

    if (results.length === 0) {
      noResultsState.style.display = '';
      resultsGrid.style.display = 'none';
      meta.style.display = 'none';
    } else {
      noResultsState.style.display = 'none';
      resultsGrid.innerHTML = results.map(a => renderCard(a, q)).join('');
      resultsGrid.style.display = '';
      meta.textContent = `${results.length} ${results.length === 1 ? 'resultado' : 'resultados'} para "${q}"`;
      meta.style.display = '';
    }
  }

  const urlQuery = new URLSearchParams(window.location.search).get('q');
  if (urlQuery) input.value = urlQuery;

  fetch('/buscar.json')
    .then(r => r.json())
    .then((data: Article[]) => {
      allArticles = data;
      loadingState.style.display = 'none';
      emptyState.style.display = '';
      if (input.value.trim()) search(input.value);
    })
    .catch(() => {
      loadingState.innerHTML = '<p style="color:var(--color-primary);">Error cargando el índice. Recarga la página.</p>';
    });

  let debounceTimer: ReturnType<typeof setTimeout>;
  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => search(input.value), 200);
  });

  input.focus();
</script>
