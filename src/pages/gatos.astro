---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import SmoothScroll from '@/components/SmoothScroll.astro';
import { getCollection } from 'astro:content';

const articulos = await getCollection('articulos', ({ data }) =>
  data.animal === 'gato' || data.animal === 'ambos'
);
const articulosOrdenados = articulos.sort(
  (a, b) => b.data.fecha.getTime() - a.data.fecha.getTime()
);

const destacados = articulosOrdenados.filter(a => a.data.destacado).slice(0, 3);

const categorias = [
  { slug: 'alimentacion', nombre: 'Alimentación', icono: '🥣' },
  { slug: 'higiene', nombre: 'Higiene', icono: '🪮' },
  { slug: 'paseo', nombre: 'Paseo', icono: '🦮' },
  { slug: 'juguetes', nombre: 'Juguetes', icono: '🧸' },
  { slug: 'hogar', nombre: 'Hogar', icono: '🏠' },
  { slug: 'cuidados', nombre: 'Cuidados', icono: '📖' },
];

const porCategoria = categorias.map(cat => ({
  ...cat,
  articulos: articulosOrdenados.filter(a =>
    cat.slug === 'cuidados' ? a.data.tipo === 'informativo' : a.data.categoria === cat.slug && a.data.tipo !== 'informativo'
  ),
})).filter(c => c.articulos.length > 0);

const siteUrl = 'https://patasyhogar.com';
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Gatos' },
  ],
};
const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Guías y comparativas para gatos',
  description: 'Todas las guías de compra y comparativas de productos para gatos.',
  url: `${siteUrl}/gatos/`,
  numberOfItems: articulosOrdenados.length,
  inLanguage: 'es',
};
---

<Base
  title={`Guías y comparativas para gatos ${new Date().getFullYear()} | Patas y Hogar`}
  description="Guías y comparativas de productos para gatos: pienso, arena, rascadores, juguetes y más. Análisis honestos para elegir lo mejor."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} slot="head" />

  <div class="category-page-header">
    <div class="container">
      <div class="category-icon-large" aria-hidden="true">🐱</div>
      <h1>Todo para tu gato</h1>
      <p>{articulosOrdenados.length} guías y comparativas para elegir lo mejor para tu gato</p>

      <nav class="subcat-nav" aria-label="Categorías">
        {porCategoria.map(cat => (
          <a href={`#${cat.slug}`} class="subcat-nav-link">
            <span aria-hidden="true">{cat.icono}</span>
            <span>{cat.nombre}</span>
            <span class="subcat-nav-count">{cat.articulos.length}</span>
          </a>
        ))}
      </nav>
    </div>
  </div>

  <div class="container section">
    <nav class="breadcrumb" aria-label="Migas de pan">
      <a href="/">Inicio</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <span>Gatos</span>
    </nav>

    <div class="category-intro">
      <p>Hemos analizado decenas de productos para gatos en España: desde el mejor pienso según la edad y necesidades de tu gato, hasta areneros autolimpiables, rascadores, juguetes interactivos y antiparasitarios. Cada guía incluye comparativa de precios entre tiendas para que encuentres la mejor oferta.</p>
    </div>

    {/* Destacados */}
    {destacados.length > 0 && (
      <div style="margin-bottom: 3rem;">
        <h2 class="subcat-heading">
          <span class="subcat-heading-icon" aria-hidden="true">⭐</span>
          Guías más populares
        </h2>
        <div class="articles-grid">
          {destacados.map(a => <ArticleCard articulo={a} />)}
        </div>
      </div>
    )}

    {/* Por categoría */}
    {porCategoria.map(cat => (
      <section id={cat.slug} class="subcat-section">
        <h2 class="subcat-heading">
          <span class="subcat-heading-icon" aria-hidden="true">{cat.icono}</span>
          {cat.nombre}
          <span class="subcat-heading-count">
            {cat.articulos.length} {cat.articulos.length === 1 ? 'artículo' : 'artículos'}
          </span>
        </h2>
        <div class="articles-grid">
          {cat.articulos.map(a => <ArticleCard articulo={a} />)}
        </div>
      </section>
    ))}
  </div>
</Base>

<SmoothScroll />

<style>
  .category-intro {
    background: var(--color-bg-muted);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin-bottom: 2rem;
    border-left: 4px solid var(--color-primary);
  }
  .category-intro p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }
  .subcat-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }
  .subcat-nav-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.85rem;
    border: 1.5px solid var(--color-border);
    border-radius: 99px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    transition: all 0.2s;
    white-space: nowrap;
    background: var(--color-bg-card);
  }
  .subcat-nav-link:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
  .subcat-nav-count {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    background: var(--color-bg-muted);
    padding: 0.1rem 0.4rem;
    border-radius: 99px;
  }
  .subcat-section {
    margin-bottom: 3rem;
    scroll-margin-top: 5rem;
  }
  .subcat-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-border);
    flex-wrap: wrap;
  }
  .subcat-heading-icon {
    font-size: 1.2rem;
  }
  .subcat-heading-count {
    font-weight: 400;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-left: auto;
  }
  @media (max-width: 640px) {
    .subcat-nav { gap: 0.4rem; }
    .subcat-nav-link { padding: 0.4rem 0.7rem; font-size: 0.75rem; }
    .subcat-heading { font-size: 1.05rem; }
    .subcat-heading-count { width: 100%; margin-left: 0; margin-top: 0.25rem; }
  }
</style>
