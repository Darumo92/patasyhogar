---
interface Producto {
  nombre: string;
  precio: string;
  valoracion: number;
  puntosFuertes: string;
  imagen?: string;
  enlaceAmazon?: string;
  enlaceZooplus?: string;
  enlaceTiendanimal?: string;
  marca?: string;
}

const AMAZON_TAG = 'patasyhogar-21';

function amazonHref(url: string): string {
  if (url.includes('tag=')) return url;
  return `${url}${url.includes('?') ? '&' : '?'}tag=${AMAZON_TAG}`;
}

interface Props {
  productos: Producto[];
  titulo?: string;
}

const { productos, titulo } = Astro.props;

const FALLBACK_IMAGE = '/og-default.jpg';
const PRICE_VALID_UNTIL = `${new Date().getFullYear() + 1}-12-31`;

function estrellas(n: number): string {
  return '★'.repeat(Math.round(n)) + '☆'.repeat(5 - Math.round(n));
}

function precioNumerico(precio: string): string | null {
  const match = precio.match(/(\d+[.,]?\d*)/);
  return match ? match[1].replace(',', '.') : null;
}

const productSchemas = productos.map(p => {
  const price = precioNumerico(p.precio);
  return {
    '@type': 'Product',
    name: p.nombre,
    image: p.imagen || FALLBACK_IMAGE,
    description: p.puntosFuertes,
    brand: {
      '@type': 'Brand',
      name: p.marca || p.nombre.split(' ')[0],
    },
    review: {
      '@type': 'Review',
      author: {
        '@type': 'Organization',
        name: 'Patas y Hogar',
      },
      reviewRating: {
        '@type': 'Rating',
        ratingValue: p.valoracion,
        bestRating: 5,
      },
    },
    ...(price && {
      offers: {
        '@type': 'Offer',
        priceCurrency: 'EUR',
        price,
        priceValidUntil: PRICE_VALID_UNTIL,
        availability: 'https://schema.org/InStock',
        ...(p.enlaceAmazon && { url: amazonHref(p.enlaceAmazon) }),
        hasMerchantReturnPolicy: {
          '@type': 'MerchantReturnPolicy',
          applicableCountry: 'ES',
          returnPolicyCategory: 'https://schema.org/MerchantReturnFiniteReturnWindow',
          merchantReturnDays: 30,
          returnMethod: 'https://schema.org/ReturnByMail',
        },
        shippingDetails: {
          '@type': 'OfferShippingDetails',
          shippingDestination: {
            '@type': 'DefinedRegion',
            addressCountry: 'ES',
          },
          deliveryTime: {
            '@type': 'ShippingDeliveryTime',
            handlingTime: {
              '@type': 'QuantitativeValue',
              minValue: 1,
              maxValue: 3,
              unitCode: 'd',
            },
            transitTime: {
              '@type': 'QuantitativeValue',
              minValue: 1,
              maxValue: 5,
              unitCode: 'd',
            },
          },
        },
      },
    }),
  };
});
---

<script is:inline type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: titulo || 'Comparativa de productos',
  numberOfItems: productSchemas.length,
  itemListElement: productSchemas.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: s,
  })),
})} />

{titulo && <h3 class="comp-titulo">{titulo}</h3>}

<div class="comp-grid">
  {productos.map((p, i) => (
    <div class="comp-card">
      {i === 0 && <span class="comp-badge">Top 1</span>}
      <div class="comp-card-header">
        {p.imagen && (
          <img src={p.imagen} alt={p.nombre} width="140" height="140" class="comp-img" loading="lazy" decoding="async" sizes="(max-width: 480px) 140px, 120px" />
        )}
        <div class="comp-card-info">
          <h4 class="comp-name">{p.nombre}</h4>
          <div class="comp-rating-price">
            <span class="comp-rating" title={`${p.valoracion}/5`}>
              {estrellas(p.valoracion)}
              <span class="comp-rating-num">{p.valoracion}/5</span>
            </span>
            <span class="comp-price">{p.precio}</span>
          </div>
        </div>
      </div>
      <p class="comp-pros">{p.puntosFuertes}</p>
      <div class="comp-buttons">
        {p.enlaceAmazon && (
          <a
            href={amazonHref(p.enlaceAmazon)}
            class="affiliate-button amazon"
            target="_blank"
            rel="nofollow noopener noreferrer sponsored"
          >
            🛒 Ver en Amazon
          </a>
        )}
        {p.enlaceZooplus && (
          <a
            href={p.enlaceZooplus}
            class="affiliate-button zooplus"
            target="_blank"
            rel="nofollow noopener noreferrer sponsored"
          >
            🛒 Ver en Zooplus
          </a>
        )}
        {p.enlaceTiendanimal && (
          <a
            href={p.enlaceTiendanimal}
            class="affiliate-button tiendanimal"
            target="_blank"
            rel="nofollow noopener noreferrer sponsored"
          >
            🛒 Ver en Tiendanimal
          </a>
        )}
      </div>
    </div>
  ))}
</div>

<style>
.comp-titulo {
  font-size: 1.2rem;
  font-weight: 800;
  margin-bottom: 1rem;
  letter-spacing: -0.02em;
}

.comp-grid {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin: 1.5rem 0 2rem;
}

.comp-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 1.25rem;
  transition: all 0.25s ease;
  position: relative;
}

.comp-card:first-child {
  border-color: var(--color-primary);
  border-width: 2px;
}

.comp-card:hover {
  border-color: var(--color-border-dark);
  box-shadow: var(--shadow-md);
}

.comp-card:first-child:hover {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-lg);
}

.comp-badge {
  position: absolute;
  top: -0.6rem;
  right: 1rem;
  background: var(--color-primary);
  color: #fff;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 0.15rem 0.6rem;
  border-radius: 100px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.comp-card-header {
  display: flex;
  gap: 1.25rem;
  align-items: flex-start;
}

.comp-img {
  width: 120px;
  height: 120px;
  object-fit: contain;
  border-radius: var(--radius-md);
  background: var(--color-bg-muted);
  padding: 0.5rem;
  flex-shrink: 0;
}

.comp-card-info {
  flex: 1;
  min-width: 0;
}

.comp-name {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--color-text);
  margin: 0 0 0.5rem;
  letter-spacing: -0.01em;
  line-height: 1.3;
}

.comp-rating-price {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.comp-rating {
  color: #f59e0b;
  font-size: 1rem;
  letter-spacing: -1px;
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

.comp-rating-num {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  letter-spacing: normal;
}

.comp-price {
  font-weight: 800;
  font-size: 1.2rem;
  color: var(--color-primary);
  letter-spacing: -0.02em;
}

.comp-pros {
  font-size: 0.88rem;
  color: var(--color-text-muted);
  line-height: 1.55;
  margin: 0.875rem 0 0;
  padding-top: 0.875rem;
  border-top: 1px solid var(--color-border);
}

.comp-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 1rem;
}

.comp-buttons .affiliate-button {
  font-size: 0.82rem;
  padding: 0.5rem 1rem;
}

@media (max-width: 480px) {
  .comp-card-header {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .comp-img {
    width: 140px;
    height: 140px;
  }

  .comp-rating-price {
    justify-content: center;
  }

  .comp-pros {
    text-align: left;
  }

  .comp-buttons {
    justify-content: center;
  }
}
</style>
