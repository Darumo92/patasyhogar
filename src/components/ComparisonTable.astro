---
interface Producto {
  nombre: string;
  precio: string;
  valoracion: number;
  puntosFuertes: string;
  imagen?: string;
  enlaceAmazon?: string;
  enlaceZooplus?: string;
  enlaceTiendanimal?: string;
}

const AMAZON_TAG = 'patasyhogar-21';

function amazonHref(url: string): string {
  if (url.includes('tag=')) return url;
  return `${url}${url.includes('?') ? '&' : '?'}tag=${AMAZON_TAG}`;
}

interface Props {
  productos: Producto[];
  titulo?: string;
}

const { productos, titulo } = Astro.props;

function estrellas(n: number): string {
  return '★'.repeat(Math.round(n)) + '☆'.repeat(5 - Math.round(n));
}
---

{titulo && <h3 style="margin-bottom: 0.5rem;">{titulo}</h3>}

<div class="comparison-table-wrapper">
  <table class="comparison-table">
    <thead>
      <tr>
        <th>Producto</th>
        <th>Valoración</th>
        <th>Precio aprox.</th>
        <th>Puntos fuertes</th>
        <th>Comprar</th>
      </tr>
    </thead>
    <tbody>
      {productos.map(p => (
        <tr>
          <td class="product-name">
            {p.imagen && (
              <img src={p.imagen} alt={p.nombre} width="80" height="80"
                style="display:block; margin-bottom: 0.4rem; border-radius: 4px; object-fit: contain;" />
            )}
            {p.nombre}
          </td>
          <td>
            <span class="rating" title={`${p.valoracion}/5`}>
              {estrellas(p.valoracion)}
            </span>
            <span style="font-size: 0.8rem; color: var(--color-text-muted); margin-left: 0.25rem;">
              {p.valoracion}/5
            </span>
          </td>
          <td class="price">{p.precio}</td>
          <td>{p.puntosFuertes}</td>
          <td>
            <div style="display: flex; flex-direction: column; gap: 0.4rem;">
              {p.enlaceAmazon && (
                <a
                  href={amazonHref(p.enlaceAmazon)}
                  class="affiliate-button amazon"
                  style="font-size: 0.8rem; padding: 0.4rem 0.75rem;"
                  target="_blank"
                  rel="nofollow noopener noreferrer sponsored"
                >
                  🛒 Amazon
                </a>
              )}
              {p.enlaceZooplus && (
                <a
                  href={p.enlaceZooplus}
                  class="affiliate-button zooplus"
                  style="font-size: 0.8rem; padding: 0.4rem 0.75rem;"
                  target="_blank"
                  rel="nofollow noopener noreferrer sponsored"
                >
                  🛒 Zooplus
                </a>
              )}
              {p.enlaceTiendanimal && (
                <a
                  href={p.enlaceTiendanimal}
                  class="affiliate-button tiendanimal"
                  style="font-size: 0.8rem; padding: 0.4rem 0.75rem;"
                  target="_blank"
                  rel="nofollow noopener noreferrer sponsored"
                >
                  🛒 Tiendanimal
                </a>
              )}
            </div>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
