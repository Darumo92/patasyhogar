---
import StoreIcon from './StoreIcon.astro';

interface Producto {
  nombre: string;
  precio: string;
  precioAmazon?: string;
  precioZooplus?: string;
  precioTiendanimal?: string;
  valoracion: number;
  puntosFuertes: string;
  imagen?: string;
  enlaceAmazon?: string;
  enlaceZooplus?: string;
  enlaceTiendanimal?: string;
  marca?: string;
}

const AMAZON_TAG = 'patasyhogar-21';

function amazonHref(url: string): string {
  if (url.includes('tag=')) return url;
  return `${url}${url.includes('?') ? '&' : '?'}tag=${AMAZON_TAG}`;
}

interface Props {
  productos: Producto[];
  titulo?: string;
}

const { productos, titulo } = Astro.props;

const FALLBACK_IMAGE = '/og-default.jpg';
const PRICE_VALID_UNTIL = `${new Date().getFullYear() + 1}-12-31`;

function estrellas(n: number): string {
  return '★'.repeat(Math.round(n)) + '☆'.repeat(5 - Math.round(n));
}

function precioNumerico(precio: string): string | null {
  const match = precio.match(/(\d+[.,]?\d*)/);
  return match ? match[1].replace(',', '.') : null;
}

const productSchemas = productos.map(p => {
  const price = precioNumerico(p.precio);
  return {
    '@type': 'Product',
    name: p.nombre,
    image: p.imagen || FALLBACK_IMAGE,
    description: p.puntosFuertes,
    brand: {
      '@type': 'Brand',
      name: p.marca || p.nombre.split(' ')[0],
    },
    review: {
      '@type': 'Review',
      author: {
        '@type': 'Organization',
        name: 'Patas y Hogar',
      },
      reviewRating: {
        '@type': 'Rating',
        ratingValue: p.valoracion,
        bestRating: 5,
      },
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: p.valoracion,
      bestRating: 5,
      ratingCount: 1,
    },
    ...(price && {
      offers: {
        '@type': 'Offer',
        priceCurrency: 'EUR',
        price,
        priceValidUntil: PRICE_VALID_UNTIL,
        availability: 'https://schema.org/InStock',
        ...(p.enlaceAmazon && { url: amazonHref(p.enlaceAmazon) }),
        hasMerchantReturnPolicy: {
          '@type': 'MerchantReturnPolicy',
          applicableCountry: 'ES',
          returnPolicyCategory: 'https://schema.org/MerchantReturnFiniteReturnWindow',
          merchantReturnDays: 30,
          returnMethod: 'https://schema.org/ReturnByMail',
          returnFees: 'https://schema.org/FreeReturn',
        },
        shippingDetails: {
          '@type': 'OfferShippingDetails',
          shippingRate: {
            '@type': 'MonetaryAmount',
            value: 0,
            currency: 'EUR',
          },
          shippingDestination: {
            '@type': 'DefinedRegion',
            addressCountry: 'ES',
          },
          deliveryTime: {
            '@type': 'ShippingDeliveryTime',
            handlingTime: {
              '@type': 'QuantitativeValue',
              minValue: 1,
              maxValue: 3,
              unitCode: 'd',
            },
            transitTime: {
              '@type': 'QuantitativeValue',
              minValue: 1,
              maxValue: 5,
              unitCode: 'd',
            },
          },
        },
      },
    }),
  };
});

function tiendas(p: Producto) {
  const list: { nombre: string; clase: string; precio: string; href: string; mejor: boolean }[] = [];
  if (p.enlaceAmazon) list.push({ nombre: 'Amazon', clase: 'amazon', precio: p.precioAmazon || p.precio, href: amazonHref(p.enlaceAmazon), mejor: false });
  if (p.enlaceZooplus) list.push({ nombre: 'Zooplus', clase: 'zooplus', precio: p.precioZooplus || p.precio, href: p.enlaceZooplus, mejor: false });
  if (p.enlaceTiendanimal) list.push({ nombre: 'Tiendanimal', clase: 'tiendanimal', precio: p.precioTiendanimal || p.precio, href: p.enlaceTiendanimal, mejor: false });

  // Mark cheapest store if there are 2+ stores with different prices
  if (list.length > 1) {
    const withNum = list.map(s => ({ ...s, num: parseFloat((s.precio.match(/(\d+[.,]?\d*)/) || ['0','0'])[1].replace(',', '.')) }));
    const min = Math.min(...withNum.map(s => s.num));
    const cheapest = withNum.filter(s => s.num === min);
    if (cheapest.length === 1 && new Set(withNum.map(s => s.num)).size > 1) {
      const idx = list.findIndex(s => s.nombre === cheapest[0].nombre);
      if (idx >= 0) list[idx].mejor = true;
    }
  }
  return list;
}
---

{productSchemas.map(s => (
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    ...s,
  })} />
))}

{titulo && <h3 class="comp-titulo">{titulo}</h3>}

<div class="comp-grid">
  {productos.map((p, i) => {
    const stores = tiendas(p);
    return (
      <div class={`comp-card ${i === 0 ? 'comp-card--top' : ''}`}>
        {i === 0 && <span class="comp-badge">Mejor opción</span>}

        <div class="comp-header">
          {p.imagen && (
            <div class="comp-img-wrap">
              <img src={p.imagen} alt={p.nombre} width="140" height="140" class="comp-img" loading="lazy" decoding="async" sizes="(max-width: 480px) 140px, 120px" />
            </div>
          )}
          <div class="comp-header-info">
            <h4 class="comp-name">{p.nombre}</h4>
            <div class="comp-meta">
              <span class="comp-stars" title={`${p.valoracion}/5`}>
                {estrellas(p.valoracion)}
                <span class="comp-stars-num">{p.valoracion}/5</span>
              </span>
              <span class="comp-price">{p.precio}</span>
            </div>
          </div>
        </div>

        <p class="comp-desc">{p.puntosFuertes}</p>

        <div class="comp-stores">
          {stores.map(s => (
            <a
              href={s.href}
              class={`affiliate-button ${s.clase}`}
              target="_blank"
              rel="nofollow noopener noreferrer sponsored"
            >
              <StoreIcon tienda={s.clase as any} size={15} />
              {s.nombre} — {s.precio}
              {s.mejor && <span class="comp-best">Mejor precio</span>}
            </a>
          ))}
        </div>
      </div>
    );
  })}
</div>

<style>
.comp-titulo {
  font-size: 1.25rem;
  font-weight: 800;
  margin-bottom: 1.25rem;
  letter-spacing: -0.02em;
}

.comp-grid {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin: 1.5rem 0 2rem;
}

.comp-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  position: relative;
  transition: box-shadow 0.2s ease;
}

.comp-card:hover {
  box-shadow: var(--shadow-md);
}

.comp-card--top {
  border: 2px solid var(--color-primary);
}

.comp-card--top:hover {
  box-shadow: 0 4px 24px color-mix(in srgb, var(--color-primary) 15%, transparent);
}

.comp-badge {
  position: absolute;
  top: -0.65rem;
  left: 1.25rem;
  background: var(--color-primary);
  color: #fff;
  font-size: 0.68rem;
  font-weight: 700;
  padding: 0.2rem 0.7rem;
  border-radius: 100px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

/* --- Header: image + name/rating/price --- */
.comp-header {
  display: flex;
  gap: 1.25rem;
  align-items: flex-start;
}

.comp-img-wrap {
  flex-shrink: 0;
  background: var(--color-bg-muted);
  border-radius: var(--radius-md);
  padding: 0.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.comp-img {
  width: 110px;
  height: 110px;
  object-fit: contain;
}

.comp-header-info {
  flex: 1;
  min-width: 0;
}

.comp-name {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--color-text);
  margin: 0 0 0.6rem;
  line-height: 1.3;
}

.comp-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.comp-stars {
  color: #f59e0b;
  font-size: 1rem;
  letter-spacing: -1px;
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

.comp-stars-num {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  letter-spacing: normal;
}

.comp-price {
  font-weight: 800;
  font-size: 1.3rem;
  color: var(--color-primary);
  letter-spacing: -0.02em;
}

/* --- Description --- */
.comp-desc {
  font-size: 0.88rem;
  color: var(--color-text-muted);
  line-height: 1.6;
  margin: 1rem 0 0;
  padding-top: 0.875rem;
  border-top: 1px solid var(--color-border);
}

/* --- Store buttons --- */
.comp-stores {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 1rem;
}

.comp-stores .affiliate-button {
  font-size: 0.85rem;
  padding: 0.6rem 1.1rem;
}

.comp-best {
  font-size: 0.65rem;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.25);
  padding: 0.1rem 0.4rem;
  border-radius: 100px;
  text-transform: uppercase;
  letter-spacing: 0.03em;
}

@media (max-width: 480px) {
  .comp-card {
    padding: 1.25rem 1rem;
  }

  .comp-header {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .comp-img {
    width: 130px;
    height: 130px;
  }

  .comp-meta {
    justify-content: center;
  }

  .comp-desc {
    text-align: left;
  }

  .comp-stores {
    flex-direction: column;
  }

  .comp-stores .affiliate-button {
    width: 100%;
    justify-content: center;
    font-size: 0.85rem;
    padding: 0.6rem 1.1rem;
    width: 100%;
  }
}
</style>
