---
interface Producto {
  nombre: string;
  precio: string;
  valoracion: number;
  puntosFuertes: string;
  imagen?: string;
  enlaceAmazon?: string;
  enlaceZooplus?: string;
  enlaceTiendanimal?: string;
}

const AMAZON_TAG = 'patasyhogar-21';

function amazonHref(url: string): string {
  if (url.includes('tag=')) return url;
  return `${url}${url.includes('?') ? '&' : '?'}tag=${AMAZON_TAG}`;
}

interface Props {
  productos: Producto[];
  titulo?: string;
}

const { productos, titulo } = Astro.props;

function estrellas(n: number): string {
  return '★'.repeat(Math.round(n)) + '☆'.repeat(5 - Math.round(n));
}

function precioNumerico(precio: string): string | null {
  const match = precio.match(/(\d+[.,]?\d*)/);
  return match ? match[1].replace(',', '.') : null;
}

const productSchemas = productos.map(p => {
  const price = precioNumerico(p.precio);
  return {
    '@type': 'Product',
    name: p.nombre,
    ...(p.imagen && { image: p.imagen }),
    description: p.puntosFuertes,
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: p.valoracion,
      bestRating: 5,
      ratingCount: 1,
    },
    ...(price && {
      offers: {
        '@type': 'Offer',
        priceCurrency: 'EUR',
        price,
        availability: 'https://schema.org/InStock',
        ...(p.enlaceAmazon && { url: amazonHref(p.enlaceAmazon) }),
      },
    }),
  };
});
---

<script is:inline type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: titulo || 'Comparativa de productos',
  numberOfItems: productSchemas.length,
  itemListElement: productSchemas.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: s,
  })),
})} />

{titulo && <h3 style="margin-bottom: 0.5rem;">{titulo}</h3>}

<div class="comparison-table-wrapper">
  <table class="comparison-table">
    <thead>
      <tr>
        <th scope="col">Producto</th>
        <th scope="col">Valoración</th>
        <th scope="col">Precio aprox.</th>
        <th scope="col">Puntos fuertes</th>
        <th scope="col">Comprar</th>
      </tr>
    </thead>
    <tbody>
      {productos.map(p => (
        <tr>
          <td class="product-name">
            {p.imagen && (
              <img src={p.imagen} alt={p.nombre} width="80" height="80"
                style="display:block; margin-bottom: 0.4rem; border-radius: 4px; object-fit: contain;" />
            )}
            {p.nombre}
          </td>
          <td>
            <span class="rating" title={`${p.valoracion}/5`}>
              {estrellas(p.valoracion)}
            </span>
            <span style="font-size: 0.8rem; color: var(--color-text-muted); margin-left: 0.25rem;">
              {p.valoracion}/5
            </span>
          </td>
          <td class="price">{p.precio}</td>
          <td>{p.puntosFuertes}</td>
          <td>
            <div style="display: flex; flex-direction: column; gap: 0.4rem;">
              {p.enlaceAmazon && (
                <a
                  href={amazonHref(p.enlaceAmazon)}
                  class="affiliate-button amazon"
                  style="font-size: 0.8rem; padding: 0.4rem 0.75rem;"
                  target="_blank"
                  rel="nofollow noopener noreferrer sponsored"
                >
                  🛒 Amazon
                </a>
              )}
              {p.enlaceZooplus && (
                <a
                  href={p.enlaceZooplus}
                  class="affiliate-button zooplus"
                  style="font-size: 0.8rem; padding: 0.4rem 0.75rem;"
                  target="_blank"
                  rel="nofollow noopener noreferrer sponsored"
                >
                  🛒 Zooplus
                </a>
              )}
              {p.enlaceTiendanimal && (
                <a
                  href={p.enlaceTiendanimal}
                  class="affiliate-button tiendanimal"
                  style="font-size: 0.8rem; padding: 0.4rem 0.75rem;"
                  target="_blank"
                  rel="nofollow noopener noreferrer sponsored"
                >
                  🛒 Tiendanimal
                </a>
              )}
            </div>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
