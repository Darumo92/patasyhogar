---
import type { CollectionEntry } from 'astro:content';

interface Props {
  articulo: CollectionEntry<'articulos'>;
}

const { articulo } = Astro.props;
const { titulo, descripcion, categoria, animal, fecha, imagen } = articulo.data;

const animalEmoji = animal === 'perro' ? '🐶' : animal === 'gato' ? '🐱' : '🐾';

const categoriasInfo: Record<string, { nombre: string; icono: string }> = {
  alimentacion: { nombre: 'Alimentación', icono: '🥣' },
  higiene: { nombre: 'Higiene', icono: '🪮' },
  descanso: { nombre: 'Descanso', icono: '🏠' },
  comportamiento: { nombre: 'Enriquecimiento', icono: '🧸' },
};

const info = categoriasInfo[categoria];
const url = `/${categoria}/${articulo.slug}`;

const fechaFormateada = fecha.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="article-card" data-animal={animal}>
  <a href={url} class="article-card-image" aria-hidden="true" tabindex="-1">
    {imagen ? (
      <img src={imagen} alt="" loading="lazy" />
    ) : (
      <div class="article-card-image-placeholder" aria-hidden="true">
        {info.icono}
      </div>
    )}
  </a>

  <div class="article-card-body">
    <div class="article-card-badges">
      <span class={`article-card-category badge badge-${categoria}`}>
        {info.nombre}
      </span>
      <span class="article-card-animal" aria-label={animal === 'perro' ? 'Para perros' : animal === 'gato' ? 'Para gatos' : 'Para perros y gatos'}>
        {animalEmoji}
      </span>
    </div>

    <a href={url}>
      <h3 class="article-card-title">{titulo}</h3>
    </a>

    <p class="article-card-excerpt">{descripcion}</p>

    <div class="article-card-meta">
      <time datetime={fecha.toISOString().split('T')[0]}>{fechaFormateada}</time>
      <a href={url} class="article-card-link" aria-label={`Leer más sobre ${titulo}`}>Leer más →</a>
    </div>
  </div>
</article>
