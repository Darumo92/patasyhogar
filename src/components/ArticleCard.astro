---
import type { CollectionEntry } from 'astro:content';

interface Props {
  articulo: CollectionEntry<'articulos'>;
  headingLevel?: 2 | 3;
  eager?: boolean;
}

const { articulo, headingLevel = 3, eager = false } = Astro.props;
const Heading = `h${headingLevel}` as any;
const { titulo, descripcion, categoria, animal, fecha, actualizadoEn, imagen, tipo } = articulo.data;

const esInformativo = tipo === 'informativo';

const categoriasInfo: Record<string, { nombre: string }> = {
  alimentacion: { nombre: 'Alimentación' },
  higiene: { nombre: 'Higiene' },
  paseo: { nombre: 'Paseo' },
  juguetes: { nombre: 'Juguetes' },
  hogar: { nombre: 'Hogar' },
};

const info = esInformativo
  ? { nombre: 'Cuidados' }
  : categoriasInfo[categoria];
const url = esInformativo
  ? `/cuidados/${articulo.slug}/`
  : `/${categoria}/${articulo.slug}/`;

const wordCount = articulo.body
  .replace(/^---[\s\S]*?---/, '')
  .replace(/^import\s.+$/gm, '')
  .replace(/<[^>]+>/g, ' ')
  .replace(/[#*`_~\[\]()]/g, '')
  .trim()
  .split(/\s+/).length;
const minutosLectura = Math.max(1, Math.round(wordCount / 200));

const fechaMostrar = actualizadoEn || fecha;
const fechaFormateada = fechaMostrar.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const esActualizado = !!actualizadoEn;
---

<article class="article-card" data-animal={animal} data-tipo={esInformativo ? 'informativo' : 'comparativa'}>
  <a href={url} class="article-card-image" aria-hidden="true" tabindex="-1">
    {imagen ? (
      <img src={imagen} alt={titulo} width="400" height="225" loading={eager ? "eager" : "lazy"} decoding={eager ? "sync" : "async"} sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 400px" fetchpriority={eager ? "high" : "low"} />
    ) : (
      <div class="article-card-image-placeholder" aria-hidden="true">
        {animal === 'gato' ? (
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.3;"><path d="M4 15V3.5a.5.5 0 0 1 .8-.4l4.2 3.15a.5.5 0 0 0 .6 0L13.8 3.1a.5.5 0 0 1 .8.4V15M2 15a9 9 0 1 0 18 0 9 9 0 0 0-18 0zM10 13v.01M14 13v.01M10 17c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/></svg>
        ) : (
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.3;"><path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5"/><path d="M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.855-1.45-2.239-2.5"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75z"/><path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444a11.702 11.702 0 0 0-.493-3.309"/></svg>
        )}
      </div>
    )}
  </a>

  <div class="article-card-body">
    <div class="article-card-badges">
      <span class={`article-card-category badge badge-${categoria}`}>
        {info.nombre}
      </span>
      <span class="article-card-animal" aria-label={animal === 'perro' ? 'Para perros' : animal === 'gato' ? 'Para gatos' : 'Para perros y gatos'}>
        {animal === 'gato' ? (
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M4 15V3.5a.5.5 0 0 1 .8-.4l4.2 3.15a.5.5 0 0 0 .6 0L13.8 3.1a.5.5 0 0 1 .8.4V15M2 15a9 9 0 1 0 18 0 9 9 0 0 0-18 0zM10 13v.01M14 13v.01M10 17c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/></svg>
        ) : animal === 'perro' ? (
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5"/><path d="M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.855-1.45-2.239-2.5"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75z"/><path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444a11.702 11.702 0 0 0-.493-3.309"/></svg>
        ) : (
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5"/><path d="M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.855-1.45-2.239-2.5"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75z"/><path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444a11.702 11.702 0 0 0-.493-3.309"/></svg>
        )}
      </span>
    </div>

    <a href={url}>
      <Heading class="article-card-title">{titulo}</Heading>
    </a>

    <p class="article-card-excerpt">{descripcion}</p>

    <div class="article-card-meta">
      <time datetime={fechaMostrar.toISOString().split('T')[0]}>
        {esActualizado ? `Actualizado: ${fechaFormateada}` : fechaFormateada}
      </time>
      <span class="article-card-reading-time"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" style="vertical-align:-2px"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> {minutosLectura} min</span>
      <a href={url} class="article-card-link" aria-label={`Leer más sobre ${titulo}`}>Leer más →</a>
    </div>
  </div>
</article>
