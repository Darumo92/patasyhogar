---
import LogoIcon from './LogoIcon.astro';

const categorias = [
  { href: '/alimentacion/', label: 'Alimentación' },
  { href: '/higiene/', label: 'Higiene' },
  { href: '/paseo/', label: 'Paseo y Transporte' },
  { href: '/juguetes/', label: 'Juguetes y Enriquecimiento' },
  { href: '/hogar/', label: 'Hogar y Descanso' },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="logo">
          <LogoIcon size={28} />
          Patas y <span style="color: var(--color-primary)">Hogar</span>
        </a>
        <p>
          Guías de compra y comparativas de productos para perros y gatos.
          Análisis honestos para ayudarte a elegir lo mejor para tu mascota.
        </p>
        <p class="footer-contact-email">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          contacto@patasyhogar.com
        </p>
      </div>

      <nav class="footer-col" aria-label="Categorías">
        <p class="footer-heading">Categorías</p>
        <ul class="footer-links" role="list">
          {categorias.map(c => (
            <li><a href={c.href}>{c.label}</a></li>
          ))}
        </ul>
      </nav>

      <div class="footer-col">
        <nav aria-label="Explorar">
          <p class="footer-heading">Explorar</p>
          <ul class="footer-links" role="list">
            <li><a href="/perros/"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 5h2"/><path d="M19 12c-.667 5.333-2.333 8-5 8h-4c-2.667 0-4.333-2.667-5-8"/><path d="M11 16c0 .667.333 1 1 1s1-.333 1-1h-2"/><path d="M12 18v2"/><path d="M10 11v.01"/><path d="M14 11v.01"/><path d="M5 4l6 .97-6.238 6.688a1.021 1.021 0 0 1-1.41.111.953.953 0 0 1-.327-.954l1.975-6.815"/><path d="M19 4l-6 .97 6.238 6.688c.358.408.989.458 1.41.111a.953.953 0 0 0 .327-.954l-1.975-6.815"/></svg> Guías para perros</a></li>
            <li><a href="/gatos/"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 3v10a8 8 0 1 1-16 0v-10l3.432 3.432a7.963 7.963 0 0 1 4.568-1.432c1.769 0 3.403.574 4.728 1.546l3.272-3.546"/><path d="M2 16h5l-4 4"/><path d="M22 16h-5l4 4"/><path d="M11 16a1 1 0 1 0 2 0 1 1 0 1 0-2 0"/><path d="M9 11v.01"/><path d="M15 11v.01"/></svg> Guías para gatos</a></li>
            <li><a href="/cuidados/"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg> Cuidados y consejos</a></li>
            <li><a href="/buscar/"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg> Buscar artículos</a></li>
            <li><a href="/articulos/"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/><path d="M8 7h6"/><path d="M8 11h8"/></svg> Todos los artículos</a></li>
            <li><a href="/tags/"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/></svg> Temas</a></li>
            <li><a href="/actualizaciones/"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg> Actualizaciones</a></li>
            <li><a href="/rss.xml"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg> RSS Feed</a></li>
            <li><a href="/sobre-mi/">Sobre mí</a></li>
            <li><a href="/contacto/">Contacto</a></li>
          </ul>
        </nav>
        <nav aria-label="Información legal" style="margin-top: 1rem;">
          <p class="footer-heading">Legal</p>
          <ul class="footer-links" role="list">
            <li><a href="/politica-privacidad/">Privacidad</a></li>
            <li><a href="/aviso-legal/">Aviso legal</a></li>
            <li><a href="/cookies/">Cookies</a></li>
          </ul>
        </nav>
      </div>
    </div>

    <div class="footer-newsletter">
      <p class="footer-heading"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:inline;vertical-align:-2px;margin-right:0.35rem"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>Newsletter</p>
      <p class="footer-newsletter-desc">
        Ofertas, nuevos artículos y los mejores consejos. Una vez por semana, directo a tu bandeja.
      </p>
      <form
        action="/api/subscribe"
        method="post"
        class="newsletter-form"
        id="newsletter-form-footer"
      >
        <label for="newsletter-email-footer" class="sr-only">Tu email</label>
        <input
          type="email"
          name="email"
          id="newsletter-email-footer"
          placeholder="tu@email.com"
          required
          aria-label="Tu email"
          class="newsletter-input"
        />
        <button type="submit" class="newsletter-btn">Suscribirme</button>
      </form>
      <p id="newsletter-msg-footer" class="newsletter-msg"></p>
    </div>

    <div class="footer-affiliate-notice">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink:0;margin-top:1px"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
      <span><strong>Aviso de afiliados:</strong> Patasyhogar.com participa en el
      Programa de Afiliados de Amazon EU y otros programas de afiliación. Cuando
      compras a través de nuestros enlaces podemos recibir una comisión sin coste
      adicional para ti. Esto nos ayuda a mantener el sitio gratuito.</span>
    </div>

    <div class="footer-bottom">
      <p>© {year} Patasyhogar.com · Todos los derechos reservados</p>
    </div>
  </div>
</footer>

<script>
  document.querySelectorAll('form[action="/api/subscribe"]').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formEl = e.target as HTMLFormElement;
      const email = (formEl.querySelector('input[name="email"]') as HTMLInputElement).value;
      const btn = formEl.querySelector('button') as HTMLButtonElement;
      const msgEl = formEl.nextElementSibling as HTMLElement;

      btn.textContent = 'Enviando...';
      btn.disabled = true;

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        const data = await res.json();

        if (data.success) {
          formEl.style.display = 'none';
          if (msgEl) {
            msgEl.textContent = '¡Suscrito! Revisa tu email para confirmar.';
            msgEl.style.color = '#22c55e';
            msgEl.style.fontWeight = '600';
          }
        } else {
          if (msgEl) {
            msgEl.textContent = data.error || 'Hubo un error. Inténtalo de nuevo.';
            msgEl.style.color = '#ef4444';
          }
          btn.textContent = 'Suscribirme';
          btn.disabled = false;
        }
      } catch {
        if (msgEl) {
          msgEl.textContent = 'Error de conexión. Inténtalo de nuevo.';
          msgEl.style.color = '#ef4444';
        }
        btn.textContent = 'Suscribirme';
        btn.disabled = false;
      }
    });
  });
</script>
