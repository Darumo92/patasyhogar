---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">

      <!-- Col 1: Brand -->
      <div class="footer-brand">
        <a class="logo" href="/">patas<span>&amp;</span>hogar</a>
        <p>
          Guías de compra y comparativas de productos para perros y gatos.
          Análisis honestos para ayudarte a elegir lo mejor para tu mascota.
        </p>
        <p class="footer-contact-email">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          contacto@patasyhogar.com
        </p>
      </div>

      <!-- Col 2: Categorías -->
      <nav class="footer-col" aria-label="Categorías">
        <p class="footer-heading">Categorías</p>
        <ul class="footer-links" role="list">
          <li><a href="/alimentacion/">Alimentación</a></li>
          <li><a href="/higiene/">Higiene</a></li>
          <li><a href="/paseo/">Paseo</a></li>
          <li><a href="/juguetes/">Juguetes</a></li>
          <li><a href="/hogar/">Hogar</a></li>
        </ul>
      </nav>

      <!-- Col 3: Explorar -->
      <nav class="footer-col" aria-label="Explorar">
        <p class="footer-heading">Explorar</p>
        <ul class="footer-links" role="list">
          <li><a href="/perros/">Perros</a></li>
          <li><a href="/gatos/">Gatos</a></li>
          <li><a href="/cuidados/">Cuidados</a></li>
          <li><a href="/articulos/">Todos los artículos</a></li>
          <li><a href="/selector/">Selector</a></li>
        </ul>
      </nav>

      <!-- Col 4: Legal -->
      <nav class="footer-col" aria-label="Legal">
        <p class="footer-heading">Legal</p>
        <ul class="footer-links" role="list">
          <li><a href="/aviso-legal/">Aviso legal</a></li>
          <li><a href="/politica-privacidad/">Privacidad</a></li>
          <li><a href="/cookies/">Cookies</a></li>
          <li><a href="/contacto/">Contacto</a></li>
        </ul>
      </nav>

    </div>

    <div class="footer-affiliate-notice">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink:0;margin-top:1px"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
      <span><strong>Aviso de afiliados:</strong> Patasyhogar.com participa en el
      Programa de Afiliados de Amazon EU y otros programas de afiliación. Cuando
      compras a través de nuestros enlaces podemos recibir una comisión sin coste
      adicional para ti. Esto nos ayuda a mantener el sitio gratuito.</span>
    </div>

    <div class="footer-bottom">
      <p>© {year} Patasyhogar.com · Todos los derechos reservados</p>
    </div>
  </div>
</footer>
