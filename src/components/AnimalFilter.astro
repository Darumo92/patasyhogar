---
import IconCategory from '@/components/IconCategory.astro';

interface Props {
  perroCount: number;
  gatoCount: number;
  totalCount: number;
}

const { perroCount, gatoCount, totalCount } = Astro.props;
---

<div class="animal-filter" role="tablist" aria-label="Filtrar por animal">
  <button class="animal-filter-btn active" data-filter="todos" role="tab" aria-selected="true">
    Todos <span class="animal-filter-count">{totalCount}</span>
  </button>
  <button class="animal-filter-btn" data-filter="perro" role="tab" aria-selected="false">
    <IconCategory category="perro" size={14} />
    Perros <span class="animal-filter-count">{perroCount}</span>
  </button>
  <button class="animal-filter-btn" data-filter="gato" role="tab" aria-selected="false">
    <IconCategory category="gato" size={14} />
    Gatos <span class="animal-filter-count">{gatoCount}</span>
  </button>
</div>

<script>
  function initAnimalFilter() {
    const buttons = document.querySelectorAll('.animal-filter-btn');
    const cards = document.querySelectorAll('.article-card[data-animal]');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = (btn as HTMLElement).dataset.filter;

        buttons.forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');

        cards.forEach(card => {
          const animal = (card as HTMLElement).dataset.animal;
          if (filter === 'todos' || animal === filter || animal === 'ambos') {
            (card as HTMLElement).style.display = '';
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initAnimalFilter);
</script>

<style>
  .animal-filter {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .animal-filter-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: var(--neutral-50);
    color: var(--neutral-500);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .animal-filter-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .animal-filter-btn[data-filter="perro"]:hover {
    border-color: var(--dog-color);
    color: var(--dog-color);
  }

  .animal-filter-btn[data-filter="gato"]:hover {
    border-color: var(--cat-color);
    color: var(--cat-color);
  }

  .animal-filter-btn.active {
    background: var(--green-800);
    border-color: var(--green-800);
    color: white;
  }

  .animal-filter-btn.active[data-filter="perro"] {
    background: var(--dog-bg);
    border-color: var(--dog-color);
    color: var(--dog-color);
  }

  .animal-filter-btn.active[data-filter="gato"] {
    background: var(--cat-bg);
    border-color: var(--cat-color);
    color: var(--cat-color);
  }

  .animal-filter-count {
    font-size: 0.75rem;
    opacity: 0.8;
  }
</style>
