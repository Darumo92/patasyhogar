---
import IconCategory from './IconCategory.astro';

const currentPath = Astro.url.pathname;

const comparativaLinks = [
  { href: '/alimentacion/', label: 'Alimentación', cat: 'alimentacion' },
  { href: '/higiene/', label: 'Higiene', cat: 'higiene' },
  { href: '/paseo/', label: 'Paseo y Transporte', cat: 'paseo' },
  { href: '/juguetes/', label: 'Juguetes', cat: 'juguetes' },
  { href: '/hogar/', label: 'Hogar y Descanso', cat: 'hogar' },
];

const infoLinks = [
  { href: '/cuidados/', label: 'Cuidados y consejos', cat: 'cuidados' },
  { href: '/articulos/', label: 'Todos los artículos', cat: 'articulos' },
];

const isPerrosActive = currentPath.startsWith('/perros/');
const isGatosActive = currentPath.startsWith('/gatos/');
const isSectionActive = [...comparativaLinks, ...infoLinks].some(l => currentPath.startsWith(l.href));
---

<header class="header">
  <div class="container">
    <div class="header-inner">
      <a href="/" class="logo">
        <svg class="logo-svg" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><circle cx="4" cy="8" r="2"/><circle cx="2" cy="16" r="2"/><path d="M15.8 13.3a1.5 1.5 0 0 0-2.2-.8 6 6 0 0 1-6.2 0 1.5 1.5 0 0 0-2.2.8l-.7 1.4A2 2 0 0 0 6.3 17h11.4a2 2 0 0 0 1.8-2.7Z"/></svg>
        Patas <span>&amp;</span> Hogar
      </a>

      <button class="nav-toggle" id="nav-toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav">
        <span class="hamburger-icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>

      <nav class="nav" id="nav" role="navigation" aria-label="Navegación principal">
        <ul class="nav-list" role="list">
          <li>
            <a
              href="/perros/"
              class={`nav-link ${isPerrosActive ? 'active' : ''}`}
              {...(isPerrosActive ? { 'aria-current': 'page' } : {})}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 2.261"/><path d="M14 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 2.261"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75Z"/><path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444c0-1.061-.162-2.2-.493-3.309m-9.243-6.082A8.801 8.801 0 0 1 12 5c.78 0 1.5.108 2.161.306"/></svg>
              Perros
            </a>
          </li>
          <li>
            <a
              href="/gatos/"
              class={`nav-link ${isGatosActive ? 'active' : ''}`}
              {...(isGatosActive ? { 'aria-current': 'page' } : {})}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5c.67 0 1.35.09 2 .26 1.78-2 5.03-2.84 6.42-2.26 1.4.58-.42 7-.42 7 .57 1.07 1 2.24 1 3.44C21 17.9 16.97 21 12 21s-9-3-9-7.56c0-1.25.5-2.4 1-3.44 0 0-1.89-6.42-.5-7 1.39-.58 4.72.23 6.5 2.23A9.04 9.04 0 0 1 12 5Z"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75Z"/></svg>
              Gatos
            </a>
          </li>

          {/* Dropdown secciones */}
          <li class="nav-dropdown" id="nav-dropdown">
            <button
              class={`nav-link nav-dropdown-trigger ${isSectionActive ? 'active' : ''}`}
              aria-expanded="false"
              aria-haspopup="true"
              id="dropdown-trigger"
            >
              Secciones <span class="nav-dropdown-arrow" aria-hidden="true">▾</span>
            </button>
            <div class="nav-dropdown-menu" id="dropdown-menu" role="menu">
              <p class="nav-dropdown-heading">Comparativas</p>
              {comparativaLinks.map(link => (
                <a
                  href={link.href}
                  class={`nav-dropdown-item ${currentPath.startsWith(link.href) ? 'active' : ''}`}
                  role="menuitem"
                  tabindex="-1"
                >
                  <IconCategory category={link.cat} size={16} />
                  {link.label}
                </a>
              ))}
              <div class="nav-dropdown-divider"></div>
              <p class="nav-dropdown-heading">Información</p>
              {infoLinks.map(link => (
                <a
                  href={link.href}
                  class={`nav-dropdown-item ${currentPath.startsWith(link.href) ? 'active' : ''}`}
                  role="menuitem"
                  tabindex="-1"
                >
                  <IconCategory category={link.cat} size={16} />
                  {link.label}
                </a>
              ))}
            </div>
          </li>

          <li>
            <a
              href="/buscar/"
              class={`nav-link nav-search ${currentPath === '/buscar/' ? 'active' : ''}`}
              aria-label="Buscar artículos"
              title="Buscar"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </a>
          </li>
          <li>
            <button
              class="theme-toggle"
              id="theme-toggle"
              aria-label="Cambiar tema claro/oscuro"
              title="Cambiar tema"
            >
              <svg id="theme-icon-sun" class="theme-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
              <svg id="theme-icon-moon" class="theme-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
            </button>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('nav');
  const dropdownTrigger = document.getElementById('dropdown-trigger');
  const dropdownMenu = document.getElementById('dropdown-menu');

  function closeDropdown() {
    dropdownMenu?.classList.remove('open');
    dropdownTrigger?.setAttribute('aria-expanded', 'false');
    const arrow = dropdownTrigger?.querySelector('.nav-dropdown-arrow') as HTMLElement;
    if (arrow) arrow.style.transform = '';
  }

  function closeNav() {
    nav?.classList.remove('open');
    toggle?.setAttribute('aria-expanded', 'false');
    closeDropdown();
  }

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.contains('open');
    if (isOpen) {
      closeNav();
    } else {
      nav?.classList.add('open');
      toggle.setAttribute('aria-expanded', 'true');
    }
  });

  // Close mobile menu on link click
  nav?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => closeNav());
  });

  // Dropdown toggle (mobile + click fallback)
  dropdownTrigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = dropdownMenu?.classList.contains('open');
    dropdownMenu?.classList.toggle('open');
    dropdownTrigger.setAttribute('aria-expanded', String(!isOpen));
    const arrow = dropdownTrigger.querySelector('.nav-dropdown-arrow');
    if (arrow) (arrow as HTMLElement).style.transform = isOpen ? '' : 'rotate(180deg)';
  });

  // Close dropdown on outside click
  document.addEventListener('click', (e) => {
    if (!(e.target as Element)?.closest('.nav-dropdown')) {
      closeDropdown();
    }
  });

  // Keyboard navigation for dropdown (Arrow keys, Escape, Home, End)
  document.addEventListener('keydown', (e) => {
    const isOpen = dropdownMenu?.classList.contains('open');
    if (!isOpen && e.key !== 'Escape') return;

    const items = Array.from(dropdownMenu?.querySelectorAll('[role="menuitem"]') || []) as HTMLElement[];
    if (!items.length) return;

    const active = document.activeElement as HTMLElement;
    const idx = items.indexOf(active);

    if (e.key === 'Escape') {
      closeDropdown();
      dropdownTrigger?.focus();
      e.preventDefault();
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      const next = idx < items.length - 1 ? idx + 1 : 0;
      items[next].focus();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      const prev = idx > 0 ? idx - 1 : items.length - 1;
      items[prev].focus();
    } else if (e.key === 'Home') {
      e.preventDefault();
      items[0].focus();
    } else if (e.key === 'End') {
      e.preventDefault();
      items[items.length - 1].focus();
    }
  });

  // Focus first item when dropdown opens via keyboard
  dropdownTrigger?.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown' || e.key === 'Enter' || e.key === ' ') {
      const isOpen = dropdownMenu?.classList.contains('open');
      if (!isOpen) {
        dropdownMenu?.classList.add('open');
        dropdownTrigger.setAttribute('aria-expanded', 'true');
        const arrow = dropdownTrigger.querySelector('.nav-dropdown-arrow');
        if (arrow) (arrow as HTMLElement).style.transform = 'rotate(180deg)';
      }
      const firstItem = dropdownMenu?.querySelector('[role="menuitem"]') as HTMLElement;
      firstItem?.focus();
      e.preventDefault();
    }
  });

  // Dark mode
  const themeBtn = document.getElementById('theme-toggle');
  themeBtn?.addEventListener('click', () => {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const metaTheme = document.getElementById('meta-theme-color');
    document.documentElement.classList.add('theme-transitioning');
    if (isDark) {
      document.documentElement.removeAttribute('data-theme');
      localStorage.setItem('theme', 'light');
      if (metaTheme) metaTheme.setAttribute('content', '#2d6a4f');
    } else {
      document.documentElement.setAttribute('data-theme', 'dark');
      localStorage.setItem('theme', 'dark');
      if (metaTheme) metaTheme.setAttribute('content', '#121220');
    }
    setTimeout(() => document.documentElement.classList.remove('theme-transitioning'), 300);
  });
</script>
