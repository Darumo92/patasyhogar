---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/alimentacion', label: 'Alimentación' },
  { href: '/higiene', label: 'Higiene' },
  { href: '/descanso', label: 'Descanso' },
  { href: '/comportamiento', label: 'Enriquecimiento' },
];
---

<header class="header">
  <div class="container">
    <div class="header-inner">
      <a href="/" class="logo">
        <span class="logo-icon">🐾</span>
        Patas y <span>Hogar</span>
      </a>

      <button class="nav-toggle" id="nav-toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav">
        ☰
      </button>

      <nav class="nav" id="nav" role="navigation" aria-label="Navegación principal">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`nav-link ${currentPath.startsWith(link.href) ? 'active' : ''}`}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/buscar"
          class={`nav-link nav-search ${currentPath === '/buscar' ? 'active' : ''}`}
          aria-label="Buscar artículos"
          title="Buscar"
        >
          🔍
        </a>
      </nav>
    </div>
  </div>
</header>

<style>
  .nav-search {
    font-size: 1.1rem;
    padding: 0.25rem 0.5rem;
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('nav');
  toggle?.addEventListener('click', () => {
    nav?.classList.toggle('open');
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
  });
</script>
