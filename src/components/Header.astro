---
import LogoIcon from './LogoIcon.astro';
import CategoryIcon from './CategoryIcon.astro';

const currentPath = Astro.url.pathname;

const comparativaLinks = [
  { href: '/alimentacion/', label: 'Alimentación', cat: 'alimentacion' },
  { href: '/higiene/', label: 'Higiene', cat: 'higiene' },
  { href: '/paseo/', label: 'Paseo y Transporte', cat: 'paseo' },
  { href: '/juguetes/', label: 'Juguetes', cat: 'juguetes' },
  { href: '/hogar/', label: 'Hogar y Descanso', cat: 'hogar' },
];

const infoLinks = [
  { href: '/cuidados/', label: 'Cuidados y consejos', cat: 'cuidados' },
  { href: '/articulos/', label: 'Todos los artículos', cat: '' },
];

const isPerrosActive = currentPath.startsWith('/perros/');
const isGatosActive = currentPath.startsWith('/gatos/');
const isSectionActive = [...comparativaLinks, ...infoLinks].some(l => currentPath.startsWith(l.href));
---

<header class="header">
  <div class="container">
    <div class="header-inner">
      <a href="/" class="logo">
        <LogoIcon size={28} />
        Patas y <span>Hogar</span>
      </a>

      <button class="nav-toggle" id="nav-toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav">
        ☰
      </button>

      <nav class="nav" id="nav" role="navigation" aria-label="Navegación principal">
        <a
          href="/perros/"
          class={`nav-link ${isPerrosActive ? 'active' : ''}`}
          {...(isPerrosActive ? { 'aria-current': 'page' } : {})}
        >
          🐶 Perros
        </a>
        <a
          href="/gatos/"
          class={`nav-link ${isGatosActive ? 'active' : ''}`}
          {...(isGatosActive ? { 'aria-current': 'page' } : {})}
        >
          🐱 Gatos
        </a>

        {/* Dropdown secciones */}
        <div class="nav-dropdown" id="nav-dropdown">
          <button
            class={`nav-link nav-dropdown-trigger ${isSectionActive ? 'active' : ''}`}
            aria-expanded="false"
            aria-haspopup="true"
            id="dropdown-trigger"
          >
            Secciones <span class="nav-dropdown-arrow" aria-hidden="true">▾</span>
          </button>
          <div class="nav-dropdown-menu" id="dropdown-menu" role="menu">
            <p class="nav-dropdown-heading">Comparativas</p>
            {comparativaLinks.map(link => (
              <a
                href={link.href}
                class={`nav-dropdown-item ${currentPath.startsWith(link.href) ? 'active' : ''}`}
                role="menuitem"
              >
                <CategoryIcon categoria={link.cat} size={18} />
                {link.label}
              </a>
            ))}
            <div class="nav-dropdown-divider"></div>
            <p class="nav-dropdown-heading">Información</p>
            {infoLinks.map(link => (
              <a
                href={link.href}
                class={`nav-dropdown-item ${currentPath.startsWith(link.href) ? 'active' : ''}`}
                role="menuitem"
              >
                {link.cat ? <CategoryIcon categoria={link.cat} size={18} /> : <span aria-hidden="true">📚</span>}
                {link.label}
              </a>
            ))}
          </div>
        </div>

        <a
          href="/buscar/"
          class={`nav-link nav-search ${currentPath === '/buscar/' ? 'active' : ''}`}
          aria-label="Buscar artículos"
          title="Buscar"
        >
          🔍
        </a>
        <button
          class="theme-toggle"
          id="theme-toggle"
          aria-label="Cambiar tema claro/oscuro"
          title="Cambiar tema"
        >
          <span id="theme-icon">🌙</span>
        </button>
      </nav>
    </div>
  </div>
</header>

<style>
  .nav-search {
    font-size: 1.1rem;
    padding: 0.25rem 0.5rem;
  }

  /* Dropdown */
  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-trigger {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }

  .nav-dropdown-arrow {
    font-size: 0.65rem;
    transition: transform 0.2s;
  }

  .nav-dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    min-width: 230px;
    padding: 0.5rem;
    z-index: 110;
  }

  .nav-dropdown-menu::before {
    content: '';
    position: absolute;
    top: -6px;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 12px;
    height: 12px;
    background: var(--color-bg-card);
    border-left: 1px solid var(--color-border);
    border-top: 1px solid var(--color-border);
  }

  /* Hover on desktop */
  .nav-dropdown:hover .nav-dropdown-menu,
  .nav-dropdown-menu.open {
    display: block;
  }

  .nav-dropdown:hover .nav-dropdown-arrow {
    transform: rotate(180deg);
  }

  .nav-dropdown-heading {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-light);
    padding: 0.5rem 0.85rem 0.25rem;
  }

  .nav-dropdown-divider {
    height: 1px;
    background: var(--color-border);
    margin: 0.4rem 0.5rem;
  }

  .nav-dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.85rem;
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    transition: all var(--transition);
  }

  .nav-dropdown-item:hover {
    background: var(--color-bg-muted);
    color: var(--color-primary);
  }

  .nav-dropdown-item.active {
    color: var(--color-primary);
    font-weight: 600;
    background: rgba(194, 65, 12, 0.06);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .nav-dropdown {
      width: 100%;
    }

    .nav-dropdown-trigger {
      width: 100%;
      padding: 0.75rem 1rem;
      justify-content: space-between;
    }

    .nav-dropdown-menu {
      position: static;
      transform: none;
      box-shadow: none;
      border: none;
      border-radius: 0;
      padding: 0 0 0 0.5rem;
      min-width: auto;
      background: transparent;
    }

    .nav-dropdown-menu::before {
      display: none;
    }

    .nav-dropdown:hover .nav-dropdown-menu {
      display: none;
    }

    .nav-dropdown .nav-dropdown-menu.open {
      display: block;
    }

    .nav-dropdown-item {
      padding: 0.6rem 1rem;
      font-size: 0.85rem;
    }

    .nav-dropdown-heading {
      padding: 0.5rem 1rem 0.25rem;
    }

    .nav-dropdown-divider {
      margin: 0.4rem 1rem;
    }

    .nav-search {
      justify-content: flex-start;
      padding: 0.75rem 1rem;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('nav');
  const dropdownTrigger = document.getElementById('dropdown-trigger');
  const dropdownMenu = document.getElementById('dropdown-menu');

  function closeDropdown() {
    dropdownMenu?.classList.remove('open');
    dropdownTrigger?.setAttribute('aria-expanded', 'false');
    const arrow = dropdownTrigger?.querySelector('.nav-dropdown-arrow') as HTMLElement;
    if (arrow) arrow.style.transform = '';
  }

  function closeNav() {
    nav?.classList.remove('open');
    toggle?.setAttribute('aria-expanded', 'false');
    closeDropdown();
  }

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.contains('open');
    if (isOpen) {
      closeNav();
    } else {
      nav?.classList.add('open');
      toggle.setAttribute('aria-expanded', 'true');
    }
  });

  // Close mobile menu on link click
  nav?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => closeNav());
  });

  // Dropdown toggle (mobile + click fallback)
  dropdownTrigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = dropdownMenu?.classList.contains('open');
    dropdownMenu?.classList.toggle('open');
    dropdownTrigger.setAttribute('aria-expanded', String(!isOpen));
    const arrow = dropdownTrigger.querySelector('.nav-dropdown-arrow');
    if (arrow) (arrow as HTMLElement).style.transform = isOpen ? '' : 'rotate(180deg)';
  });

  // Close dropdown on outside click
  document.addEventListener('click', (e) => {
    if (!(e.target as Element)?.closest('.nav-dropdown')) {
      closeDropdown();
    }
  });

  // Dark mode
  const themeBtn = document.getElementById('theme-toggle');
  const themeIcon = document.getElementById('theme-icon');
  function updateIcon() {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    if (themeIcon) themeIcon.textContent = isDark ? '☀️' : '🌙';
  }
  updateIcon();
  themeBtn?.addEventListener('click', () => {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const metaTheme = document.getElementById('meta-theme-color');
    if (isDark) {
      document.documentElement.removeAttribute('data-theme');
      localStorage.setItem('theme', 'light');
      if (metaTheme) metaTheme.setAttribute('content', '#c2410c');
    } else {
      document.documentElement.setAttribute('data-theme', 'dark');
      localStorage.setItem('theme', 'dark');
      if (metaTheme) metaTheme.setAttribute('content', '#0c0a09');
    }
    updateIcon();
  });
</script>
