---
// Quiz data loaded on-demand from /quiz-data.json to keep homepage HTML small
import IconCategory from './IconCategory.astro';
---

<div class="quiz" id="pet-quiz">
  <div class="quiz-step quiz-step--active" data-step="1">
    <p class="quiz-question">¿Para quién buscas?</p>
    <div class="quiz-options">
      <button class="quiz-option" data-value="perro" data-field="animal">
        <span class="quiz-option-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5h2"/><path d="M19 12c-.667 5.333-2.333 8-5 8h-4c-2.667 0-4.333-2.667-5-8"/><path d="M11 16c0 .667.333 1 1 1s1-.333 1-1h-2"/><path d="M12 18v2"/><path d="M10 11v.01"/><path d="M14 11v.01"/><path d="M5 4l6 .97-6.238 6.688a1.021 1.021 0 0 1-1.41.111.953.953 0 0 1-.327-.954l1.975-6.815"/><path d="M19 4l-6 .97 6.238 6.688c.358.408.989.458 1.41.111a.953.953 0 0 0 .327-.954l-1.975-6.815"/></svg></span>
        <span>Perro</span>
      </button>
      <button class="quiz-option" data-value="gato" data-field="animal">
        <span class="quiz-option-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 3v10a8 8 0 1 1-16 0v-10l3.432 3.432a7.963 7.963 0 0 1 4.568-1.432c1.769 0 3.403.574 4.728 1.546l3.272-3.546"/><path d="M2 16h5l-4 4"/><path d="M22 16h-5l4 4"/><path d="M11 16a1 1 0 1 0 2 0 1 1 0 1 0-2 0"/><path d="M9 11v.01"/><path d="M15 11v.01"/></svg></span>
        <span>Gato</span>
      </button>
    </div>
  </div>

  <div class="quiz-step" data-step="2">
    <p class="quiz-question">¿Qué tipo de producto te interesa?</p>
    <div class="quiz-options quiz-options--grid">
      <button class="quiz-option" data-value="alimentacion" data-field="categoria">
        <span class="quiz-option-icon"><IconCategory category="alimentacion" size={28} /></span>
        <span>Alimentación</span>
      </button>
      <button class="quiz-option" data-value="higiene" data-field="categoria">
        <span class="quiz-option-icon"><IconCategory category="higiene" size={28} /></span>
        <span>Higiene</span>
      </button>
      <button class="quiz-option" data-value="paseo" data-field="categoria">
        <span class="quiz-option-icon"><IconCategory category="paseo" size={28} /></span>
        <span>Paseo</span>
      </button>
      <button class="quiz-option" data-value="juguetes" data-field="categoria">
        <span class="quiz-option-icon"><IconCategory category="juguetes" size={28} /></span>
        <span>Juguetes</span>
      </button>
      <button class="quiz-option" data-value="hogar" data-field="categoria">
        <span class="quiz-option-icon"><IconCategory category="hogar" size={28} /></span>
        <span>Hogar</span>
      </button>
      <button class="quiz-option" data-value="cuidados" data-field="categoria">
        <span class="quiz-option-icon"><IconCategory category="cuidados" size={28} /></span>
        <span>Salud y cuidados</span>
      </button>
    </div>
  </div>

  <div class="quiz-step" data-step="3">
    <p class="quiz-question">Estas guías son para ti:</p>
    <div class="quiz-results" id="quiz-results"></div>
    <button class="quiz-restart" id="quiz-restart">← Volver a empezar</button>
  </div>

  <div class="quiz-progress">
    <div class="quiz-progress-dot quiz-progress-dot--active" data-dot="1"></div>
    <div class="quiz-progress-dot" data-dot="2"></div>
    <div class="quiz-progress-dot" data-dot="3"></div>
  </div>
</div>

<script is:inline>
(function() {
  var quiz = document.getElementById('pet-quiz');
  if (!quiz) return;

  var quizData = null;
  var dataPromise = null;
  var answers = {};
  var steps = quiz.querySelectorAll('.quiz-step');
  var dots = quiz.querySelectorAll('.quiz-progress-dot');
  var resultsEl = document.getElementById('quiz-results');
  var restartBtn = document.getElementById('quiz-restart');

  function loadData() {
    if (!dataPromise) {
      dataPromise = fetch('/quiz-data.json').then(function(r) { return r.json(); }).then(function(d) {
        quizData = d;
      });
    }
    return dataPromise;
  }

  function goToStep(n) {
    steps.forEach(function(s) { s.classList.remove('quiz-step--active'); });
    dots.forEach(function(d) { d.classList.remove('quiz-progress-dot--active'); });
    var step = quiz.querySelector('[data-step="' + n + '"]');
    if (step) step.classList.add('quiz-step--active');
    for (var i = 1; i <= n; i++) {
      var dot = quiz.querySelector('[data-dot="' + i + '"]');
      if (dot) dot.classList.add('quiz-progress-dot--active');
    }
  }

  function showResults() {
    if (!resultsEl || !quizData) return;
    var animal = answers.animal;
    var cat = answers.categoria;

    var results = quizData.filter(function(r) {
      return (r.a === animal || r.a === 'ambos') &&
        (cat === 'cuidados' ? r.p === 'informativo' : r.c === cat);
    });

    if (results.length === 0) {
      results = quizData.filter(function(r) { return r.a === animal || r.a === 'ambos'; }).slice(0, 5);
    }

    results = results.slice(0, 5);

    resultsEl.innerHTML = results.map(function(r) {
      return '<a href="' + r.u + '" class="quiz-result-card">' +
        (r.i ? '<img src="' + r.i + '" alt="" width="80" height="45" loading="lazy" />' : '') +
        '<div><strong>' + r.t + '</strong>' +
        '<span>' + r.d + '</span></div></a>';
    }).join('');

    goToStep(3);
  }

  quiz.querySelectorAll('.quiz-option').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var field = btn.dataset.field;
      var value = btn.dataset.value;
      answers[field] = value;

      btn.closest('.quiz-options').querySelectorAll('.quiz-option').forEach(function(b) { b.classList.remove('quiz-option--selected'); });
      btn.classList.add('quiz-option--selected');

      // Start loading data on first interaction
      loadData();

      setTimeout(function() {
        if (field === 'animal') goToStep(2);
        else if (field === 'categoria') {
          loadData().then(showResults);
        }
      }, 200);
    });
  });

  restartBtn && restartBtn.addEventListener('click', function() {
    Object.keys(answers).forEach(function(k) { delete answers[k]; });
    quiz.querySelectorAll('.quiz-option--selected').forEach(function(b) { b.classList.remove('quiz-option--selected'); });
    goToStep(1);
  });
})();
</script>

<style>
.quiz {
  background: var(--color-bg-card);
  border: 2px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 2rem 1.5rem;
  text-align: center;
  position: relative;
}

.quiz-step {
  display: none;
}

.quiz-step--active {
  display: block;
  animation: quizFadeIn 0.3s ease;
}

@keyframes quizFadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

@media (prefers-reduced-motion: reduce) {
  .quiz-step--active {
    animation: none;
  }
}

.quiz-question {
  font-family: var(--font-display);
  font-size: 1.3rem;
  font-weight: 800;
  color: var(--color-text);
  margin-bottom: 1.25rem;
}

.quiz-options {
  display: flex;
  justify-content: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.quiz-options--grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.625rem;
  max-width: 420px;
  margin: 0 auto;
}

.quiz-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
  padding: 1rem 1.5rem;
  background: var(--color-bg-muted);
  border: 2px solid var(--color-border);
  border-radius: var(--radius-md);
  cursor: pointer;
  font-family: var(--font-sans);
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--color-text);
  transition: all 0.2s ease;
}

.quiz-option:hover {
  border-color: var(--color-primary);
  background: color-mix(in srgb, var(--color-primary) 5%, var(--color-bg-muted));
}

.quiz-option--selected {
  border-color: var(--color-primary);
  background: color-mix(in srgb, var(--color-primary) 8%, var(--color-bg));
  color: var(--color-primary);
}

.quiz-option-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

.quiz-results {
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
  margin: 1rem 0;
  text-align: left;
}

.quiz-result-card {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem;
  background: var(--color-bg-muted);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  text-decoration: none;
  color: var(--color-text);
  transition: all 0.2s ease;
}

.quiz-result-card:hover {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-sm);
  color: var(--color-text);
}

.quiz-result-card img {
  width: 80px;
  height: 45px;
  object-fit: cover;
  border-radius: 6px;
  flex-shrink: 0;
}

.quiz-result-card strong {
  display: block;
  font-size: 0.88rem;
  font-weight: 700;
  margin-bottom: 0.15rem;
}

.quiz-result-card span {
  font-size: 0.78rem;
  color: var(--color-text-muted);
}

.quiz-restart {
  margin-top: 1rem;
  background: none;
  border: 1.5px solid var(--color-border);
  border-radius: 100px;
  padding: 0.5rem 1.25rem;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--color-text-muted);
  cursor: pointer;
  font-family: var(--font-sans);
  transition: all 0.2s;
}

.quiz-restart:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.quiz-progress {
  display: flex;
  justify-content: center;
  gap: 0.5rem;
  margin-top: 1.25rem;
}

.quiz-progress-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--color-border);
  transition: background 0.3s;
}

.quiz-progress-dot--active {
  background: var(--color-primary);
}

@media (max-width: 480px) {
  .quiz-options--grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .quiz-option {
    padding: 0.75rem 1rem;
    font-size: 0.82rem;
  }

  .quiz-option-icon svg {
    width: 24px;
    height: 24px;
  }
}
</style>
