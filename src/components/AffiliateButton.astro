---
import StoreIcon from './StoreIcon.astro';

interface Props {
  href: string;
  tienda?: 'amazon' | 'zooplus' | 'tiendanimal' | 'default';
  texto?: string;
}

const { href, tienda = 'default', texto } = Astro.props;

const WEBGAINS_CAMPAIGN = '1746742';
const WEBGAINS_PROGRAM = '9507';

const tiendaInfo: Record<string, { label: string }> = {
  amazon: { label: 'Ver en Amazon' },
  zooplus: { label: 'Ver en Zooplus' },
  tiendanimal: { label: 'Ver en Tiendanimal' },
  default: { label: 'Ver oferta' },
};

const info = tiendaInfo[tienda];
const label = texto || info.label;

function buildHref(url: string, store: string): string {
  if (store === 'amazon' && !url.includes('tag=')) {
    return `${url}${url.includes('?') ? '&' : '?'}tag=patasyhogar-21`;
  }
  if (store === 'tiendanimal' || url.includes('tiendanimal.com')) {
    return `https://assets.ikhnaie.me/click.html?wgcampaignid=${WEBGAINS_CAMPAIGN}&wgprogramid=${WEBGAINS_PROGRAM}&wgtarget=${encodeURIComponent(url)}`;
  }
  return url;
}

const finalHref = buildHref(href, tienda);
---

<a
  href={finalHref}
  class={`affiliate-button ${tienda !== 'default' ? tienda : ''}`}
  target="_blank"
  rel="nofollow noopener noreferrer sponsored"
>
  <StoreIcon tienda={tienda} size={15} />
  {label}
</a>
