---
import StoreIcon from './StoreIcon.astro';

const AMAZON_TAG = 'patasyhogar-21';
const WEBGAINS_CAMPAIGN = '1746742';
const WEBGAINS_PROGRAM = '9507';

function tiendanimalHref(url: string): string {
  return `https://assets.ikhnaie.me/click.html?wgcampaignid=${WEBGAINS_CAMPAIGN}&wgprogramid=${WEBGAINS_PROGRAM}&wgtarget=${encodeURIComponent(url)}`;
}

interface Props {
  nombre: string;
  descripcion: string;
  precio: string;
  precioAmazon?: string;
  precioZooplus?: string;
  precioTiendanimal?: string;
  enlaceAmazon?: string;
  enlaceZooplus?: string;
  enlaceTiendanimal?: string;
  imagen?: string;
  etiqueta?: string;
}

const {
  nombre,
  descripcion,
  precio,
  precioAmazon,
  precioZooplus,
  precioTiendanimal,
  enlaceAmazon,
  enlaceZooplus,
  enlaceTiendanimal,
  imagen,
  etiqueta = 'Nuestra elección',
} = Astro.props;

const amazonFinal = enlaceAmazon && !enlaceAmazon.includes('tag=')
  ? `${enlaceAmazon}${enlaceAmazon.includes('?') ? '&' : '?'}tag=${AMAZON_TAG}`
  : enlaceAmazon;

/** Resize Amazon product images to save bandwidth (160px display × 2x retina = 320px) */
const optimizeImg = (url?: string) =>
  url?.replace(/\._AC_SL\d+_/, '._AC_SL320_') ?? url;

const imagenOpt = optimizeImg(imagen);

const tiendas: { nombre: string; clase: string; precio: string; href: string; mejor: boolean }[] = [];
if (amazonFinal) tiendas.push({ nombre: 'Amazon', clase: 'amazon', precio: precioAmazon || precio, href: amazonFinal, mejor: false });
if (enlaceZooplus) tiendas.push({ nombre: 'Zooplus', clase: 'zooplus', precio: precioZooplus || precio, href: enlaceZooplus, mejor: false });
if (enlaceTiendanimal) tiendas.push({ nombre: 'Tiendanimal', clase: 'tiendanimal', precio: precioTiendanimal || precio, href: tiendanimalHref(enlaceTiendanimal), mejor: false });

if (tiendas.length > 1) {
  const withNum = tiendas.map(s => ({ ...s, num: parseFloat((s.precio.match(/(\d+[.,]?\d*)/) || ['0','0'])[1].replace(',', '.')) }));
  const min = Math.min(...withNum.map(s => s.num));
  const cheapest = withNum.filter(s => s.num === min);
  if (cheapest.length === 1 && new Set(withNum.map(s => s.num)).size > 1) {
    const idx = tiendas.findIndex(s => s.nombre === cheapest[0].nombre);
    if (idx >= 0) tiendas[idx].mejor = true;
  }
}
---

<div class="top-pick">
  <div class="top-pick-badge">🏆 {etiqueta}</div>
  <div class="top-pick-body">
    {imagen && (
      <div class="top-pick-img-wrap">
        <img src={imagenOpt} alt={nombre} width="160" height="160" class="top-pick-img" loading="lazy" decoding="async" sizes="(max-width: 540px) 160px, 140px" />
      </div>
    )}
    <div class="top-pick-info">
      <p class="top-pick-nombre">{nombre}</p>
      <p class="top-pick-desc">{descripcion}</p>
      <p class="top-pick-precio">{precio}</p>
      {tiendas.length > 1 ? (
        <div class="tp-price-table">
          {tiendas.map(s => (
            <a
              href={s.href}
              class={`tp-price-row ${s.mejor ? 'tp-price-row--best' : ''}`}
              target="_blank"
              rel="nofollow noopener noreferrer sponsored"
            >
              <span class="tp-price-store">
                <StoreIcon tienda={s.clase as any} size={14} />
                {s.nombre}
              </span>
              <span class="tp-price-amount">{s.precio}</span>
              {s.mejor && <span class="tp-price-best-tag">Mejor precio</span>}
              <span class="tp-price-go">Ver →</span>
            </a>
          ))}
        </div>
      ) : (
        <div class="top-pick-stores">
          {tiendas.map(s => (
            <a
              href={s.href}
              class={`affiliate-button ${s.clase}`}
              target="_blank"
              rel="nofollow noopener noreferrer sponsored"
            >
              <StoreIcon tienda={s.clase as any} size={15} />
              {s.nombre} — {s.precio}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</div>

<style>
.top-pick {
  border: 2px solid var(--color-primary);
  border-radius: var(--radius-lg);
  padding: 1.75rem 1.5rem 1.5rem;
  margin: 1.5rem 0;
  background: color-mix(in srgb, var(--color-primary) 4%, var(--color-bg));
  position: relative;
  box-shadow: 0 4px 24px color-mix(in srgb, var(--color-primary) 10%, transparent);
}

.top-pick-badge {
  position: absolute;
  top: -0.8rem;
  left: 1.25rem;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: white;
  font-size: 0.72rem;
  font-weight: 700;
  padding: 0.3rem 0.9rem;
  border-radius: 100px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  box-shadow: 0 2px 8px color-mix(in srgb, var(--color-primary) 30%, transparent);
}

.top-pick-body {
  display: flex;
  gap: 1.5rem;
  align-items: flex-start;
  margin-top: 0.25rem;
}

.top-pick-img-wrap {
  flex-shrink: 0;
  background: var(--color-bg-muted);
  border-radius: var(--radius-md);
  padding: 0.75rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.top-pick-img {
  width: 140px;
  height: 140px;
  object-fit: contain;
}

.top-pick-info {
  flex: 1;
  min-width: 0;
}

.top-pick-nombre {
  font-size: 1.2rem;
  font-weight: 800;
  margin: 0 0 0.4rem;
  color: var(--color-text);
  letter-spacing: -0.02em;
}

.top-pick-desc {
  font-size: 0.9rem;
  color: var(--color-text-muted);
  margin: 0 0 0.6rem;
  line-height: 1.5;
}

.top-pick-precio {
  font-size: 1.6rem;
  font-weight: 800;
  margin: 0 0 1rem;
  color: var(--color-primary);
  letter-spacing: -0.02em;
}

/* --- Price comparison table (multi-store) --- */
.tp-price-table {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}

.tp-price-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.6rem 0.875rem;
  border-radius: var(--radius-sm);
  background: var(--color-bg-muted);
  border-left: 3px solid var(--store-color, var(--color-border));
  text-decoration: none;
  color: var(--color-text);
  transition: all 0.2s ease;
  font-size: 0.88rem;
}

.tp-price-row:hover {
  background: var(--color-border);
  color: var(--color-text);
  transform: translateX(2px);
}

.tp-price-row[href*="amazon"] { --store-color: #ff9900; }
.tp-price-row[href*="zooplus"] { --store-color: #398927; }
.tp-price-row[href*="tiendanimal"] { --store-color: #00632E; }
.tp-price-row[href*="ikhnaie.me"] { --store-color: #00632E; }

.tp-price-row--best {
  background: color-mix(in srgb, var(--store-color) 10%, var(--color-bg-muted));
  border: 1px solid color-mix(in srgb, var(--store-color) 25%, transparent);
  border-left: 3px solid var(--store-color);
}

.tp-price-row--best:hover {
  background: color-mix(in srgb, var(--store-color) 15%, var(--color-bg-muted));
}

.tp-price-store {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-weight: 600;
  min-width: 110px;
}

.tp-price-amount {
  font-weight: 800;
  font-size: 1rem;
  color: var(--color-text);
}

.tp-price-best-tag {
  font-size: 0.6rem;
  font-weight: 700;
  background: var(--store-color);
  color: #fff;
  padding: 0.15rem 0.5rem;
  border-radius: 100px;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  white-space: nowrap;
}

.tp-price-go {
  margin-left: auto;
  font-weight: 600;
  font-size: 0.8rem;
  color: var(--color-primary);
  white-space: nowrap;
}

/* --- Single store button --- */
.top-pick-stores {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.top-pick-stores .affiliate-button {
  font-size: 0.88rem;
  padding: 0.65rem 1.2rem;
  font-weight: 700;
}

@media (max-width: 540px) {
  .top-pick-body {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .top-pick-img {
    width: 160px;
    height: 160px;
  }

  .top-pick-desc {
    text-align: left;
  }

  .top-pick-stores {
    flex-direction: column;
  }

  .top-pick-stores .affiliate-button {
    justify-content: center;
    width: 100%;
    font-size: 0.88rem;
    padding: 0.7rem 1.1rem;
  }

  .tp-price-store {
    min-width: auto;
  }

  .tp-price-row {
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tp-price-go {
    margin-left: 0;
    width: 100%;
    text-align: center;
    padding-top: 0.25rem;
    border-top: 1px solid var(--color-border);
    margin-top: 0.25rem;
  }
}
</style>
