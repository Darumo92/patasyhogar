---
import StoreIcon from './StoreIcon.astro';

const AMAZON_TAG = 'patasyhogar-21';

interface Props {
  nombre: string;
  descripcion: string;
  precio: string;
  precioAmazon?: string;
  precioZooplus?: string;
  precioTiendanimal?: string;
  enlaceAmazon?: string;
  enlaceZooplus?: string;
  enlaceTiendanimal?: string;
  imagen?: string;
  etiqueta?: string;
}

const {
  nombre,
  descripcion,
  precio,
  precioAmazon,
  precioZooplus,
  precioTiendanimal,
  enlaceAmazon,
  enlaceZooplus,
  enlaceTiendanimal,
  imagen,
  etiqueta = 'Nuestra elección',
} = Astro.props;

const amazonFinal = enlaceAmazon && !enlaceAmazon.includes('tag=')
  ? `${enlaceAmazon}${enlaceAmazon.includes('?') ? '&' : '?'}tag=${AMAZON_TAG}`
  : enlaceAmazon;

const tiendas: { nombre: string; clase: string; precio: string; href: string; mejor: boolean }[] = [];
if (amazonFinal) tiendas.push({ nombre: 'Amazon', clase: 'amazon', precio: precioAmazon || precio, href: amazonFinal, mejor: false });
if (enlaceZooplus) tiendas.push({ nombre: 'Zooplus', clase: 'zooplus', precio: precioZooplus || precio, href: enlaceZooplus, mejor: false });
if (enlaceTiendanimal) tiendas.push({ nombre: 'Tiendanimal', clase: 'tiendanimal', precio: precioTiendanimal || precio, href: enlaceTiendanimal, mejor: false });

if (tiendas.length > 1) {
  const withNum = tiendas.map(s => ({ ...s, num: parseFloat((s.precio.match(/(\d+[.,]?\d*)/) || ['0','0'])[1].replace(',', '.')) }));
  const min = Math.min(...withNum.map(s => s.num));
  const cheapest = withNum.filter(s => s.num === min);
  if (cheapest.length === 1 && new Set(withNum.map(s => s.num)).size > 1) {
    const idx = tiendas.findIndex(s => s.nombre === cheapest[0].nombre);
    if (idx >= 0) tiendas[idx].mejor = true;
  }
}
---

<div class="top-pick">
  <div class="top-pick-badge">🏆 {etiqueta}</div>
  <div class="top-pick-body">
    {imagen && (
      <div class="top-pick-img-wrap">
        <img src={imagen} alt={nombre} width="160" height="160" class="top-pick-img" loading="lazy" decoding="async" sizes="(max-width: 540px) 160px, 140px" />
      </div>
    )}
    <div class="top-pick-info">
      <p class="top-pick-nombre">{nombre}</p>
      <p class="top-pick-desc">{descripcion}</p>
      <p class="top-pick-precio">{precio}</p>
      <div class="top-pick-stores">
        {tiendas.map(s => (
          <a
            href={s.href}
            class={`affiliate-button ${s.clase} ${s.mejor ? 'tp-best-btn' : ''}`}
            target="_blank"
            rel="nofollow noopener noreferrer sponsored"
          >
            <StoreIcon tienda={s.clase as any} size={15} />
            {s.nombre} — {s.precio}
            {s.mejor && <span class="tp-best">Mejor precio</span>}
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
.top-pick {
  border: 2px solid var(--color-primary);
  border-radius: var(--radius-lg);
  padding: 1.75rem 1.5rem 1.5rem;
  margin: 1.5rem 0;
  background: color-mix(in srgb, var(--color-primary) 4%, var(--color-bg));
  position: relative;
  box-shadow: 0 4px 24px color-mix(in srgb, var(--color-primary) 10%, transparent);
}

.top-pick-badge {
  position: absolute;
  top: -0.8rem;
  left: 1.25rem;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: white;
  font-size: 0.72rem;
  font-weight: 700;
  padding: 0.3rem 0.9rem;
  border-radius: 100px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  box-shadow: 0 2px 8px color-mix(in srgb, var(--color-primary) 30%, transparent);
}

.top-pick-body {
  display: flex;
  gap: 1.5rem;
  align-items: flex-start;
  margin-top: 0.25rem;
}

.top-pick-img-wrap {
  flex-shrink: 0;
  background: var(--color-bg-muted);
  border-radius: var(--radius-md);
  padding: 0.75rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.top-pick-img {
  width: 140px;
  height: 140px;
  object-fit: contain;
}

.top-pick-info {
  flex: 1;
  min-width: 0;
}

.top-pick-nombre {
  font-size: 1.2rem;
  font-weight: 800;
  margin: 0 0 0.4rem;
  color: var(--color-text);
  letter-spacing: -0.02em;
}

.top-pick-desc {
  font-size: 0.9rem;
  color: var(--color-text-muted);
  margin: 0 0 0.6rem;
  line-height: 1.5;
}

.top-pick-precio {
  font-size: 1.6rem;
  font-weight: 800;
  margin: 0 0 1rem;
  color: var(--color-primary);
  letter-spacing: -0.02em;
}

.top-pick-stores {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.top-pick-stores .affiliate-button {
  font-size: 0.88rem;
  padding: 0.65rem 1.2rem;
  font-weight: 700;
}

.tp-best-btn {
  position: relative;
  box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.3), 0 4px 12px rgba(0, 0, 0, 0.15);
}

.tp-best {
  font-size: 0.6rem;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.3);
  padding: 0.15rem 0.45rem;
  border-radius: 100px;
  text-transform: uppercase;
  letter-spacing: 0.03em;
}

@media (max-width: 540px) {
  .top-pick-body {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .top-pick-img {
    width: 160px;
    height: 160px;
  }

  .top-pick-desc {
    text-align: left;
  }

  .top-pick-stores {
    flex-direction: column;
  }

  .top-pick-stores .affiliate-button {
    justify-content: center;
    width: 100%;
    font-size: 0.88rem;
    padding: 0.7rem 1.1rem;
  }
}
</style>
