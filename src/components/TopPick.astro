---
const AMAZON_TAG = 'patasyhogar-21';

interface Props {
  nombre: string;
  descripcion: string;
  precio: string;
  enlaceAmazon?: string;
  enlaceZooplus?: string;
  imagen?: string;
  etiqueta?: string;
}

const {
  nombre,
  descripcion,
  precio,
  enlaceAmazon,
  enlaceZooplus,
  imagen,
  etiqueta = 'Nuestra elección',
} = Astro.props;

const amazonFinal = enlaceAmazon && !enlaceAmazon.includes('tag=')
  ? `${enlaceAmazon}${enlaceAmazon.includes('?') ? '&' : '?'}tag=${AMAZON_TAG}`
  : enlaceAmazon;
---

<div class="top-pick">
  <div class="top-pick-badge">{etiqueta}</div>
  <div class="top-pick-body">
    {imagen && (
      <div class="top-pick-img-wrap">
        <img src={imagen} alt={nombre} width="160" height="160" class="top-pick-img" loading="lazy" />
      </div>
    )}
    <div class="top-pick-info">
      <p class="top-pick-nombre">{nombre}</p>
      <p class="top-pick-desc">{descripcion}</p>
      <p class="top-pick-precio">{precio}</p>
      <div class="top-pick-buttons">
        {amazonFinal && (
          <a href={amazonFinal} class="affiliate-button amazon" target="_blank" rel="nofollow noopener noreferrer sponsored">
            🛒 Consultar precio en Amazon
          </a>
        )}
        {enlaceZooplus && (
          <a href={enlaceZooplus} class="affiliate-button zooplus" target="_blank" rel="nofollow noopener noreferrer sponsored">
            🛒 Ver en Zooplus
          </a>
        )}
      </div>
    </div>
  </div>
</div>

<style>
.top-pick {
  border: 2px solid var(--color-primary);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  margin: 1.5rem 0;
  background: color-mix(in srgb, var(--color-primary) 4%, var(--color-bg));
  position: relative;
}

.top-pick-badge {
  position: absolute;
  top: -0.7rem;
  left: 1.25rem;
  background: var(--color-primary);
  color: white;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 0.2rem 0.75rem;
  border-radius: 100px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.top-pick-body {
  display: flex;
  gap: 1.5rem;
  align-items: flex-start;
  margin-top: 0.25rem;
}

.top-pick-img-wrap {
  flex-shrink: 0;
  background: var(--color-bg-muted);
  border-radius: var(--radius-md);
  padding: 0.75rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.top-pick-img {
  width: 140px;
  height: 140px;
  object-fit: contain;
}

.top-pick-info {
  flex: 1;
  min-width: 0;
}

.top-pick-nombre {
  font-size: 1.15rem;
  font-weight: 800;
  margin: 0 0 0.4rem;
  color: var(--color-text);
  letter-spacing: -0.02em;
}

.top-pick-desc {
  font-size: 0.9rem;
  color: var(--color-text-muted);
  margin: 0 0 0.75rem;
  line-height: 1.5;
}

.top-pick-precio {
  font-size: 1.3rem;
  font-weight: 800;
  margin: 0 0 1rem;
  color: var(--color-primary);
  letter-spacing: -0.02em;
}

.top-pick-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

@media (max-width: 540px) {
  .top-pick-body {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .top-pick-img {
    width: 160px;
    height: 160px;
  }

  .top-pick-buttons {
    justify-content: center;
  }
}
</style>
